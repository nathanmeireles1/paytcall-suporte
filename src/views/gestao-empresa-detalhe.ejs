<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= empresa.nome %> — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-empresas' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: empresa.nome, breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Empresas', href: '/gestao/empresas' },
      { label: empresa.nome }
    ] }) %>

    <div class="page">

      <div class="page-header">
        <div>
          <h1 class="page-title"><%= empresa.nome %></h1>
          <% if (empresa.segmento) { %>
            <p class="page-subtitle"><%= empresa.segmento %></p>
          <% } %>
        </div>
        <% if (empresa.status) { %>
          <% if (empresa.status === 'Ativo' || empresa.status === 'ativo') { %>
            <span class="badge badge-success" style="align-self:center">Ativo</span>
          <% } else { %>
            <span class="badge badge-neutral" style="align-self:center"><%= empresa.status %></span>
          <% } %>
        <% } %>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start">

        <!-- Informações da empresa -->
        <div class="card">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span style="font-weight:600;font-size:14px">Informações</span>
          </div>
          <div class="card-body">
            <dl style="display:grid;grid-template-columns:auto 1fr;gap:8px 16px;font-size:13px">
              <% if (empresa.cnpj) { %>
                <dt style="color:var(--text-3)">CNPJ</dt>
                <dd style="margin:0"><%= empresa.cnpj %></dd>
              <% } %>
              <% if (empresa.email) { %>
                <dt style="color:var(--text-3)">Email</dt>
                <dd style="margin:0"><%= empresa.email %></dd>
              <% } %>
              <% if (empresa.telefone) { %>
                <dt style="color:var(--text-3)">Telefone</dt>
                <dd style="margin:0"><%= empresa.telefone %></dd>
              <% } %>
              <% if (empresa.contato) { %>
                <dt style="color:var(--text-3)">Contato</dt>
                <dd style="margin:0"><%= empresa.contato %></dd>
              <% } %>
              <% if (empresa.site) { %>
                <dt style="color:var(--text-3)">Site</dt>
                <dd style="margin:0"><a href="<%= empresa.site %>" target="_blank" rel="noopener" style="color:var(--brand)"><%= empresa.site %></a></dd>
              <% } %>
              <% if (empresa.cidade || empresa.estado) { %>
                <dt style="color:var(--text-3)">Localização</dt>
                <dd style="margin:0"><%= [empresa.cidade, empresa.estado].filter(Boolean).join(' / ') %></dd>
              <% } %>
              <% if (empresa.dt_criacao) { %>
                <dt style="color:var(--text-3)">Cadastro</dt>
                <dd style="margin:0"><%= new Date(empresa.dt_criacao).toLocaleDateString('pt-BR') %></dd>
              <% } %>
            </dl>
            <% if (empresa.descricao) { %>
              <hr style="border:none;border-top:1px solid var(--border);margin:12px 0">
              <p style="font-size:13px;color:var(--text-2);line-height:1.6;margin:0"><%= empresa.descricao %></p>
            <% } %>
          </div>
        </div>

        <!-- Notas e follow-ups -->
        <div>
          <% if (canManage) { %>
          <div class="card" style="margin-bottom:16px">
            <div class="card-header">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              <span style="font-weight:600;font-size:14px">Nova Nota</span>
            </div>
            <div class="card-body">
              <form method="POST" action="/gestao/empresas/<%= empresa.id %>/notas">
                <div style="margin-bottom:10px">
                  <label class="form-label">Anotação</label>
                  <textarea name="conteudo" class="form-input" rows="3" placeholder="Registre um follow-up, observação ou contato..." required style="resize:vertical"></textarea>
                </div>
                <div style="margin-bottom:12px">
                  <label class="form-label">Data de follow-up (opcional)</label>
                  <input type="date" name="data_followup" class="form-input">
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Salvar nota</button>
              </form>
            </div>
          </div>
          <% } %>

          <div class="card" style="padding:0">
            <div class="card-header">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span style="font-weight:600;font-size:14px">Notas (<%= notas.length %>)</span>
            </div>
            <% if (notas.length === 0) { %>
              <div style="padding:24px;text-align:center;color:var(--text-3);font-size:13px">
                Nenhuma nota registrada ainda
              </div>
            <% } else { %>
              <div style="max-height:480px;overflow-y:auto">
                <% notas.forEach(n => { %>
                <div style="padding:14px 16px;border-bottom:1px solid var(--border)">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                    <span style="font-size:12px;font-weight:600;color:var(--text-2)"><%= n.autor || 'Sistema' %></span>
                    <span style="font-size:11px;color:var(--text-4)">
                      <%= new Date(n.dt_criacao).toLocaleDateString('pt-BR') %>
                    </span>
                  </div>
                  <p style="font-size:13px;color:var(--text);margin:0;line-height:1.5"><%= n.conteudo %></p>
                  <% if (n.data_followup) { %>
                    <div style="margin-top:6px">
                      <span style="font-size:11px;background:var(--warning-bg);color:var(--warning);border:1px solid var(--warning-border);border-radius:4px;padding:2px 7px">
                        Follow-up: <%= new Date(n.data_followup).toLocaleDateString('pt-BR') %>
                      </span>
                    </div>
                  <% } %>
                </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

      </div><!-- /grid -->

    </div><!-- /.page -->
  </div><!-- /.main -->

  <%- include('partials/ai-chat') %>
</div>
</body>
</html>
