<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= empresa.nome %> — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-catalogo' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: empresa.nome, breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Catálogo', href: '/gestao/catalogo?tab=empresas' },
      { label: empresa.nome }
    ] }) %>

    <div class="page">

      <div class="page-header">
        <div>
          <h1 class="page-title"><%= empresa.nome %></h1>
          <% if (empresa.segmento) { %>
            <p class="page-subtitle"><%= empresa.segmento %></p>
          <% } %>
          <div style="display:flex;gap:8px;align-items:center;margin-top:10px">
          <% if (empresa.status === 'Ativo' || empresa.status === 'ativo') { %>
            <span class="badge badge-success">Ativo</span>
          <% } else if (empresa.status) { %>
            <span class="badge badge-neutral"><%= empresa.status %></span>
          <% } %>
          <% if (canEdit) { %>
            <button class="btn btn-secondary btn-sm" onclick="openModal('modal-editar-empresa')">Editar</button>
          <% } %>
          <% if (isAdmin) { %>
            <button class="btn btn-sm" style="background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger-border)" onclick="confirmarExclusao()">Excluir</button>
          <% } %>
          </div>
        </div>
      </div>

      <!-- Grid: Informações + Feedbacks -->
      <div class="col-layout-2">

        <!-- Informações da empresa -->
        <div class="card">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span style="font-weight:600;font-size:14px">Informações</span>
          </div>
          <div class="card-body">
            <dl style="display:grid;grid-template-columns:auto 1fr;gap:8px 16px;font-size:13px">
              <% if (empresa.cnpj) { %>
                <dt style="color:var(--text-3)">CNPJ</dt><dd style="margin:0"><%= empresa.cnpj %></dd>
              <% } %>
              <% if (empresa.email) { %>
                <dt style="color:var(--text-3)">Email</dt><dd style="margin:0"><%= empresa.email %></dd>
              <% } %>
              <% if (empresa.telefone) { %>
                <dt style="color:var(--text-3)">Telefone</dt><dd style="margin:0"><%= empresa.telefone %></dd>
              <% } %>
              <% if (empresa.contato) { %>
                <dt style="color:var(--text-3)">Contato</dt><dd style="margin:0"><%= empresa.contato %></dd>
              <% } %>
              <% if (empresa.site) { %>
                <dt style="color:var(--text-3)">Site</dt>
                <dd style="margin:0"><a href="<%= empresa.site %>" target="_blank" rel="noopener" style="color:var(--brand)"><%= empresa.site %></a></dd>
              <% } %>
              <% if (empresa.cidade || empresa.estado) { %>
                <dt style="color:var(--text-3)">Localização</dt>
                <dd style="margin:0"><%= [empresa.cidade, empresa.estado].filter(Boolean).join(' / ') %></dd>
              <% } %>
              <% if (empresa.dt_criacao) { %>
                <dt style="color:var(--text-3)">Cadastro</dt>
                <dd style="margin:0"><%= new Date(empresa.dt_criacao).toLocaleDateString('pt-BR') %></dd>
              <% } %>
            </dl>
            <% if (empresa.descricao) { %>
              <hr style="border:none;border-top:1px solid var(--border);margin:12px 0">
              <p style="font-size:13px;color:var(--text-2);line-height:1.6;margin:0"><%= empresa.descricao %></p>
            <% } %>
          </div>
        </div>

        <!-- Lista de feedbacks -->
        <div class="card" style="padding:0">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            <span style="font-weight:600;font-size:14px">Feedbacks (<%= feedbacks.length %>)</span>
          </div>
          <div style="max-height:420px;overflow-y:auto">
            <%- include('partials/feedback-list', {
              feedbacks,
              redirectUrl: '/gestao/empresas/' + empresa.id,
              currentUserName: currentUser.name || currentUser.email,
              isAdmin
            }) %>
          </div>
        </div>

      </div>

      <!-- Produtos da empresa -->
      <div class="card" style="margin-top:20px">
        <div class="card-header">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
          <span style="font-weight:600;font-size:14px">Produtos (<%= produtos.length %>)</span>
        </div>
        <% if (produtos.length === 0) { %>
        <div class="card-body" style="text-align:center;color:var(--text-4);font-size:13px;padding:24px">
          Nenhum produto vinculado a esta empresa. Para vincular, edite o produto e preencha o campo "Empresa" com o nome exato: <strong><%= empresa.nome %></strong>
        </div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead><tr>
              <th>Nome</th>
              <th>Nicho</th>
              <th>SKU</th>
              <th>Status</th>
            </tr></thead>
            <tbody>
              <% produtos.forEach(p => { %>
              <tr style="cursor:pointer" onclick="location.href='/gestao/produtos/<%= p.id %>'">
                <td style="font-weight:500;color:var(--text)"><%= p.nome %></td>
                <td style="color:var(--text-3)"><%= p.nicho || '—' %></td>
                <td style="color:var(--text-3)"><%= p.sku || '—' %></td>
                <td><% if (p.status) { %><span class="badge <%= p.status === 'Ativo' ? 'badge-success' : 'badge-neutral' %>"><%= p.status %></span><% } else { %><span style="color:var(--text-4)">—</span><% } %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- Formulário de feedback — largura total -->
      <div class="card" style="margin-top:20px">
        <div class="card-header">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <span style="font-weight:600;font-size:14px">Registrar Feedback</span>
        </div>
        <div class="card-body">
          <form method="POST" action="/gestao/feedbacks" style="display:flex;gap:12px;align-items:flex-end">
            <input type="hidden" name="empresa" value="<%= empresa.nome %>">
            <input type="hidden" name="redirect" value="/gestao/empresas/<%= empresa.id %>">
            <div style="flex:1">
              <textarea name="texto" class="form-input" rows="4" placeholder="Registre um problema, observação ou informação relevante sobre esta empresa..." required style="resize:vertical;width:100%"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="white-space:nowrap">Salvar</button>
          </form>
        </div>
      </div>

    </div><!-- /.page -->
  </div><!-- /.main -->

  <%- include('partials/ai-chat') %>
</div>

<!-- Modal Editar Empresa -->
<% if (canEdit) { %>
<div id="modal-editar-empresa" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;overflow-y:auto;padding:40px 20px">
  <div class="card" style="max-width:560px;margin:0 auto">
    <div class="card-header" style="justify-content:space-between">
      <span style="font-weight:700;font-size:15px">Editar Empresa</span>
      <button onclick="closeModal('modal-editar-empresa')" style="background:none;border:none;cursor:pointer;color:var(--text-3);font-size:20px;line-height:1">&times;</button>
    </div>
    <form method="POST" action="/gestao/empresas/<%= empresa.id %>/editar">
      <div style="padding:20px;display:flex;flex-direction:column;gap:14px">
        <div class="form-group">
          <label class="form-label">Nome *</label>
          <input name="nome" class="form-input" required value="<%= empresa.nome %>">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">Segmento</label>
            <input name="segmento" class="form-input" value="<%= empresa.segmento || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
              <option value="">—</option>
              <option value="Ativo" <%= empresa.status === 'Ativo' ? 'selected' : '' %>>Ativo</option>
              <option value="Inativo" <%= empresa.status === 'Inativo' ? 'selected' : '' %>>Inativo</option>
            </select>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">CNPJ</label>
            <input name="cnpj" class="form-input" value="<%= empresa.cnpj || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-input" value="<%= empresa.email || '' %>">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">Telefone</label>
            <input name="telefone" class="form-input" value="<%= empresa.telefone || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Contato</label>
            <input name="contato" class="form-input" value="<%= empresa.contato || '' %>">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 80px;gap:12px">
          <div class="form-group">
            <label class="form-label">Cidade</label>
            <input name="cidade" class="form-input" value="<%= empresa.cidade || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">UF</label>
            <input name="estado" class="form-input" maxlength="2" value="<%= empresa.estado || '' %>">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Site</label>
          <input name="site" class="form-input" value="<%= empresa.site || '' %>">
        </div>
        <div class="form-group">
          <label class="form-label">Descrição</label>
          <textarea name="descricao" class="form-input" rows="3" style="resize:vertical"><%= empresa.descricao || '' %></textarea>
        </div>
      </div>
      <div class="card-footer" style="justify-content:flex-end;gap:8px">
        <button type="button" onclick="closeModal('modal-editar-empresa')" class="btn btn-secondary">Cancelar</button>
        <button type="submit" class="btn btn-primary">Salvar alterações</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<!-- Form exclusão oculto -->
<% if (isAdmin) { %>
<form id="form-excluir" method="POST" action="/gestao/empresas/<%= empresa.id %>/excluir" style="display:none"></form>
<% } %>

<script>
function openModal(id) { document.getElementById(id).style.display = ''; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }
document.querySelectorAll('[id^="modal-"]').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) closeModal(m.id); });
});
function confirmarExclusao() {
  showConfirm('Excluir a empresa "<%= empresa.nome %>"? Esta ação não pode ser desfeita.', () => {
    document.getElementById('form-excluir').submit();
  }, { okLabel: 'Excluir', okClass: 'btn-danger' });
}
function editarFb(id) {
  document.querySelector('.fb-view-' + id).style.display = 'none';
  document.querySelector('.fb-edit-' + id).style.display = '';
}
function cancelarEditFb(id) {
  document.querySelector('.fb-view-' + id).style.display = '';
  document.querySelector('.fb-edit-' + id).style.display = 'none';
}
</script>
</body>
</html>
