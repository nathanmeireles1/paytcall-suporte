<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>payt Tracker — Dashboard</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f5; color: #333; }

    .navbar { background: #1a1a2e; padding: 0 24px; display: flex; align-items: center; height: 56px; gap: 16px; }
    .navbar h1 { color: #fff; font-size: 18px; font-weight: 700; white-space: nowrap; }
    .navbar .nav-info { display: flex; gap: 20px; margin-left: auto; align-items: center; }
    .navbar .nav-info span { color: #888; font-size: 12px; white-space: nowrap; }
    .navbar .nav-info span strong { color: #ccc; font-weight: 500; }
    .navbar a.nav-refresh { color: #aaa; font-size: 13px; text-decoration: none; white-space: nowrap; border: 1px solid #333; border-radius: 6px; padding: 4px 10px; }
    .navbar a.nav-refresh:hover { color: #fff; border-color: #555; }

    .container { max-width: 1200px; margin: 0 auto; padding: 24px; }

    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .stat-card { background: #fff; border-radius: 10px; padding: 16px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .stat-card .label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: .5px; }
    .stat-card .value { font-size: 28px; font-weight: 700; margin-top: 4px; }
    .stat-card.total .value { color: #1a1a2e; }
    .stat-card.delivered .value { color: #16a34a; }
    .stat-card.transit .value { color: #2563eb; }
    .stat-card.attempt .value { color: #d97706; }
    .stat-card.returned .value { color: #dc2626; }
    .stat-card.out .value { color: #7c3aed; }

    .toolbar { background: #fff; border-radius: 10px; padding: 16px; box-shadow: 0 1px 4px rgba(0,0,0,.08); margin-bottom: 16px; display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
    .toolbar form { display: flex; gap: 12px; flex-wrap: wrap; width: 100%; }
    .toolbar input, .toolbar select { padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; outline: none; }
    .toolbar input:focus, .toolbar select:focus { border-color: #4f46e5; }
    .toolbar input[name="search"] { flex: 1; min-width: 200px; }
    .btn { padding: 8px 16px; border-radius: 6px; border: none; cursor: pointer; font-size: 14px; font-weight: 500; }
    .btn-primary { background: #4f46e5; color: #fff; }
    .btn-primary:hover { background: #4338ca; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .btn-ghost { background: transparent; border: 1px solid #ddd; color: #555; }
    .btn-ghost:hover { background: #f5f5f5; }

    .table-wrap { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.08); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed; }
    thead tr { background: #f8f8f8; }
    th { padding: 10px 12px; text-align: left; font-weight: 600; color: #555; font-size: 11px; text-transform: uppercase; letter-spacing: .5px; white-space: nowrap; overflow: hidden; }
    td { padding: 10px 12px; border-top: 1px solid #f0f0f0; vertical-align: middle; overflow: hidden; text-overflow: ellipsis; }
    tr:hover td { background: #fafafa; }
    tr.clickable { cursor: pointer; }
    tr.clickable:hover td { background: #f0f0ff; }
    col.col-code { width: 140px; }
    col.col-carrier { width: 80px; }
    col.col-company { width: 140px; }
    col.col-order { width: 90px; }
    col.col-product { width: 160px; }
    col.col-client { width: 180px; }
    col.col-status { width: 110px; }
    col.col-event { width: 160px; }
    col.col-date { width: 110px; }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 99px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .3px; }
    .badge-delivered { background: #dcfce7; color: #16a34a; }
    .badge-forwarded { background: #dbeafe; color: #2563eb; }
    .badge-posted_object { background: #e0f2fe; color: #0369a1; }
    .badge-delivering { background: #ede9fe; color: #7c3aed; }
    .badge-recipient_not_found { background: #fef3c7; color: #d97706; }
    .badge-returned { background: #fee2e2; color: #dc2626; }
    .badge-returning { background: #fce7f3; color: #9d174d; }
    .badge-waiting_client { background: #fef9c3; color: #854d0e; }
    .badge-overdue { background: #ffedd5; color: #c2410c; }
    .badge-wrong_address { background: #fee2e2; color: #991b1b; }
    .badge-delivery_problem { background: #fef3c7; color: #92400e; }
    .badge-pending { background: #f3f4f6; color: #6b7280; }
    .badge-no_tracking { background: #f1f5f9; color: #94a3b8; }

    .code { font-family: monospace; font-size: 13px; font-weight: 600; color: #1a1a2e; }
    .text-muted { color: #999; font-size: 12px; }

    .pagination { display: flex; gap: 8px; justify-content: center; margin-top: 20px; flex-wrap: wrap; }
    .pagination a { padding: 6px 12px; border-radius: 6px; border: 1px solid #ddd; font-size: 13px; text-decoration: none; color: #555; }
    .pagination a:hover { background: #f0f0f0; }
    .pagination a.active { background: #4f46e5; color: #fff; border-color: #4f46e5; }

    .empty { text-align: center; padding: 60px 20px; color: #999; }
    .empty svg { width: 48px; height: 48px; margin-bottom: 12px; opacity: .3; }

    .refresh-btn { margin-left: auto; }
  </style>
</head>
<body>

<nav class="navbar">
  <h1>payt Tracker</h1>
  <div class="nav-info">
    <% if (lastQueried) { %>
    <span>Última consulta: <strong><%= lastQueried %></strong></span>
    <% } else { %>
    <span>Última consulta: <strong>—</strong></span>
    <% } %>
    <span>Próxima janela: <strong><%= nextWindow %></strong></span>
    <a href="/api/tracking/refresh" class="nav-refresh" onclick="refreshAll(event)">↻ Atualizar todos</a>
  </div>
</nav>

<div class="container">

  <!-- Stats -->
  <div class="stats">
    <div class="stat-card total">
      <div class="label">Total</div>
      <div class="value"><%= stats.total %></div>
    </div>
    <div class="stat-card delivered">
      <div class="label">Entregues</div>
      <div class="value"><%= stats.delivered %></div>
    </div>
    <div class="stat-card transit">
      <div class="label">Em trânsito</div>
      <div class="value"><%= stats.in_transit %></div>
    </div>
    <div class="stat-card out">
      <div class="label">Saiu p/ entrega</div>
      <div class="value"><%= stats.out_for_delivery %></div>
    </div>
    <div class="stat-card attempt">
      <div class="label">Tentativa</div>
      <div class="value"><%= stats.delivery_attempt %></div>
    </div>
    <div class="stat-card returned">
      <div class="label">Devolvidos</div>
      <div class="value"><%= stats.returned %></div>
    </div>
    <div class="stat-card attempt">
      <div class="label">Ag. Retirada</div>
      <div class="value" style="color:#854d0e"><%= stats.waiting_client %></div>
    </div>
  </div>

  <!-- Filtros -->
  <div class="toolbar">
    <form method="GET" action="/">
      <input type="text" name="search" placeholder="Buscar código, pedido ou cliente..." value="<%= filters.search || '' %>">
      <select name="seller_id">
        <option value="">Todas as empresas</option>
        <% companies.forEach(c => { %>
          <option value="<%= c.seller_id %>" <%= filters.seller_id === c.seller_id ? 'selected' : '' %>>
            <%= c.company_name || c.seller_id %> (<%= c.total %>)
          </option>
        <% }) %>
      </select>
      <select name="status">
        <option value="">Todos os status</option>
        <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pendente</option>
        <option value="posted_object" <%= filters.status === 'posted_object' ? 'selected' : '' %>>Objeto Postado</option>
        <option value="forwarded" <%= filters.status === 'forwarded' ? 'selected' : '' %>>Encaminhado</option>
        <option value="delivering" <%= filters.status === 'delivering' ? 'selected' : '' %>>Saiu para entrega</option>
        <option value="recipient_not_found" <%= filters.status === 'recipient_not_found' ? 'selected' : '' %>>Tentativa / Dest. não encontrado</option>
        <option value="delivery_problem" <%= filters.status === 'delivery_problem' ? 'selected' : '' %>>Problema na entrega</option>
        <option value="wrong_address" <%= filters.status === 'wrong_address' ? 'selected' : '' %>>Endereço errado</option>
        <option value="waiting_client" <%= filters.status === 'waiting_client' ? 'selected' : '' %>>Aguardando retirada</option>
        <option value="delivered" <%= filters.status === 'delivered' ? 'selected' : '' %>>Entregue</option>
        <option value="returning" <%= filters.status === 'returning' ? 'selected' : '' %>>Devolvendo</option>
        <option value="returned" <%= filters.status === 'returned' ? 'selected' : '' %>>Devolvido</option>
        <option value="overdue" <%= filters.status === 'overdue' ? 'selected' : '' %>>Em atraso</option>
        <option value="no_tracking" <%= filters.status === 'no_tracking' ? 'selected' : '' %>>Sem rastreio gerado</option>
      </select>
      <button type="submit" class="btn btn-primary">Filtrar</button>
      <% if (filters.status || filters.search || filters.seller_id) { %>
        <a href="/" class="btn btn-ghost">Limpar</a>
      <% } %>
    </form>
  </div>

  <!-- Tabela -->
  <div class="table-wrap">
    <% if (shipments.length === 0) { %>
      <div class="empty">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4"/></svg>
        <p>Nenhum envio encontrado</p>
      </div>
    <% } else { %>
    <table>
      <colgroup>
        <col class="col-code"><col class="col-carrier"><col class="col-company">
        <col class="col-order"><col class="col-product"><col class="col-client">
        <col class="col-status"><col class="col-event"><col class="col-date">
      </colgroup>
      <thead>
        <tr>
          <th>Código</th><th>Transp.</th><th>Empresa</th>
          <th>Pedido</th><th>Produto</th><th>Cliente</th>
          <th>Status</th><th>Último evento</th><th>Atualizado</th>
        </tr>
      </thead>
      <tbody>
        <%
        const sLabel = {
          pending: 'Pendente', posted_object: 'Obj. Postado', forwarded: 'Em Trânsito',
          delivering: 'Saiu p/ Entrega', recipient_not_found: 'Dest. não encontrado',
          delivery_problem: 'Prob. Entrega', wrong_address: 'End. Incorreto',
          waiting_client: 'Ag. Retirada', delivered: 'Entregue',
          returning: 'Devolvendo', returned: 'Devolvido', overdue: 'Em Atraso',
          no_tracking: 'Sem Rastreio',
        };
        %>
        <% shipments.forEach(s => { %>
        <tr class="clickable" onclick="window.location='/shipment/<%= s.tracking_code %>'">
          <td><span class="code"><%= s.tracking_code %></span></td>
          <td><span class="text-muted"><%= s.carrier || '—' %></span></td>
          <td>
            <% if (s.company_name) { %>
              <span style="font-weight:600;color:#1a1a2e"><%= s.company_name %></span><br>
              <span class="text-muted"><%= s.seller_id %></span>
            <% } else { %>
              <span class="text-muted"><%= s.seller_id || '—' %></span>
            <% } %>
          </td>
          <td><% if (s.order_id) { %><%= s.order_id %><% } else { %><span class="text-muted">—</span><% } %></td>
          <td>
            <% if (s.product_name) { %>
              <%= s.product_name %>
              <% if (s.product_quantity > 1) { %><br><span class="text-muted">Qtd: <%= s.product_quantity %></span><% } %>
            <% } else { %><span class="text-muted">—</span><% } %>
          </td>
          <td>
            <% if (s.customer_name) { %><%= s.customer_name %><% } else { %><span class="text-muted">—</span><% } %>
            <% if (s.customer_email) { %><br><span class="text-muted"><%= s.customer_email %></span><% } %>
          </td>
          <td><span class="badge badge-<%= s.status %>"><%= sLabel[s.status] || s.status %></span></td>
          <td>
            <% if (s.last_event) { %><%= s.last_event %><% } else { %><span class="text-muted">—</span><% } %>
            <% if (s.last_event_date) { %><br><span class="text-muted"><%= s.last_event_date %></span><% } %>
          </td>
          <td><span class="text-muted"><%= s.updated_at ? new Date(s.updated_at).toLocaleString('pt-BR', {timeZone:'America/Sao_Paulo', day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—' %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- Paginação -->
  <% if (pages > 1) { %>
  <%
    const qs = (filters.status ? '&status=' + filters.status : '') + (filters.search ? '&search=' + filters.search : '') + (filters.seller_id ? '&seller_id=' + filters.seller_id : '');
    const pUrl = (p) => '?page=' + p + qs;
    const showPage = (p) => p === 1 || p === pages || (p >= currentPage - 2 && p <= currentPage + 2);
  %>
  <div class="pagination">
    <% if (currentPage > 1) { %><a href="<%= pUrl(currentPage - 1) %>">‹ Anterior</a><% } %>
    <% let lastShown = 0; for (let i = 1; i <= pages; i++) { %>
      <% if (showPage(i)) { %>
        <% if (lastShown && i - lastShown > 1) { %><span style="padding:6px 4px;color:#999">…</span><% } %>
        <a href="<%= pUrl(i) %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
        <% lastShown = i; %>
      <% } %>
    <% } %>
    <% if (currentPage < pages) { %><a href="<%= pUrl(currentPage + 1) %>">Próxima ›</a><% } %>
  </div>
  <% } %>

</div>

<script>
function refreshAll(e) {
  e.preventDefault();
  if (!confirm('Atualizar todos os envios ativos via H7?')) return;
  fetch('/api/tracking/refresh', {
    method: 'POST',
    headers: { 'x-admin-secret': '' }
  }).then(() => alert('Atualização iniciada! Aguarde alguns instantes.')).catch(() => alert('Erro ao iniciar atualização.'));
}
</script>
</body>
</html>
