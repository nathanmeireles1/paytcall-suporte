<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vendas — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    .period-btn {
      padding: 5px 11px;
      font-size: 12px;
      font-weight: 500;
      border: none;
      background: transparent;
      color: var(--text-3);
      border-radius: var(--radius);
      cursor: pointer;
      transition: background .15s, color .15s;
    }
    .period-btn.active,
    .period-btn:hover {
      background: var(--surface);
      color: var(--text);
      box-shadow: var(--shadow-xs);
    }
    .multiselect-wrap { position: relative; }
    .multiselect-btn {
      padding: 7px 12px;
      font-size: 13px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
      white-space: nowrap;
      min-width: 140px;
      text-align: left;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 6px;
    }
    .multiselect-btn.has-selection { border-color: var(--brand); background: var(--brand-dim); color: var(--brand-dark); }
    .multiselect-dropdown {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      z-index: 200;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-md);
      width: 240px;
      display: none;
    }
    .multiselect-dropdown.open { display: block; }
    .multiselect-search { padding: 8px; border-bottom: 1px solid var(--border); }
    .multiselect-search input { width: 100%; box-sizing: border-box; }
    .multiselect-list { max-height: 220px; overflow-y: auto; padding: 4px 0; }
    .multiselect-item { display: flex; align-items: center; gap: 8px; padding: 6px 12px; font-size: 13px; cursor: pointer; }
    .multiselect-item:hover { background: var(--surface-2); }
    .multiselect-footer { padding: 6px 10px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: var(--text-3); }
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 12px; margin-bottom: 20px; }
    .kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 16px; }
    .kpi-label { font-size: 11px; font-weight: 600; color: var(--text-3); text-transform: uppercase; letter-spacing: .04em; margin-bottom: 6px; }
    .kpi-value { font-size: 22px; font-weight: 700; color: var(--text); line-height: 1.1; }
    .kpi-sub { font-size: 12px; color: var(--text-3); margin-top: 4px; }
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .tables-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    @media (max-width: 900px) { .charts-grid, .tables-grid { grid-template-columns: 1fr; } }
    #customRange { display: none; gap: 8px; align-items: center; }
    #customRange.visible { display: flex; }
    .loading-overlay { position: absolute; inset: 0; background: rgba(255,255,255,.6); display: flex; align-items: center; justify-content: center; border-radius: inherit; z-index: 10; }
    html.dark .loading-overlay { background: rgba(0,0,0,.4); }
    .spinner { width: 22px; height: 22px; border: 2px solid var(--border); border-top-color: var(--brand); border-radius: 50%; animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .danger-text { color: var(--danger); }
  </style>
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-vendas' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: 'Vendas', breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Vendas' }
    ] }) %>

    <div class="page">

      <div class="p-page-header" style="margin-bottom:16px">
        <div class="p-page-header-left">
          <h1>Dashboard de Vendas</h1>
          <p class="p-subtitle">Faturamento e métricas em tempo real</p>
        </div>
        <div class="p-page-header-right">
          <a href="/gestao/vendas/import" class="btn btn-secondary btn-sm">↑ Importar Excel</a>
        </div>
      </div>

      <!-- Barra de filtros -->
      <div class="card" style="padding:14px 16px;margin-bottom:16px;overflow:visible">
        <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:center;overflow:visible">

          <!-- Período -->
          <div style="display:flex;gap:4px;background:var(--surface-2);border-radius:var(--radius-md);padding:3px">
            <% [['today','Hoje'],['7d','7 dias'],['30d','30 dias'],['90d','90 dias'],['12m','12 meses'],['all','Tudo'],['custom','Período']].forEach(([val,lbl]) => { %>
              <button class="period-btn <%= val === '30d' ? 'active' : '' %>" data-period="<%= val %>" onclick="setPeriod('<%= val %>')"><%= lbl %></button>
            <% }) %>
          </div>

          <!-- Período customizado -->
          <div id="customRange">
            <input type="date" id="customFrom" class="form-input" style="width:140px" onchange="loadData()">
            <span style="color:var(--text-3);font-size:13px">até</span>
            <input type="date" id="customTo" class="form-input" style="width:140px" onchange="loadData()">
          </div>

          <!-- Fonte (somente admin) -->
          <% if (isAdmin) { %>
          <div class="multiselect-wrap" id="msFonteWrap">
            <button type="button" class="multiselect-btn" id="msFonteBtn" onclick="toggleMs('msFonte')">
              <span id="msFonteLabel">Fonte</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="multiselect-dropdown" id="msFonteDropdown">
              <div class="multiselect-list" id="msFonteList">
                <div class="multiselect-item" onclick="selectFonte('all','Fonte')">Todas</div>
                <div class="multiselect-item" onclick="selectFonte('paytcall','Paytcall')">Paytcall</div>
              </div>
            </div>
          </div>

          <!-- Vendedora (somente admin) -->
          <div class="multiselect-wrap" id="msVendedoraWrap">
            <button type="button" class="multiselect-btn" id="msVendedoraBtn" onclick="toggleMs('msVendedora')">
              <span id="msVendedoraLabel">Vendedora</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="multiselect-dropdown" id="msVendedoraDropdown">
              <div class="multiselect-search"><input type="text" class="form-input" placeholder="Buscar..." oninput="filterMs('msVendedora', this.value)"></div>
              <div class="multiselect-list" id="msVendedoraList">
                <div class="multiselect-item" onclick="selectVendedora('all','Vendedora')">Todas</div>
                <% colaboradores.forEach(c => { %>
                  <div class="multiselect-item" onclick="selectVendedora('<%= c.email %>','<%= c.primeiro_nome || c.email.split('@')[0] %>')"><%= c.primeiro_nome || c.email.split('@')[0] %></div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <!-- Equipe (somente admin) -->
          <% if (isAdmin && equipes.length > 0) { %>
          <div class="multiselect-wrap" id="msEquipeWrap">
            <button type="button" class="multiselect-btn" id="msEquipeBtn" onclick="toggleMs('msEquipe')">
              <span id="msEquipeLabel">Equipe</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="multiselect-dropdown" id="msEquipeDropdown">
              <div class="multiselect-list" id="msEquipeList">
                <div class="multiselect-item" onclick="selectSingle('msEquipe','all','Equipe')">Todas</div>
                <% equipes.forEach(eq => { %>
                  <div class="multiselect-item" onclick="selectSingle('msEquipe','<%= eq %>','<%= eq %>')"><%= eq %></div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <!-- Tipo de venda -->
          <% if (tipos.length > 0) { %>
          <div class="multiselect-wrap" id="msTipoWrap">
            <button type="button" class="multiselect-btn" id="msTipoBtn" onclick="toggleMs('msTipo')">
              <span id="msTipoLabel">Tipo</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="multiselect-dropdown" id="msTipoDropdown">
              <div class="multiselect-list" id="msTipoList">
                <div class="multiselect-item" onclick="selectSingle('msTipo','all','Tipo')">Todos</div>
                <% tipos.forEach(t => { %>
                  <div class="multiselect-item" onclick="selectSingle('msTipo','<%= t %>','<%= t %>')"><%= t %></div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <!-- Forma de pagamento -->
          <% if (formas.length > 0) { %>
          <div class="multiselect-wrap" id="msFormaWrap">
            <button type="button" class="multiselect-btn" id="msFormaBtn" onclick="toggleMs('msForma')">
              <span id="msFormaLabel">Pagamento</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="multiselect-dropdown" id="msFormaDropdown">
              <div class="multiselect-list" id="msFormaList">
                <div class="multiselect-item" onclick="selectSingle('msForma','all','Pagamento')">Todas</div>
                <% formas.forEach(f => { const lbl = f === 'credit_card' ? 'Cartão de Crédito' : f === 'debit_card' ? 'Cartão de Débito' : f === 'pix' ? 'PIX' : f === 'pix_cnpj' ? 'PIX CNPJ' : f === 'boleto' ? 'Boleto' : f === 'cash_on_delivery' ? 'Pag. na Entrega' : f; %>
                  <div class="multiselect-item" onclick="selectSingle('msForma','<%= f %>','<%= lbl %>')"><%= lbl %></div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <!-- MultiSelect: Empresas -->
          <div class="multiselect-wrap" id="msEmpresasWrap">
            <button type="button" class="multiselect-btn" id="msEmpresasBtn" onclick="toggleMs('msEmpresas')">
              <span id="msEmpresasLabel">Empresas</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="multiselect-dropdown" id="msEmpresasDropdown">
              <div class="multiselect-search"><input type="text" class="form-input" placeholder="Buscar..." oninput="filterMs('msEmpresas', this.value)"></div>
              <div class="multiselect-list" id="msEmpresasList">
                <% empresas.forEach(e => { %>
                  <label class="multiselect-item"><input type="checkbox" value="<%= e %>" onchange="updateMs('msEmpresas')"> <%= e %></label>
                <% }) %>
              </div>
              <div class="multiselect-footer">
                <span id="msEmpresasCount">0 selecionadas</span>
                <button type="button" onclick="clearMs('msEmpresas')" style="background:none;border:none;color:var(--brand);cursor:pointer;font-size:11px;padding:0">Limpar</button>
              </div>
            </div>
          </div>

          <!-- MultiSelect: Produtos -->
          <div class="multiselect-wrap" id="msProdutosWrap">
            <button type="button" class="multiselect-btn" id="msProdutosBtn" onclick="toggleMs('msProdutos')">
              <span id="msProdutosLabel">Produtos</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="multiselect-dropdown" id="msProdutosDropdown">
              <div class="multiselect-search"><input type="text" class="form-input" placeholder="Buscar..." oninput="filterMs('msProdutos', this.value)"></div>
              <div class="multiselect-list" id="msProdutosList">
                <% produtos.forEach(p => { %>
                  <label class="multiselect-item"><input type="checkbox" value="<%= p %>" onchange="updateMs('msProdutos')"> <%= p %></label>
                <% }) %>
              </div>
              <div class="multiselect-footer">
                <span id="msProdutosCount">0 selecionados</span>
                <button type="button" onclick="clearMs('msProdutos')" style="background:none;border:none;color:var(--brand);cursor:pointer;font-size:11px;padding:0">Limpar</button>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- KPI Cards -->
      <div class="kpi-grid" id="kpiGrid">
        <div class="kpi-card">
          <div class="kpi-label">Faturamento</div>
          <div style="display:flex;align-items:baseline;gap:8px">
            <div class="kpi-value" id="kpiFaturamento">—</div>
            <span id="kpiDeltaFaturamento" style="font-size:12px;font-weight:600"></span>
          </div>
          <div class="kpi-sub" id="kpiTotalVendas">carregando...</div>
          <div style="height:36px;margin-top:8px;position:relative"><canvas id="sparkFaturamento"></canvas></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Ticket Médio</div>
          <div style="display:flex;align-items:baseline;gap:8px">
            <div class="kpi-value" id="kpiTicket">—</div>
            <span id="kpiDeltaTicket" style="font-size:12px;font-weight:600"></span>
          </div>
          <div class="kpi-sub">por venda paga</div>
          <div style="height:36px;margin-top:8px;position:relative"><canvas id="sparkTicket"></canvas></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Chargebacks</div>
          <div style="display:flex;align-items:baseline;gap:8px">
            <div class="kpi-value" id="kpiChargebacks">—</div>
            <span id="kpiDeltaCb" style="font-size:12px;font-weight:600"></span>
          </div>
          <div class="kpi-sub" id="kpiTaxaCb">taxa: —</div>
          <div id="sparkCb" style="margin-top:10px;height:6px;background:var(--surface-2);border-radius:99px;overflow:hidden">
            <div id="sparkCbBar" style="height:100%;width:0%;background:var(--danger);border-radius:99px;transition:width .4s"></div>
          </div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Reembolsos</div>
          <div style="display:flex;align-items:baseline;gap:8px">
            <div class="kpi-value" id="kpiReembolsos">—</div>
          </div>
          <div class="kpi-sub" id="kpiReembolsosTotal">total: —</div>
          <div id="sparkReemb" style="margin-top:10px;height:6px;background:var(--surface-2);border-radius:99px;overflow:hidden">
            <div id="sparkReembBar" style="height:100%;width:0%;background:var(--warning);border-radius:99px;transition:width .4s"></div>
          </div>
        </div>
      </div>

      <!-- Formas de Pagamento -->
      <div style="display:flex;gap:16px;margin-bottom:16px;align-items:start;flex-wrap:wrap" id="paymentSection">
        <div style="display:flex;flex-wrap:wrap;gap:12px;flex:1;min-width:0" id="paymentCards">
          <!-- preenchido pelo JS -->
        </div>
        <div class="card" style="padding:14px;width:190px;flex-shrink:0">
          <div style="font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.04em;margin-bottom:10px">Distribuição</div>
          <div style="position:relative;height:150px">
            <canvas id="chartFormas"></canvas>
          </div>
          <div id="formasLegend" style="margin-top:10px;display:flex;flex-direction:column;gap:4px;font-size:11px"></div>
        </div>
      </div>

      <!-- Gráfico de área + tabela diária -->
      <div class="charts-grid">
        <div class="card" style="padding:0;position:relative">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span style="font-weight:600;font-size:14px">Faturamento por Dia</span>
          </div>
          <div class="card-body" style="position:relative;height:220px">
            <canvas id="chartDiario"></canvas>
          </div>
          <div class="loading-overlay" id="loadingChart"><div class="spinner"></div></div>
        </div>

        <div class="card" style="padding:0;position:relative">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span style="font-weight:600;font-size:14px">Vendas por Dia</span>
            <span style="margin-left:auto;font-size:11px;color:var(--text-3)">mais recente primeiro</span>
          </div>
          <div class="table-wrap" style="max-height:280px;overflow-y:auto">
            <table id="tabelaDiariaTable">
              <thead id="tabelaDiariaThead">
                <tr><th>Data</th><th style="text-align:right">Geral</th></tr>
              </thead>
              <tbody id="tabelaDiaria">
                <tr><td colspan="2" style="text-align:center;color:var(--text-3);padding:24px">Carregando...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="loading-overlay" id="loadingTabela"><div class="spinner"></div></div>
        </div>
      </div>

      <!-- Top Empresas + Top Produtos -->
      <div class="tables-grid">
        <div class="card" style="padding:0;position:relative">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            <span style="font-weight:600;font-size:14px">Top Empresas</span>
            <span style="margin-left:auto;font-size:11px;color:var(--text-3)">por faturamento · top 5</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr><th>#</th><th>Empresa</th><th style="text-align:right">Vendas</th><th style="text-align:right">Faturamento</th></tr>
              </thead>
              <tbody id="topEmpresas">
                <tr><td colspan="4" style="text-align:center;color:var(--text-3);padding:24px">Carregando...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="loading-overlay" id="loadingEmpresas"><div class="spinner"></div></div>
        </div>

        <div class="card" style="padding:0;position:relative">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            <span style="font-weight:600;font-size:14px">Top Produtos</span>
            <span style="margin-left:auto;font-size:11px;color:var(--text-3)">por quantidade · top 5</span>
          </div>
          <div class="card-body" id="topProdutosContainer" style="padding:16px">
            <div style="text-align:center;color:var(--text-3);padding:20px">Carregando...</div>
          </div>
          <div class="loading-overlay" id="loadingProdutos"><div class="spinner"></div></div>
        </div>
      </div>

      <!-- Faturamento por Nichos -->
      <div class="card" style="padding:0;position:relative;margin-bottom:16px">
        <div class="card-header">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/><path d="M2 12h20"/></svg>
          <span style="font-weight:600;font-size:14px">Faturamento por Nicho</span>
          <span style="margin-left:auto;font-size:11px;color:var(--text-3)">vendas pagas</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Nicho</th>
                <th style="text-align:right">Qtd</th>
                <th style="text-align:right">Faturamento</th>
                <th style="text-align:right">% do total</th>
                <th style="width:120px"></th>
              </tr>
            </thead>
            <tbody id="topNichos">
              <tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:24px">Carregando...</td></tr>
            </tbody>
          </table>
        </div>
        <div class="loading-overlay" id="loadingNichos"><div class="spinner"></div></div>
      </div>

      <!-- Ranking de Vendedoras (somente admin) -->
      <% if (isAdmin) { %>
      <div class="card" style="padding:0;position:relative;margin-bottom:16px">
        <div class="card-header">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          <span style="font-weight:600;font-size:14px">Ranking de Vendedoras</span>
          <span style="margin-left:auto;font-size:11px;color:var(--text-3)" id="rankingPeriodLabel"></span>
        </div>
        <div class="card-body" id="rankingContainer" style="padding:16px">
          <div style="text-align:center;color:var(--text-3);padding:20px">Carregando...</div>
        </div>
        <div class="loading-overlay" id="loadingRanking"><div class="spinner"></div></div>
      </div>
      <% } %>

    </div><!-- /.page -->
  </div><!-- /.main -->

  <%- include('partials/ai-chat') %>
</div>

<script>
  // ── Estado ─────────────────────────────────────────────────────────────────
  let currentPeriod = '30d';
  let chartDiario = null;
  let chartFormas = null;
  let sparkFat = null, sparkTkt = null;
  let loadTimer = null;

  // ── Helpers de formatação ───────────────────────────────────────────────────
  function fmt(v) {
    return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(v || 0);
  }
  function fmtN(v) {
    return new Intl.NumberFormat('pt-BR').format(v || 0);
  }
  function fmtDate(s) {
    // s = "YYYY-MM-DD"
    if (!s) return '—';
    const [y, m, d] = s.split('-');
    return `${d}/${m}`;
  }
  function fmtDateFull(s) {
    if (!s) return '—';
    const [y, m, d] = s.split('-');
    return `${d}/${m}/${y}`;
  }

  // ── Período ─────────────────────────────────────────────────────────────────
  function setPeriod(p) {
    currentPeriod = p;
    document.querySelectorAll('.period-btn').forEach(b => b.classList.toggle('active', b.dataset.period === p));
    document.getElementById('customRange').classList.toggle('visible', p === 'custom');
    if (p !== 'custom') loadData();
  }

  // ── MultiSelect ─────────────────────────────────────────────────────────────
  function toggleMs(id) {
    const dd = document.getElementById(id + 'Dropdown');
    dd.classList.toggle('open');
  }
  function filterMs(id, q) {
    const list = document.getElementById(id + 'List');
    const lower = q.toLowerCase();
    list.querySelectorAll('.multiselect-item').forEach(el => {
      el.style.display = el.textContent.toLowerCase().includes(lower) ? '' : 'none';
    });
  }
  function updateMs(id) {
    const list = document.getElementById(id + 'List');
    const checked = [...list.querySelectorAll('input:checked')].map(i => i.value);
    const btn = document.getElementById(id + 'Btn');
    const label = document.getElementById(id + 'Label');
    const count = document.getElementById(id + 'Count');
    const defaultLabel = id === 'msEmpresas' ? 'Empresas' : 'Produtos';
    if (checked.length === 0) {
      label.textContent = defaultLabel;
      btn.classList.remove('has-selection');
    } else if (checked.length === 1) {
      label.textContent = checked[0].length > 20 ? checked[0].slice(0,18)+'…' : checked[0];
      btn.classList.add('has-selection');
    } else {
      label.textContent = `${checked.length} ${id === 'msEmpresas' ? 'empresas' : 'produtos'}`;
      btn.classList.add('has-selection');
    }
    count.textContent = `${checked.length} selecionada${checked.length !== 1 ? 's' : ''}`;
    loadData();
  }
  function clearMs(id) {
    document.getElementById(id + 'List').querySelectorAll('input').forEach(i => i.checked = false);
    updateMs(id);
  }
  function getMs(id) {
    return [...document.getElementById(id + 'List').querySelectorAll('input:checked')].map(i => i.value);
  }

  // Single-select genérico (Equipe, Tipo, Forma)
  const _single = { msEquipe: 'all', msTipo: 'all', msForma: 'all' };
  function selectSingle(id, value, label) {
    _single[id] = value;
    document.getElementById(id + 'Label').textContent = label;
    document.getElementById(id + 'Btn').classList.toggle('has-selection', value !== 'all');
    document.getElementById(id + 'Dropdown').classList.remove('open');
    loadData();
  }

  // Fonte e Vendedora: single-select dropdowns
  let currentFonte    = 'all';
  let currentVendedora = 'all';

  function selectFonte(value, label) {
    currentFonte = value;
    document.getElementById('msFonteLabel').textContent = label;
    document.getElementById('msFonteBtn').classList.toggle('has-selection', value !== 'all');
    document.getElementById('msFonteDropdown').classList.remove('open');
    loadData();
  }

  function selectVendedora(email, label) {
    currentVendedora = email;
    document.getElementById('msVendedoraLabel').textContent = label;
    document.getElementById('msVendedoraBtn').classList.toggle('has-selection', email !== 'all');
    document.getElementById('msVendedoraDropdown').classList.remove('open');
    loadData();
  }

  // Fecha dropdown ao clicar fora
  document.addEventListener('mousedown', e => {
    ['msEmpresas','msProdutos','msFonte','msVendedora','msEquipe','msTipo','msForma'].forEach(id => {
      const wrap = document.getElementById(id + 'Wrap');
      if (wrap && !wrap.contains(e.target)) {
        document.getElementById(id + 'Dropdown').classList.remove('open');
      }
    });
  });

  // ── Loading ─────────────────────────────────────────────────────────────────
  function setLoading(on) {
    ['Chart','Tabela','Empresas','Produtos','Nichos','Ranking'].forEach(id => {
      const el = document.getElementById('loading' + id);
      if (el) el.style.display = on ? 'flex' : 'none';
    });
  }

  // ── Cálculo de período anterior para comparação ───────────────────────────────
  function buildParams(overridePeriod, overrideFrom, overrideTo) {
    const p = new URLSearchParams({ period: overridePeriod || currentPeriod });
    // Se datas explícitas foram passadas (período anterior), usa como custom diretamente
    if (overrideFrom) {
      p.set('period', 'custom');
      p.set('dateFrom', overrideFrom);
      p.set('dateTo',   overrideTo);
    } else if ((overridePeriod || currentPeriod) === 'today') {
      const now = new Date();
      const t = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
      p.set('period', 'custom');
      p.set('dateFrom', t);
      p.set('dateTo',   t);
    } else if ((overridePeriod || currentPeriod) === 'custom') {
      p.set('dateFrom', document.getElementById('customFrom').value || '');
      p.set('dateTo',   document.getElementById('customTo').value   || '');
    }
    if (_single.msEquipe !== 'all') p.set('equipe', _single.msEquipe);
    if (_single.msTipo   !== 'all') p.set('tipo',   _single.msTipo);
    if (_single.msForma  !== 'all') p.set('forma',  _single.msForma);
    if (currentFonte     !== 'all') p.set('fonte',     currentFonte);
    if (currentVendedora !== 'all') p.set('vendedora', currentVendedora);
    const msE = getMs('msEmpresas'); if (msE.length) p.set('empresas', msE.join(','));
    const msP = getMs('msProdutos'); if (msP.length) p.set('produtos', msP.join(','));
    return p;
  }

  function getPrevDates() {
    // Retorna {from, to} do período anterior de mesmo tamanho, ou null para 'all'
    if (currentPeriod === 'all') return null;
    const now = new Date();
    const pad = n => String(n).padStart(2,'0');
    const fmt = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
    const days = { 'today': 1, '7d': 7, '30d': 30, '90d': 90, '12m': 365 }[currentPeriod];
    if (days) {
      const prevTo = new Date(now); prevTo.setDate(prevTo.getDate() - days);
      const prevFrom = new Date(prevTo); prevFrom.setDate(prevFrom.getDate() - days);
      return { from: fmt(prevFrom), to: fmt(prevTo) };
    }
    if (currentPeriod === 'custom') {
      const fromVal = document.getElementById('customFrom').value;
      const toVal   = document.getElementById('customTo').value;
      if (!fromVal || !toVal) return null;
      const fromD = new Date(fromVal), toD = new Date(toVal);
      const diff = Math.round((toD - fromD) / 86400000) + 1;
      const prevTo = new Date(fromD); prevTo.setDate(prevTo.getDate() - 1);
      const prevFrom = new Date(prevTo); prevFrom.setDate(prevFrom.getDate() - diff + 1);
      return { from: fmt(prevFrom), to: fmt(prevTo) };
    }
    return null;
  }

  // ── Carga de dados ───────────────────────────────────────────────────────────
  async function loadData() {
    clearTimeout(loadTimer);
    loadTimer = setTimeout(_load, 200);
  }

  async function _load() {
    setLoading(true);
    try {
      const params = buildParams();
      const prevDates = getPrevDates();

      const fetches = [fetch('/gestao/api/vendas?' + params)];
      // Período anterior: lite=1 (só KPIs, sem formasQuery pesada)
      if (prevDates) fetches.push(fetch('/gestao/api/vendas?' + buildParams(null, prevDates.from, prevDates.to) + '&lite=1'));
      fetches.push(fetch('/gestao/api/vendas/ranking?' + params));

      const results = await Promise.all(fetches);
      const [r, rPrev, rRank] = [results[0], prevDates ? results[1] : null, results[prevDates ? 2 : 1]];

      const d = await r.json();
      if (!r.ok || d.error) throw new Error(d.error || 'Erro ' + r.status);

      let prevKpis = null;
      if (rPrev) {
        const dp = await rPrev.json();
        if (rPrev.ok && !dp.error) prevKpis = dp.kpis;
      }

      renderKpis(d.kpis, prevKpis, d.daily);
      renderPaymentSection(d.formasPagamento || [], d.kpis);
      renderChart(d.daily);
      renderTabelaDiaria(d.daily);
      renderTopEmpresas(d.topEmpresas);
      renderTopProdutos(d.topProdutos);
      renderNichos(d.topNichos || []);

      if (rRank) {
        const dRank = await rRank.json();
        renderRanking(dRank.ranking || [], dRank.rankingByRegiao || {}, params);
      }
    } catch (err) {
      console.error('[Vendas]', err);
      const msg = `<tr><td colspan="4" style="text-align:center;color:var(--danger);padding:16px">Erro: ${err.message}</td></tr>`;
      ['tabelaDiaria','topEmpresas','topProdutos'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = msg;
      });
    } finally {
      setLoading(false);
    }
  }

  // ── Renderização ─────────────────────────────────────────────────────────────
  function renderDelta(elId, current, prev, higherIsBetter = true) {
    const el = document.getElementById(elId);
    if (!el || prev === null || prev === undefined || prev === 0) { if (el) el.textContent = ''; return; }
    const pct = ((current - prev) / Math.abs(prev)) * 100;
    const up = pct >= 0;
    const color = (up === higherIsBetter) ? 'var(--success)' : 'var(--danger)';
    el.style.color = color;
    el.textContent = `${up ? '▲' : '▼'} ${Math.abs(pct).toFixed(1)}%`;
  }

  // datasets: [{values, color, main}] — main=true é a linha grossa com fill
  function renderSparkline(canvasId, datasets, refVar) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    if (refVar && refVar.chart) { refVar.chart.destroy(); refVar.chart = null; }
    const mainDs = datasets.find(d => d.main);
    if (!mainDs || !mainDs.values || mainDs.values.length < 2) {
      const wrap = canvas.parentElement; if (wrap) wrap.style.display = 'none';
      return;
    }
    const wrap = canvas.parentElement; if (wrap) wrap.style.display = '';
    canvas.style.display = 'block';
    const maxLen = Math.max(...datasets.map(d => d.values.length));
    const ctx = canvas.getContext('2d');
    const chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: Array.from({ length: maxLen }, (_, i) => i),
        datasets: datasets.map(d => ({
          data: d.values,
          borderColor: d.color,
          borderWidth: d.main ? 2 : 1,
          pointRadius: 0,
          fill: d.main,
          backgroundColor: d.main ? d.color.replace(')', ', 0.12)').replace('rgb', 'rgba') : 'transparent',
          tension: 0.3,
        })),
      },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: { x: { display: false }, y: { display: false } },
        elements: { line: { borderCapStyle: 'round' } },
      },
    });
    if (refVar) refVar.chart = chart;
  }

  function renderKpis(k, prev, daily) {
    document.getElementById('kpiFaturamento').textContent = fmt(k.faturamento);
    document.getElementById('kpiTotalVendas').textContent = `${fmtN(k.totalPaid)} vendas pagas`;
    document.getElementById('kpiTicket').textContent = fmt(k.ticketMedio);
    document.getElementById('kpiChargebacks').textContent = fmtN(k.chargebacks);
    const taxaEl = document.getElementById('kpiTaxaCb');
    taxaEl.textContent = `taxa: ${k.taxaCb.toFixed(1)}%`;
    taxaEl.className = 'kpi-sub' + (k.taxaCb > 5 ? ' danger-text' : '');
    document.getElementById('kpiReembolsos').textContent = fmtN(k.reembolsos || 0);
    document.getElementById('kpiReembolsosTotal').textContent = `total: ${fmt(k.reembolsosTotal || 0)}`;

    // Barra de chargebacks (% do total)
    const cbPct = k.totalPaid ? Math.min((k.chargebacks / k.totalPaid) * 100, 100) : 0;
    document.getElementById('sparkCbBar').style.width = cbPct + '%';
    const reembPct = k.totalPaid ? Math.min(((k.reembolsos || 0) / k.totalPaid) * 100, 100) : 0;
    document.getElementById('sparkReembBar').style.width = reembPct + '%';

    // Sparklines de Faturamento e Ticket Médio
    if (daily && daily.length > 1) {
      renderSparkline('sparkFaturamento', [{ values: daily.map(d => d.total), color: 'rgb(228,124,36)', main: true }], { get chart() { return sparkFat; }, set chart(v) { sparkFat = v; } });
      renderSparkline('sparkTicket', [{ values: daily.map(d => d.count ? d.total / d.count : 0), color: 'rgb(99,102,241)', main: true }], { get chart() { return sparkTkt; }, set chart(v) { sparkTkt = v; } });
    }

    // Deltas vs período anterior
    if (prev) {
      renderDelta('kpiDeltaFaturamento', k.faturamento, prev.faturamento, true);
      renderDelta('kpiDeltaTicket',      k.ticketMedio, prev.ticketMedio, true);
      renderDelta('kpiDeltaCb',          k.chargebacks, prev.chargebacks, false);
    } else {
      ['kpiDeltaFaturamento','kpiDeltaTicket','kpiDeltaCb'].forEach(id => {
        const el = document.getElementById(id); if (el) el.textContent = '';
      });
    }
  }

  const EMPRESA_COLORS = ['#6366f1','#22c55e','#0ea5e9','#f59e0b','#ec4899','#8b5cf6','#14b8a6','#ef4444'];

  const FORMA_LABELS = {
    pix: 'PIX', credit_card: 'Cartão de Crédito', debit_card: 'Cartão de Débito',
    boleto: 'Boleto', pix_cnpj: 'PIX CNPJ', cash_on_delivery: 'Pag. na Entrega', outros: 'Outros',
  };
  const FORMA_COLORS = ['#e47c24','#6366f1','#22c55e','#0ea5e9','#f59e0b','#ec4899','#8b5cf6','#14b8a6'];

  function renderPaymentSection(formas, kpis) {
    const container = document.getElementById('paymentCards');
    if (!container) return;

    if (!formas.length) { container.innerHTML = '<span style="color:var(--text-3);font-size:13px">Sem dados de pagamento</span>'; return; }

    const totalGeral = formas.reduce((s, f) => s + f.total, 0) || 1;

    container.innerHTML = formas.map((f, i) => {
      const pct = ((f.total / totalGeral) * 100).toFixed(1);
      const label = FORMA_LABELS[f.forma] || f.forma;
      const color = FORMA_COLORS[i % FORMA_COLORS.length];
      const ticket = f.count ? f.total / f.count : 0;
      return `<div class="kpi-card" style="min-width:155px;flex:0 1 165px">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
          <div style="width:8px;height:8px;border-radius:99px;background:${color};flex-shrink:0"></div>
          <div class="kpi-label" style="margin:0">${label}</div>
        </div>
        <div class="kpi-value" style="font-size:18px">${fmtN(f.count)}</div>
        <div class="kpi-sub" style="margin-top:2px">${fmt(f.total)}</div>
        <div class="kpi-sub" style="margin-top:1px">Ticket: ${fmt(ticket)}</div>
        <div style="margin-top:8px;height:4px;background:var(--surface-2);border-radius:99px;overflow:hidden">
          <div style="height:100%;width:${pct}%;background:${color};border-radius:99px;transition:width .4s"></div>
        </div>
        <div style="font-size:10px;color:var(--text-4);margin-top:3px;text-align:right">${pct}%</div>
      </div>`;
    }).join('');

    // Gráfico de pizza
    const labels = formas.map(f => FORMA_LABELS[f.forma] || f.forma);
    const data   = formas.map(f => f.total);
    const colors = formas.map((_, i) => FORMA_COLORS[i % FORMA_COLORS.length]);

    const ctx = document.getElementById('chartFormas');
    if (!ctx) return;
    if (chartFormas) chartFormas.destroy();
    chartFormas = new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth: 0, hoverOffset: 4 }] },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: c => ` ${c.label}: ${fmt(c.raw)} (${((c.raw/totalGeral)*100).toFixed(1)}%)` } },
        },
        cutout: '60%',
      },
    });

    // Legenda manual
    const legendEl = document.getElementById('formasLegend');
    if (legendEl) {
      legendEl.innerHTML = formas.slice(0,5).map((f, i) => `
        <div style="display:flex;align-items:center;gap:5px">
          <div style="width:8px;height:8px;border-radius:2px;background:${FORMA_COLORS[i % FORMA_COLORS.length]};flex-shrink:0"></div>
          <span style="color:var(--text-3)">${FORMA_LABELS[f.forma] || f.forma}</span>
        </div>`).join('');
    }
  }

  function renderRanking(ranking, rankingByRegiao, params) {
    const container = document.getElementById('rankingContainer');
    if (!container) return;
    const label = document.getElementById('rankingPeriodLabel');
    if (label) {
      const pStr = { 'today':'hoje', '7d':'últimos 7 dias', '30d':'últimos 30 dias', '90d':'últimos 90 dias', '12m':'últimos 12 meses', 'all':'todo o período' }[currentPeriod] || currentPeriod;
      label.textContent = pStr;
    }

    const regioes = Object.keys(rankingByRegiao || {}).sort();
    const columns = [
      { label: 'Geral', rows: ranking },
      ...regioes.map(reg => ({ label: reg, rows: rankingByRegiao[reg] || [] })),
    ];

    const fmtNome = email => email.split('@')[0].replace(/[._-]/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    const colCount = Math.min(columns.length, 5);
    container.style.display = 'grid';
    container.style.gridTemplateColumns = `repeat(${colCount}, 1fr)`;
    container.style.gap = '20px';

    container.innerHTML = columns.map(col => {
      const rows = col.rows.length
        ? col.rows.map((v, i) => {
            const nome = fmtNome(v.email);
            return `<tr>
              <td style="color:var(--text-4);width:18px;font-weight:${i<3?'700':'400'};font-size:11px">${i+1}</td>
              <td>
                <div style="font-weight:500;font-size:12px">${nome}</div>
                <div style="font-size:10px;color:var(--text-4)">${v.email}</div>
              </td>
              <td style="text-align:right;color:var(--text-3);font-size:12px">${fmtN(v.qtd)}</td>
              <td style="text-align:right;font-weight:600;color:var(--brand-dark);font-size:12px">${fmt(v.total)}</td>
            </tr>`;
          }).join('')
        : `<tr><td colspan="4" style="text-align:center;color:var(--text-3);padding:12px;font-size:12px">Sem dados</td></tr>`;
      return `<div>
        <div style="font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;border-bottom:1px solid var(--border);padding-bottom:6px">${col.label}</div>
        <table style="width:100%">
          <thead><tr>
            <th style="width:18px"></th>
            <th style="font-size:11px">Vendedora</th>
            <th style="text-align:right;font-size:11px">Qtd</th>
            <th style="text-align:right;font-size:11px">Fat.</th>
          </tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>`;
    }).join('');
  }

  function renderChart(daily) {
    const labels = daily.map(d => fmtDate(d.data));
    const ctx = document.getElementById('chartDiario').getContext('2d');
    if (chartDiario) chartDiario.destroy();
    chartDiario = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Faturamento',
          data: daily.map(d => d.total),
          borderColor: '#e47c24',
          backgroundColor: 'rgba(228,124,36,.1)',
          borderWidth: 2,
          pointRadius: daily.length > 60 ? 0 : 3,
          fill: true,
          tension: 0.3,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => fmt(ctx.raw) } } },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 11 }, maxTicksLimit: 12 } },
          y: { ticks: { callback: v => `R$ ${(v/1000).toFixed(0)}k`, font: { size: 11 } }, grid: { color: 'rgba(0,0,0,.05)' } },
        },
      },
    });
  }

  function renderTabelaDiaria(daily) {
    const tbody = document.getElementById('tabelaDiaria');
    const thead = document.getElementById('tabelaDiariaThead');
    if (thead) thead.innerHTML = '<tr><th>Data</th><th style="text-align:right">Vendas</th><th style="text-align:right">Faturamento</th><th style="text-align:right">Ticket Médio</th></tr>';
    if (!daily.length) { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--text-3);padding:20px">Sem dados no período</td></tr>'; return; }
    tbody.innerHTML = [...daily].reverse().map(d => `
      <tr>
        <td>${fmtDateFull(d.data)}</td>
        <td style="text-align:right">${fmtN(d.count)}</td>
        <td style="text-align:right;font-weight:500">${fmt(d.total)}</td>
        <td style="text-align:right;color:var(--text-3)">${d.count ? fmt(d.total / d.count) : '—'}</td>
      </tr>`).join('');
  }

  function renderTopEmpresas(top) {
    const tbody = document.getElementById('topEmpresas');
    const slice = top.slice(0, 5);
    if (!slice.length) { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--text-3);padding:20px">Sem dados</td></tr>'; return; }
    tbody.innerHTML = slice.map((e, i) => `
      <tr>
        <td style="color:var(--text-4);width:28px">${i+1}</td>
        <td style="font-weight:500">${e.label}</td>
        <td style="text-align:right;color:var(--text-3)">${fmtN(e.qtd)}</td>
        <td style="text-align:right;font-weight:600;color:var(--brand-dark)">${fmt(e.total)}</td>
      </tr>`).join('');
  }

  function _miniRankTable(rows, cols) {
    // cols: [{key,label,align,fmt}]
    const ths = cols.map(c => `<th style="text-align:${c.align||'left'};font-size:11px">${c.label}</th>`).join('');
    const trs = rows.length
      ? rows.map((r, i) => {
          const tds = cols.map(c => `<td style="text-align:${c.align||'left'};font-size:12px${c.bold?';font-weight:600;color:var(--brand-dark)':''}">${c.fmt ? c.fmt(r[c.key], r) : (r[c.key] ?? '—')}</td>`).join('');
          return `<tr><td style="color:var(--text-4);width:18px;font-size:11px;font-weight:${i<3?'700':'400'}">${i+1}</td>${tds}</tr>`;
        }).join('')
      : `<tr><td colspan="${cols.length+1}" style="text-align:center;color:var(--text-3);padding:10px;font-size:12px">Sem dados</td></tr>`;
    return `<table style="width:100%"><thead><tr><th style="width:18px"></th>${ths}</tr></thead><tbody>${trs}</tbody></table>`;
  }

  function renderTopProdutos(top) {
    const tbody = document.getElementById('topProdutosContainer');
    if (!tbody) return;
    tbody.style.display = '';
    tbody.style.gridTemplateColumns = '';
    if (!top || !top.length) { tbody.innerHTML = '<p style="color:var(--text-3);padding:8px 0">Sem dados</p>'; return; }
    tbody.innerHTML = `<table style="width:100%"><thead><tr><th>#</th><th>Produto</th><th style="text-align:right">Qtd</th><th style="text-align:right">Faturamento</th></tr></thead><tbody>${
      top.slice(0, 10).map((p, i) => `<tr>
        <td style="color:var(--text-4);width:28px">${i + 1}</td>
        <td style="font-weight:500">${p.label}</td>
        <td style="text-align:right;color:var(--text-3)">${fmtN(p.qtd)}</td>
        <td style="text-align:right;font-weight:600;color:var(--brand-dark)">${fmt(p.total)}</td>
      </tr>`).join('')
    }</tbody></table>`;
  }

  function renderNichos(nichos) {
    const tbody = document.getElementById('topNichos');
    if (!tbody) return;
    if (!nichos.length) {
      tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:20px">Sem dados no período</td></tr>';
      return;
    }
    const totalGeral = nichos.reduce((s, n) => s + n.total, 0) || 1;
    tbody.innerHTML = nichos.map((n, i) => {
      const pct = ((n.total / totalGeral) * 100).toFixed(1);
      return `<tr>
        <td style="color:var(--text-4);width:28px">${i + 1}</td>
        <td style="font-weight:500">${n.nicho}</td>
        <td style="text-align:right;color:var(--text-3)">${fmtN(n.qtd)}</td>
        <td style="text-align:right;font-weight:600;color:var(--brand-dark)">${fmt(n.total)}</td>
        <td style="text-align:right;color:var(--text-3)">${pct}%</td>
        <td style="padding-right:16px">
          <div style="height:4px;background:var(--surface-2);border-radius:99px;overflow:hidden">
            <div style="height:100%;width:${pct}%;background:var(--brand);border-radius:99px;transition:width .4s"></div>
          </div>
        </td>
      </tr>`;
    }).join('');
  }

  // ── Init ─────────────────────────────────────────────────────────────────────
  loadData();
</script>
</body>
</html>
