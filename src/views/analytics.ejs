<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Análises — Paytcall Operações</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    @media print {
      .no-print, .sidebar, .topbar, #ai-chat-container { display: none !important; }
      .main { margin: 0 !important; padding: 0 !important; }
      .app { display: block !important; }
      .page { padding: 12px !important; }
      body { background: #fff !important; }
    }
  </style>
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'analytics' }) %>

  <div class="main">
    <%- include('partials/topbar', {
      pageTitle: 'Análises',
      breadcrumb: [{ label: 'Paytcall', href: '/dashboard' }, { label: 'Análises' }]
    }) %>

    <div class="page">

      <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
        <div>
          <h1>Análises</h1>
          <p>Performance de entregas, transportadoras e atendimento</p>
        </div>
        <button onclick="window.print()" class="btn btn-ghost btn-sm no-print" style="display:flex;align-items:center;gap:6px">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Baixar PDF
        </button>
      </div>

      <!-- Filtros -->
      <form method="GET" action="/analytics" class="card" style="padding:14px 16px;margin-bottom:20px;overflow:visible">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <!-- Período -->
          <div style="display:flex;gap:2px;background:var(--surface-2);border-radius:var(--radius-md);padding:3px">
            <% [['','Tudo'],['7d','7 dias'],['30d','30 dias'],['90d','90 dias']].forEach(([val,lbl]) => { %>
              <a href="/analytics?period=<%= val %><%= filters.seller_id ? '&seller_id='+filters.seller_id : '' %><%= filters.carrier ? '&carrier='+filters.carrier : '' %>"
                 style="padding:4px 10px;font-size:12px;font-weight:500;border-radius:var(--radius);text-decoration:none;
                        background:<%= filters.period === val ? 'var(--surface)' : 'transparent' %>;
                        color:<%= filters.period === val ? 'var(--text)' : 'var(--text-3)' %>;
                        box-shadow:<%= filters.period === val ? 'var(--shadow-xs)' : 'none' %>"><%= lbl %></a>
            <% }) %>
          </div>

          <select name="seller_id" class="form-select" style="font-size:12.5px;padding:5px 9px" onchange="this.form.submit()">
            <option value="">Todas as empresas</option>
            <% (typeof companies !== 'undefined' ? companies : []).forEach(c => { %>
              <option value="<%= c.seller_id %>" <%= filters.seller_id === c.seller_id ? 'selected' : '' %>><%= c.company_name || c.seller_id %></option>
            <% }) %>
          </select>

          <div style="display:flex;align-items:center;gap:4px">
            <input type="date" name="date_from" value="<%= filters.date_from || '' %>" class="form-input" style="font-size:12.5px;padding:5px 9px;width:140px" onchange="applyAnalyticsDateRange(this.form)">
            <span style="font-size:11px;color:var(--text-3)">até</span>
            <input type="date" name="date_to" value="<%= filters.date_to || '' %>" class="form-input" style="font-size:12.5px;padding:5px 9px;width:140px" onchange="applyAnalyticsDateRange(this.form)">
          </div>

          <select name="carrier" class="form-select" style="font-size:12.5px;padding:5px 9px" onchange="this.form.submit()">
            <option value="">Todas as transportadoras</option>
            <option value="Loggi"    <%= filters.carrier === 'Loggi'    ? 'selected' : '' %>>Loggi</option>
            <option value="Correios" <%= filters.carrier === 'Correios' ? 'selected' : '' %>>Correios</option>
            <option value="Jadlog"   <%= filters.carrier === 'Jadlog'   ? 'selected' : '' %>>Jadlog</option>
          </select>

          <% if (filters.seller_id || filters.carrier || filters.date_from || filters.period) { %>
          <a href="/analytics" class="btn btn-ghost btn-sm">Limpar</a>
          <% } %>
        </div>
      </form>

      <%
      const s = stats;
      const total = s.total || 1; // evita divisão por zero
      const txEntrega = ((s.delivered / total) * 100).toFixed(1);
      const txPendente = (((s.total - s.delivered - s.returned) / total) * 100).toFixed(1);
      const txDevolucao = ((s.returned / total) * 100).toFixed(1);
      %>

      <!-- KPI Cards -->
      <div class="stats-grid" style="grid-template-columns:repeat(auto-fill,minmax(180px,1fr));margin-bottom:24px">
        <div class="stat-card" style="border-left:3px solid var(--success)">
          <div class="stat-label">Taxa de Entrega</div>
          <div class="stat-value" style="color:var(--success)"><%= txEntrega %>%</div>
          <div class="stat-sub"><%= (s.delivered||0).toLocaleString('pt-BR') %> de <%= (s.total||0).toLocaleString('pt-BR') %> pedidos</div>
        </div>
        <div class="stat-card" style="border-left:3px solid var(--warning)">
          <div class="stat-label">Em Trânsito / Pendentes</div>
          <div class="stat-value" style="color:var(--warning)"><%= txPendente %>%</div>
          <div class="stat-sub"><%= ((s.in_transit||0)+(s.out_for_delivery||0)+(s.delivery_attempt||0)).toLocaleString('pt-BR') %> pedidos</div>
        </div>
        <div class="stat-card" style="border-left:3px solid var(--danger)">
          <div class="stat-label">Taxa de Devolução</div>
          <div class="stat-value" style="color:var(--danger)"><%= txDevolucao %>%</div>
          <div class="stat-sub"><%= (s.returned||0).toLocaleString('pt-BR') %> pedidos devolvidos</div>
        </div>
        <div class="stat-card" style="border-left:3px solid var(--brand)">
          <div class="stat-label">Rastreio em Atraso</div>
          <div class="stat-value" style="color:var(--brand)"><%= (s.tracking_delayed||0).toLocaleString('pt-BR') %></div>
          <div class="stat-sub"><%= (((s.tracking_delayed||0)/total)*100).toFixed(1) %>% do total</div>
        </div>
        <% const _avgDias = kpisExtra.avgEntregaDias; %>
        <div class="stat-card" style="border-left:3px solid var(--info,#0ea5e9)">
          <div class="stat-label">Tempo Médio de Entrega</div>
          <div class="stat-value" style="color:var(--info,#0ea5e9)"><%= _avgDias != null ? _avgDias + 'd' : '—' %></div>
          <div class="stat-sub">após pagamento aprovado</div>
        </div>
        <div class="stat-card" style="border-left:3px solid <%= parseFloat(kpisExtra.chargebackRate||0) > 1 ? 'var(--danger)' : 'var(--success)' %>">
          <div class="stat-label">Taxa de Chargeback</div>
          <div class="stat-value" style="color:<%= parseFloat(kpisExtra.chargebackRate||0) > 1 ? 'var(--danger)' : 'var(--success)' %>"><%= kpisExtra.chargebackRate || '0.00' %>%</div>
          <div class="stat-sub"><%= kpisExtra.cbTotal || 0 %> chargeback<%= (kpisExtra.cbTotal||0) !== 1 ? 's' : '' %> registrados</div>
        </div>
      </div>

      <!-- Gráfico de linha — pedidos por dia -->
      <div class="card" style="margin-bottom:18px">
        <div class="card-header">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <h3>Pedidos por Dia</h3>
          <span style="margin-left:auto;font-size:11px;color:var(--text-3)"><%= filters.date_from ? filters.date_from + ' → ' + (filters.date_to || 'hoje') : 'últimos 30 dias' %></span>
        </div>
        <div class="card-body">
          <canvas id="chartTimeSeriesAnalytics" height="70"></canvas>
        </div>
      </div>

      <!-- Gráficos linha 1 -->
      <div class="grid-2" style="margin-bottom:18px">

        <!-- Status dos envios — donut -->
        <div class="card">
          <div class="card-header"><h3>Distribuição de Status</h3></div>
          <div class="card-body" style="display:flex;align-items:center;gap:24px">
            <div style="width:160px;height:160px;flex-shrink:0;position:relative">
              <canvas id="chartStatusDonut"></canvas>
              <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center">
                <div style="font-size:20px;font-weight:700;color:var(--text)"><%= txEntrega %>%</div>
                <div style="font-size:10px;color:var(--text-4);font-weight:600;text-transform:uppercase;letter-spacing:.4px">entregues</div>
              </div>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;gap:8px">
              <%
              const statusDist = [
                { label:'Entregues',   val:s.delivered||0,        color:'#16a34a' },
                { label:'Em Trânsito', val:s.in_transit||0,       color:'#2563eb' },
                { label:'Saiu p/ent.', val:s.out_for_delivery||0, color:'#7c3aed' },
                { label:'Tentativa',   val:s.delivery_attempt||0, color:'#c2800a' },
                { label:'Devolvidos',  val:s.returned||0,         color:'#dc2626' },
                { label:'Sem rastreio',val:s.no_tracking||0,      color:'#9ca3af' },
                { label:'Em atraso',   val:s.tracking_delayed||0, color:'#e47c24' },
              ];
              %>
              <% statusDist.forEach(item => { %>
              <div style="display:flex;align-items:center;gap:8px">
                <span style="width:8px;height:8px;border-radius:99px;background:<%= item.color %>;flex-shrink:0"></span>
                <span style="font-size:12px;color:var(--text-3);flex:1"><%= item.label %></span>
                <span style="font-size:12px;font-weight:600;color:var(--text)"><%= item.val.toLocaleString('pt-BR') %></span>
                <span style="font-size:11px;color:var(--text-4);min-width:36px;text-align:right"><%= ((item.val/total)*100).toFixed(1) %>%</span>
              </div>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- Por transportadora — bar -->
        <div class="card">
          <div class="card-header"><h3>Por Transportadora</h3></div>
          <div class="card-body">
            <% if (analytics.transportadoras && analytics.transportadoras.length > 0) { %>
            <canvas id="chartCarrier" height="140"></canvas>
            <div style="margin-top:16px;display:flex;flex-direction:column;gap:8px">
              <% analytics.transportadoras.forEach(c => { %>
              <div style="display:flex;align-items:center;justify-content:space-between;font-size:12px">
                <span style="font-weight:600;color:var(--text)"><%= c.carrier %></span>
                <div style="display:flex;gap:12px">
                  <span style="color:var(--text-3)">Total: <strong style="color:var(--text)"><%= (parseInt(c.total)||0).toLocaleString('pt-BR') %></strong></span>
                  <span style="color:var(--success)">Ent.: <strong><%= parseInt(c.entregues)||0 %></strong></span>
                  <span style="color:var(--danger)">Dev.: <strong><%= parseInt(c.devolvidos)||0 %></strong></span>
                </div>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <div class="empty-state" style="padding:30px"><p>Sem dados de transportadora</p></div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Linha 2 -->
      <div class="grid-2" style="margin-bottom:18px">

        <!-- Produtos com mais problemas -->
        <div class="card">
          <div class="card-header">
            <h3>Produtos com Mais Pendências</h3>
            <span style="margin-left:auto;font-size:11px;color:var(--text-4)">status pendente/sem rastreio/em atraso</span>
          </div>
          <div class="card-body no-pad">
            <% if (analytics.produtos && analytics.produtos.length > 0) { %>
            <table style="width:100%;font-size:12.5px;border-collapse:collapse">
              <thead>
                <tr>
                  <th style="padding:8px 16px;text-align:left;font-size:10.5px;font-weight:700;color:var(--text-4);text-transform:uppercase;letter-spacing:.5px;background:var(--surface-2);border-bottom:1px solid var(--border)">Produto</th>
                  <th style="padding:8px 12px;text-align:right;font-size:10.5px;font-weight:700;color:var(--text-4);text-transform:uppercase;letter-spacing:.5px;background:var(--surface-2);border-bottom:1px solid var(--border)">Total</th>
                  <th style="padding:8px 12px;text-align:right;font-size:10.5px;font-weight:700;color:var(--text-4);text-transform:uppercase;letter-spacing:.5px;background:var(--surface-2);border-bottom:1px solid var(--border)">Pendentes</th>
                  <th style="padding:8px 16px 8px 4px;text-align:right;font-size:10.5px;font-weight:700;color:var(--text-4);text-transform:uppercase;letter-spacing:.5px;background:var(--surface-2);border-bottom:1px solid var(--border)">Entregues</th>
                </tr>
              </thead>
              <tbody>
                <% analytics.produtos.forEach((p,i) => { %>
                <tr style="border-bottom:1px solid var(--border)<%= i===analytics.produtos.length-1?';border-bottom:none':'' %>">
                  <td style="padding:10px 16px;color:var(--text-2);font-weight:500;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= p.product_name %></td>
                  <td style="padding:10px 12px;text-align:right;color:var(--text-3)"><%= parseInt(p.total)||0 %></td>
                  <td style="padding:10px 12px;text-align:right">
                    <span style="font-weight:600;color:<%= parseInt(p.problemas)>0?'var(--danger)':'var(--text-4)' %>"><%= parseInt(p.problemas)||0 %></span>
                  </td>
                  <td style="padding:10px 16px 10px 4px;text-align:right;color:var(--success);font-weight:500"><%= parseInt(p.entregues)||0 %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
            <div class="empty-state" style="padding:30px"><p>Dados insuficientes</p><div class="empty-sub">São necessários ao menos 3 pedidos por produto</div></div>
            <% } %>
          </div>
        </div>

        <!-- Motivos de ticket -->
        <div class="card">
          <div class="card-header">
            <h3>Motivos de Ticket</h3>
            <a href="/relatorios/tickets" class="btn btn-ghost btn-xs" style="margin-left:auto">Ver tickets</a>
          </div>
          <div class="card-body">
            <% if (analytics.ticketsMotivo && analytics.ticketsMotivo.length > 0) { %>
            <canvas id="chartMotivos" height="160"></canvas>
            <% } else { %>
            <div class="empty-state" style="padding:30px"><p>Nenhum ticket registrado</p></div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Linha 3: Top Estados + SLA de Tickets -->
      <div class="grid-2" style="margin-bottom:18px">

        <!-- Top Estados com pendências -->
        <div class="card">
          <div class="card-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            <h3>Top Estados — Pendências</h3>
            <span style="margin-left:auto;font-size:11px;color:var(--text-3)">em trânsito e em atraso</span>
          </div>
          <div class="card-body">
            <% const topEst = (kpisExtra.topEstados || []); %>
            <% if (topEst.length > 0) { %>
            <canvas id="chartEstados" height="200"></canvas>
            <% } else { %>
            <div class="empty-state" style="padding:24px"><p>Sem dados de estados</p></div>
            <% } %>
          </div>
        </div>

        <!-- SLA de Tickets -->
        <div class="card">
          <div class="card-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <h3>SLA de Tickets</h3>
            <span style="margin-left:auto;font-size:11px;color:var(--text-3)">tempo médio de resolução</span>
          </div>
          <div class="card-body">
            <% const sla = (typeof kpisExtra !== 'undefined' && kpisExtra.slaTickets) || []; %>
            <% if (sla.length > 0) { %>
            <div style="display:flex;flex-direction:column;gap:16px">
              <% sla.forEach(item => {
                const dias = Math.floor(item.avgHoras / 24);
                const horas = item.avgHoras % 24;
                const label = dias > 0 ? `${dias}d ${horas}h` : `${horas}h`;
                const pct = Math.min(100, (item.avgHoras / 72) * 100);
                const cor = item.avgHoras <= 48 ? 'var(--success)' : item.avgHoras <= 72 ? 'var(--warning)' : 'var(--danger)';
              %>
              <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                  <span style="font-size:13px;font-weight:600;color:var(--text)"><%= item.tipo %></span>
                  <div style="text-align:right">
                    <span style="font-size:14px;font-weight:700;color:<%= cor %>"><%= label %></span>
                    <span style="font-size:11px;color:var(--text-4);margin-left:6px"><%= item.count %> ticket<%= item.count !== 1 ? 's' : '' %></span>
                  </div>
                </div>
                <div style="height:6px;background:var(--surface-2);border-radius:99px;overflow:hidden">
                  <div style="height:100%;width:<%= pct %>%;background:<%= cor %>;border-radius:99px;transition:width .4s"></div>
                </div>
                <div style="font-size:10px;color:var(--text-4);margin-top:3px">SLA: 72h — barra = % do limite</div>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <div class="empty-state" style="padding:24px"><p>Nenhum ticket encerrado</p></div>
            <% } %>
          </div>
        </div>

      </div>

      <!-- Linha 4: Evolução mensal (largura total) -->
      <div class="card" style="margin-bottom:18px">
        <div class="card-header">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <h3>Evolução Mensal</h3>
          <span style="margin-left:auto;font-size:11px;color:var(--text-3)">últimos 6 meses</span>
        </div>
        <div class="card-body">
          <% const evolucao = (typeof kpisExtra !== 'undefined' && kpisExtra.evolucaoMensal) || []; %>
          <% if (evolucao.length > 0) { %>
          <canvas id="chartEvolucao" height="80"></canvas>
          <% } else { %>
          <div class="empty-state" style="padding:24px"><p>Sem dados mensais</p></div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
function applyAnalyticsDateRange(form) {
  const from = form.date_from?.value;
  const to = form.date_to?.value;
  if (from && to) form.submit();
}

(function() {
  const isDark = document.documentElement.classList.contains('dark');
  const textColor = isDark ? '#a8a8a8' : '#8a7a6a';
  const gridColor = isDark ? 'rgba(255,255,255,.06)' : 'rgba(0,0,0,.05)';

  // Line — pedidos por dia (analytics)
  const ctxTSA = document.getElementById('chartTimeSeriesAnalytics');
  if (ctxTSA) {
    <%
    const tsaObj = typeof timeSeries !== 'undefined' ? timeSeries : { labels: [], byCompany: {} };
    const tsaLabels = tsaObj.labels || [];
    const tsaCompanies = Object.entries(tsaObj.byCompany || {});
    const TSA_COLORS = ['#e47c24','#2563eb','#16a34a','#7c3aed','#dc2626','#c2800a'];
    %>
    new Chart(ctxTSA, {
      type: 'line',
      data: {
        labels: <%- JSON.stringify(tsaLabels) %>,
        datasets: [
          <% tsaCompanies.forEach(([name, co], i) => { %>
          {
            label: '<%= name %>',
            data: <%- JSON.stringify(co.values || []) %>,
            borderColor: '<%= TSA_COLORS[i % TSA_COLORS.length] %>',
            backgroundColor: 'rgba(228,124,36,.07)',
            pointBackgroundColor: '<%= TSA_COLORS[i % TSA_COLORS.length] %>',
            pointRadius: <%= tsaLabels.length > 20 ? 0 : 3 %>,
            pointHoverRadius: 5,
            tension: 0.4, fill: <%= tsaCompanies.length === 1 ? 'true' : 'false' %>, borderWidth: 2,
          },
          <% }) %>
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: <%= tsaCompanies.length > 1 ? 'true' : 'false' %>, position: 'bottom', labels: { color: textColor, font: { size: 11 }, boxWidth: 10, padding: 12 } },
          tooltip: { callbacks: { label: (ctx) => ' ' + ctx.dataset.label + ': ' + ctx.parsed.y + ' pedidos' } }
        },
        scales: {
          x: { grid: { display: false }, ticks: { color: textColor, font: { size: 10 }, maxTicksLimit: 10, maxRotation: 0 } },
          y: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 10 }, precision: 0 }, beginAtZero: true }
        },
        animation: { duration: 400 }
      }
    });
  }

  // Donut — status
  const ctxD = document.getElementById('chartStatusDonut');
  if (ctxD) {
    new Chart(ctxD, {
      type: 'doughnut',
      data: {
        labels: ['Entregues','Em Trânsito','Saiu p/ent.','Tentativa','Devolvidos','Sem rastreio','Em atraso'],
        datasets: [{
          data: [
            <%= stats.delivered||0 %>, <%= stats.in_transit||0 %>,
            <%= stats.out_for_delivery||0 %>, <%= stats.delivery_attempt||0 %>,
            <%= stats.returned||0 %>, <%= stats.no_tracking||0 %>, <%= stats.tracking_delayed||0 %>
          ],
          backgroundColor: ['#16a34a','#2563eb','#7c3aed','#c2800a','#dc2626','#9ca3af','#e47c24'],
          borderWidth: 0, hoverOffset: 6
        }]
      },
      options: {
        cutout: '72%',
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => ' ' + ctx.label + ': ' + ctx.parsed.toLocaleString('pt-BR') }}},
        animation: { duration: 500 }
      }
    });
  }

  // Bar — transportadoras
  const ctxC = document.getElementById('chartCarrier');
  if (ctxC) {
    const carriers = <%- JSON.stringify(analytics.transportadoras||[]) %>;
    new Chart(ctxC, {
      type: 'bar',
      data: {
        labels: carriers.map(c => c.carrier),
        datasets: [
          { label: 'Entregues', data: carriers.map(c => parseInt(c.entregues)||0), backgroundColor: '#16a34a', borderRadius: 4 },
          { label: 'Pendentes', data: carriers.map(c => parseInt(c.pendentes)||0), backgroundColor: '#2563eb', borderRadius: 4 },
          { label: 'Devolvidos', data: carriers.map(c => parseInt(c.devolvidos)||0), backgroundColor: '#dc2626', borderRadius: 4 },
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { position: 'top', labels: { font: { size: 11 }, color: textColor, padding: 10, boxWidth: 10, boxHeight: 10 } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: textColor, font: { size: 11 } } },
          y: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 11 }, precision: 0 }, beginAtZero: true }
        },
        animation: { duration: 400 }
      }
    });
  }

  // Bar horizontal — top estados com pendências
  const ctxEst = document.getElementById('chartEstados');
  if (ctxEst) {
    const estData = <%- JSON.stringify((kpisExtra.topEstados || [])) %>;
    new Chart(ctxEst, {
      type: 'bar',
      data: {
        labels: estData.map(e => e.uf),
        datasets: [{ label: 'Pendências', data: estData.map(e => e.count), backgroundColor: '#e47c24', borderRadius: 4, borderSkipped: false }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ' ' + ctx.parsed.x + ' pedidos' } } },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 11 }, precision: 0 }, beginAtZero: true },
          y: { grid: { display: false }, ticks: { color: textColor, font: { size: 12, weight: '600' } } }
        },
        animation: { duration: 400 }
      }
    });
  }

  // Bar — evolução mensal
  const ctxEv = document.getElementById('chartEvolucao');
  if (ctxEv) {
    const evData = <%- JSON.stringify((typeof kpisExtra !== 'undefined' && kpisExtra.evolucaoMensal) || []) %>;
    const evLabels = evData.map(d => {
      const [y, m] = d.mes.split('-');
      return ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'][parseInt(m)-1] + '/' + y.slice(2);
    });
    new Chart(ctxEv, {
      type: 'bar',
      data: {
        labels: evLabels,
        datasets: [
          { label: 'Total', data: evData.map(d => d.total), backgroundColor: 'rgba(37,99,235,.25)', borderColor: '#2563eb', borderWidth: 1.5, borderRadius: 4 },
          { label: 'Entregues', data: evData.map(d => d.entregues), backgroundColor: 'rgba(22,163,74,.35)', borderColor: '#16a34a', borderWidth: 1.5, borderRadius: 4 },
        ]
      },
      options: {
        responsive: true,
        plugins: { legend: { position: 'top', labels: { font: { size: 11 }, color: textColor, padding: 10, boxWidth: 10, boxHeight: 10 } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: textColor, font: { size: 11 } } },
          y: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 11 }, precision: 0 }, beginAtZero: true }
        },
        animation: { duration: 400 }
      }
    });
  }

  // Bar — motivos de ticket
  const ctxM = document.getElementById('chartMotivos');
  if (ctxM) {
    const motivos = <%- JSON.stringify(analytics.ticketsMotivo||[]) %>;
    const colors = ['#e47c24','#dc2626','#2563eb','#16a34a','#7c3aed','#c2800a','#9ca3af','#e47c24','#dc2626','#2563eb'];
    new Chart(ctxM, {
      type: 'bar',
      data: {
        labels: motivos.map(m => m.motivo),
        datasets: [{
          data: motivos.map(m => parseInt(m.total)||0),
          backgroundColor: motivos.map((_,i) => colors[i % colors.length]),
          borderRadius: 4, borderSkipped: false
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => ' ' + ctx.parsed.x + ' tickets' } } },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 11 }, precision: 0 }, beginAtZero: true },
          y: { grid: { display: false }, ticks: { color: textColor, font: { size: 11 } } }
        },
        animation: { duration: 400 }
      }
    });
  }
})();
</script>
<%- include('partials/ai-chat') %>
</body>
</html>
