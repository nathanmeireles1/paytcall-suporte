<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auditoria — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'admin-auditoria' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: 'Log de Auditoria', breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Admin', href: '/admin/configuracoes' },
      { label: 'Auditoria' }
    ] }) %>

    <div class="page">

      <div class="p-page-header" style="margin-bottom:16px">
        <div class="p-page-header-left">
          <h1>Log de Auditoria</h1>
          <p class="p-subtitle"><%= total.toLocaleString('pt-BR') %> registro<%= total !== 1 ? 's' : '' %> encontrado<%= total !== 1 ? 's' : '' %></p>
        </div>
      </div>

      <!-- Filtros -->
      <form method="GET" action="/admin/auditoria" class="card" style="padding:14px 16px;margin-bottom:16px">
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
          <select name="action" class="form-select" style="width:200px" onchange="this.form.submit()">
            <option value="all" <%= filters.action === '' ? 'selected' : '' %>>Todas as ações</option>
            <optgroup label="Usuários">
              <option value="usuario." <%= filters.action === 'usuario.' ? 'selected' : '' %>>Usuários (todas)</option>
              <option value="usuario.criar" <%= filters.action === 'usuario.criar' ? 'selected' : '' %>>Criar usuário</option>
              <option value="usuario.convidar" <%= filters.action === 'usuario.convidar' ? 'selected' : '' %>>Convidar usuário</option>
              <option value="usuario.excluir" <%= filters.action === 'usuario.excluir' ? 'selected' : '' %>>Excluir usuário</option>
              <option value="usuario.alterar_role" <%= filters.action === 'usuario.alterar_role' ? 'selected' : '' %>>Alterar role</option>
              <option value="usuario.ativar" <%= filters.action === 'usuario.ativar' ? 'selected' : '' %>>Ativar usuário</option>
              <option value="usuario.desativar" <%= filters.action === 'usuario.desativar' ? 'selected' : '' %>>Desativar usuário</option>
            </optgroup>
            <optgroup label="Catálogo">
              <option value="empresa." <%= filters.action === 'empresa.' ? 'selected' : '' %>>Empresas (todas)</option>
              <option value="produto." <%= filters.action === 'produto.' ? 'selected' : '' %>>Produtos (todas)</option>
            </optgroup>
            <optgroup label="Admin">
              <option value="permissoes." <%= filters.action === 'permissoes.' ? 'selected' : '' %>>Permissões</option>
              <option value="configuracao." <%= filters.action === 'configuracao.' ? 'selected' : '' %>>Configurações</option>
            </optgroup>
          </select>
          <input type="text" name="user" class="form-input" placeholder="Filtrar por usuário..." value="<%= filters.user %>" style="width:220px">
          <button type="submit" class="btn btn-secondary btn-sm">Filtrar</button>
          <% if (filters.action || filters.user) { %>
            <a href="/admin/auditoria" class="btn btn-ghost btn-sm">Limpar</a>
          <% } %>
        </div>
      </form>

      <!-- Tabela -->
      <div class="card" style="padding:0">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th style="width:160px">Data/Hora</th>
                <th style="width:180px">Usuário</th>
                <th style="width:200px">Ação</th>
                <th>Entidade</th>
                <th style="width:220px">Detalhes</th>
              </tr>
            </thead>
            <tbody>
              <% if (logs.length === 0) { %>
              <tr><td colspan="5" style="text-align:center;color:var(--text-4);padding:32px">Nenhum registro encontrado</td></tr>
              <% } %>
              <% logs.forEach(log => {
                const dt = new Date(log.created_at).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo', day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' });
                const [category, verb] = log.action.split('.');
                const categoryColors = { usuario:'var(--brand)', empresa:'var(--success)', produto:'var(--info)', permissao:'var(--warning)', configuracao:'var(--warning)', import:'var(--text-3)' };
                const color = categoryColors[category] || 'var(--text-3)';
              %>
              <tr>
                <td style="color:var(--text-3);font-size:12px;white-space:nowrap"><%= dt %></td>
                <td>
                  <div style="font-weight:500;font-size:13px;color:var(--text)"><%= log.user_name || '—' %></div>
                  <div style="font-size:11px;color:var(--text-4)"><%= log.user_email || '' %></div>
                </td>
                <td>
                  <span class="badge" style="background:color-mix(in srgb,<%= color %> 12%,transparent);color:<%= color %>;border:1px solid color-mix(in srgb,<%= color %> 25%,transparent);font-size:11px"><%= log.action %></span>
                </td>
                <td>
                  <% if (log.entity_name) { %>
                    <div style="font-size:13px;color:var(--text-2)"><%= log.entity_name %></div>
                  <% } %>
                  <% if (log.entity_type) { %>
                    <div style="font-size:11px;color:var(--text-4)"><%= log.entity_type %><%= log.entity_id ? ' · ' + log.entity_id : '' %></div>
                  <% } %>
                </td>
                <td style="font-size:12px;color:var(--text-3)">
                  <% if (log.details) {
                    const d = typeof log.details === 'string' ? JSON.parse(log.details) : log.details;
                    const entries = Object.entries(d).filter(([,v]) => v !== null && v !== undefined);
                  %>
                    <% entries.forEach(([k,v]) => { %>
                      <span style="display:inline-block;margin-right:8px"><span style="color:var(--text-4)"><%= k %>:</span> <strong><%= typeof v === 'object' ? JSON.stringify(v) : String(v) %></strong></span>
                    <% }) %>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <%- include('partials/pagination', { pages, currentPage, total, perPage }) %>
      </div>

    </div>
  </div>

  <%- include('partials/ai-chat') %>
</div>
</body>
</html>
