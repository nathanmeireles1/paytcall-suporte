<%
  const _title = typeof pageTitle !== 'undefined' ? pageTitle : 'Painel';
  const _breadcrumb = typeof breadcrumb !== 'undefined' ? breadcrumb : [];
  const _searchAction = typeof searchAction !== 'undefined' ? searchAction : null;
  const _searchValue = typeof searchValue !== 'undefined' ? searchValue : '';
  const _polaris = typeof polarisTopbar !== 'undefined' ? polarisTopbar : false;
%>

<% if (_polaris) { %>
<header class="topbar-polaris">
  <div class="tp-left">
    <% if (_breadcrumb.length > 0) { %>
    <div style="font-size:12px;color:var(--text-4);display:flex;align-items:center;gap:4px;white-space:nowrap;flex-wrap:nowrap">
      <% _breadcrumb.forEach((b, i) => { %>
        <% if (i > 0) { %><span style="color:var(--text-4);flex-shrink:0">›</span><% } %>
        <% if (b.href) { %><a href="<%= b.href %>" style="color:var(--text-3);transition:color .1s;white-space:nowrap" onmouseover="this.style.color='var(--brand)'" onmouseout="this.style.color='var(--text-3)'"><%= b.label %></a><% } else { %><span style="color:var(--text-2);font-weight:500;white-space:nowrap"><%= b.label %></span><% } %>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="tp-center">
    <% if (_searchAction) { %>
    <form method="GET" action="<%= _searchAction %>" class="topbar-search-wrap">
      <span class="search-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg></span>
      <input type="text" name="search" placeholder="Buscar pedido, código ou cliente..." value="<%= _searchValue %>" autocomplete="off">
    </form>
    <% } else { %>
    <div class="topbar-search-wrap">
      <span class="search-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg></span>
      <input type="text" placeholder="Buscar no portal..." autocomplete="off">
    </div>
    <% } %>
  </div>

  <div class="tp-right">
    <div style="position:relative">
      <button id="notifBtn" onclick="toggleNotifs()" class="btn-icon" style="position:relative">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="var(--text-3)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>
        </svg>
        <span id="notifBadge" style="display:none;position:absolute;top:-1px;right:-1px;background:var(--danger);color:#fff;font-size:9px;font-weight:700;border-radius:99px;min-width:15px;height:15px;line-height:15px;text-align:center;padding:0 3px;border:1.5px solid var(--bg-2)">0</span>
      </button>
      <div id="notifDropdown" class="notif-dropdown">
        <div class="notif-header">
          <span style="font-size:13px;font-weight:600;color:var(--text)">Notificações</span>
          <button onclick="markAllRead()" class="btn btn-ghost btn-xs">Marcar lidas</button>
        </div>
        <div id="notifList"><div style="text-align:center;color:var(--text-4);padding:28px;font-size:13px">Carregando...</div></div>
      </div>
    </div>
  </div>
</header>

<% } else { %>
<header class="topbar">
  <div class="topbar-left">
    <% if (_breadcrumb.length > 0) { %>
    <div class="topbar-breadcrumb">
      <% _breadcrumb.forEach((b, i) => { %>
        <% if (i > 0) { %><span class="sep">›</span><% } %>
        <% if (b.href) { %><a href="<%= b.href %>"><%= b.label %></a><% } else { %><span style="color:var(--text-2);font-weight:500"><%= b.label %></span><% } %>
      <% }) %>
    </div>
    <% } %>
    <div class="topbar-title"><%= _title %></div>
  </div>
  <div class="topbar-actions">
    <div style="position:relative">
      <button id="notifBtn" onclick="toggleNotifs()" class="btn-icon" style="position:relative">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="var(--text-3)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>
        </svg>
        <span id="notifBadge" style="display:none;position:absolute;top:-1px;right:-1px;background:var(--danger);color:#fff;font-size:9px;font-weight:700;border-radius:99px;min-width:15px;height:15px;line-height:15px;text-align:center;padding:0 3px;border:1.5px solid var(--bg-2)">0</span>
      </button>
      <div id="notifDropdown" class="notif-dropdown">
        <div class="notif-header">
          <span style="font-size:13px;font-weight:600;color:var(--text)">Notificações</span>
          <button onclick="markAllRead()" class="btn btn-ghost btn-xs">Marcar lidas</button>
        </div>
        <div id="notifList"><div style="text-align:center;color:var(--text-4);padding:28px;font-size:13px">Carregando...</div></div>
      </div>
    </div>
  </div>
</header>
<% } %>

<script>
// Dark mode toggle — persiste no localStorage
(function() {
  const saved = localStorage.getItem('payt-theme');
  if (saved === 'dark') document.documentElement.classList.add('dark');
})();

function toggleTheme() {
  const isDark = document.documentElement.classList.toggle('dark');
  localStorage.setItem('payt-theme', isDark ? 'dark' : 'light');
}

function toggleNotifs() {
  const dd = document.getElementById('notifDropdown');
  dd.classList.toggle('open');
  if (dd.classList.contains('open')) loadNotifs();
}
async function loadNotifs() {
  try {
    const r = await fetch('/api/notifications');
    const { notifications, unread } = await r.json();
    const badge = document.getElementById('notifBadge');
    badge.style.display = unread > 0 ? 'block' : 'none';
    badge.textContent = unread;
    const list = document.getElementById('notifList');
    if (!notifications.length) { list.innerHTML = '<div style="text-align:center;color:var(--text-4);padding:24px;font-size:13px">Nenhuma notificação</div>'; return; }
    list.innerHTML = notifications.map(n => {
      const date = new Date(n.created_at).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo',day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
      return `<a href="/shipment/${n.tracking_code||''}" class="notif-item${n.is_read ? '' : ' unread'}"><div style="font-size:13px;color:var(--text-2)">${n.message}</div><div style="font-size:11px;color:var(--text-4);margin-top:2px">${date}</div></a>`;
    }).join('');
  } catch(e) {}
}
async function markAllRead() {
  await fetch('/api/notifications/read', { method: 'POST' });
  loadNotifs();
}
fetch('/api/notifications').then(r=>r.json()).then(({unread})=>{
  const b = document.getElementById('notifBadge');
  if (b) { b.style.display = unread > 0 ? 'block' : 'none'; b.textContent = unread; }
}).catch(()=>{});
document.addEventListener('click', (e) => {
  const dd = document.getElementById('notifDropdown');
  const btn = document.getElementById('notifBtn');
  if (dd && btn && !dd.contains(e.target) && !btn.contains(e.target)) dd.classList.remove('open');
});
</script>
