<%
  const _title = typeof pageTitle !== 'undefined' ? pageTitle : 'Painel';
  const _breadcrumb = typeof breadcrumb !== 'undefined' ? breadcrumb : [];
  const _searchAction = typeof searchAction !== 'undefined' ? searchAction : null;
  const _searchValue = typeof searchValue !== 'undefined' ? searchValue : '';
  const _polaris = typeof polarisTopbar !== 'undefined' ? polarisTopbar : false;
%>

<% if (_polaris) { %>
<header class="topbar-polaris">
  <div class="tp-left">
    <% if (_breadcrumb.length > 0) { %>
    <div style="font-size:12px;color:var(--text-4);display:flex;align-items:center;gap:4px;white-space:nowrap;flex-wrap:nowrap">
      <% _breadcrumb.forEach((b, i) => { %>
        <% if (i > 0) { %><span style="color:var(--text-4);flex-shrink:0">›</span><% } %>
        <% if (b.href) { %><a href="<%= b.href %>" style="color:var(--text-3);transition:color .1s;white-space:nowrap" onmouseover="this.style.color='var(--brand)'" onmouseout="this.style.color='var(--text-3)'"><%= b.label %></a><% } else { %><span style="color:var(--text-2);font-weight:500;white-space:nowrap"><%= b.label %></span><% } %>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="tp-center">
    <% if (_searchAction) { %>
    <form method="GET" action="<%= _searchAction %>" class="topbar-search-wrap">
      <span class="search-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg></span>
      <input type="text" name="search" placeholder="Buscar pedido, código ou cliente..." value="<%= _searchValue %>" autocomplete="off">
    </form>
    <% } else { %>
    <div class="topbar-search-wrap">
      <span class="search-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg></span>
      <input type="text" placeholder="Buscar no portal..." autocomplete="off">
    </div>
    <% } %>
  </div>

  <div class="tp-right">
    <div style="position:relative">
      <button id="notifBtn" onclick="toggleNotifs()" class="btn-icon" style="position:relative">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="var(--text-3)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>
        </svg>
        <span id="notifBadge" style="display:none;position:absolute;top:-1px;right:-1px;background:var(--danger);color:#fff;font-size:9px;font-weight:700;border-radius:99px;min-width:15px;height:15px;line-height:15px;text-align:center;padding:0 3px;border:1.5px solid var(--bg-2)">0</span>
      </button>
      <div id="notifDropdown" class="notif-dropdown">
        <div class="notif-header">
          <span style="font-size:13px;font-weight:600;color:var(--text)">Notificações</span>
          <button onclick="markAllRead()" class="btn btn-ghost btn-xs">Marcar lidas</button>
        </div>
        <div id="notifList"><div style="text-align:center;color:var(--text-4);padding:28px;font-size:13px">Carregando...</div></div>
      </div>
    </div>
  </div>
</header>

<% } else { %>
<header class="topbar">
  <div class="topbar-left">
    <% if (_breadcrumb.length > 0) { %>
    <div class="topbar-breadcrumb">
      <% _breadcrumb.forEach((b, i) => { %>
        <% if (i > 0) { %><span class="sep">›</span><% } %>
        <% if (b.href) { %><a href="<%= b.href %>"><%= b.label %></a><% } else { %><span style="color:var(--text-2);font-weight:500"><%= b.label %></span><% } %>
      <% }) %>
    </div>
    <% } %>
    <div class="topbar-title"><%= _title %></div>
  </div>
  <div class="topbar-actions">
    <button onclick="openGlobalSearch()" class="btn-icon" title="Busca global (Ctrl+K)" style="display:flex;align-items:center;gap:6px;padding:5px 10px;border-radius:8px;background:var(--surface-2);border:1px solid var(--border);color:var(--text-3);font-size:12px;cursor:pointer;transition:background .15s" onmouseover="this.style.background='var(--border)'" onmouseout="this.style.background='var(--surface-2)'">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <span style="display:none" class="hide-mobile">Buscar</span>
      <kbd style="font-size:10px;background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:1px 5px;font-family:inherit;display:none" class="hide-mobile">Ctrl+K</kbd>
    </button>
    <div style="position:relative">
      <button id="notifBtn" onclick="toggleNotifs()" class="btn-icon" style="position:relative">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="var(--text-3)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>
        </svg>
        <span id="notifBadge" style="display:none;position:absolute;top:-1px;right:-1px;background:var(--danger);color:#fff;font-size:9px;font-weight:700;border-radius:99px;min-width:15px;height:15px;line-height:15px;text-align:center;padding:0 3px;border:1.5px solid var(--bg-2)">0</span>
      </button>
      <div id="notifDropdown" class="notif-dropdown">
        <div class="notif-header">
          <span style="font-size:13px;font-weight:600;color:var(--text)">Notificações</span>
          <button onclick="markAllRead()" class="btn btn-ghost btn-xs">Marcar lidas</button>
        </div>
        <div id="notifList"><div style="text-align:center;color:var(--text-4);padding:28px;font-size:13px">Carregando...</div></div>
      </div>
    </div>
  </div>
</header>
<% } %>

<script>
// Dark mode toggle — persiste no localStorage
(function() {
  const saved = localStorage.getItem('payt-theme');
  if (saved === 'dark') document.documentElement.classList.add('dark');
})();

function toggleTheme() {
  const isDark = document.documentElement.classList.toggle('dark');
  localStorage.setItem('payt-theme', isDark ? 'dark' : 'light');
}

function toggleNotifs() {
  const dd = document.getElementById('notifDropdown');
  dd.classList.toggle('open');
  if (dd.classList.contains('open')) loadNotifs();
}
async function loadNotifs() {
  try {
    const r = await fetch('/api/notifications');
    const { notifications, unread } = await r.json();
    const badge = document.getElementById('notifBadge');
    badge.style.display = unread > 0 ? 'block' : 'none';
    badge.textContent = unread;
    const list = document.getElementById('notifList');
    if (!notifications.length) { list.innerHTML = '<div style="text-align:center;color:var(--text-4);padding:24px;font-size:13px">Nenhuma notificação</div>'; return; }
    list.innerHTML = notifications.map(n => {
      const date = new Date(n.created_at).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo',day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
      return `<a href="/shipment/${n.tracking_code||''}" class="notif-item${n.is_read ? '' : ' unread'}"><div style="font-size:13px;color:var(--text-2)">${n.message}</div><div style="font-size:11px;color:var(--text-4);margin-top:2px">${date}</div></a>`;
    }).join('');
  } catch(e) {}
}
async function markAllRead() {
  await fetch('/api/notifications/read', { method: 'POST' });
  loadNotifs();
}
fetch('/api/notifications').then(r=>r.json()).then(({unread})=>{
  const b = document.getElementById('notifBadge');
  if (b) { b.style.display = unread > 0 ? 'block' : 'none'; b.textContent = unread; }
}).catch(()=>{});
document.addEventListener('click', (e) => {
  const dd = document.getElementById('notifDropdown');
  const btn = document.getElementById('notifBtn');
  if (dd && btn && !dd.contains(e.target) && !btn.contains(e.target)) dd.classList.remove('open');
});

// Toast global
let _toastTimer;
function showToast(msg, type = 'success') {
  let t = document.getElementById('__toast');
  if (!t) {
    t = document.createElement('div');
    t.id = '__toast';
    t.style.cssText = 'display:none;position:fixed;top:20px;left:50%;transform:translateX(-50%);color:#fff;padding:12px 22px;border-radius:10px;font-size:14px;font-weight:600;z-index:10001;box-shadow:0 6px 24px rgba(0,0,0,.22);min-width:200px;max-width:400px;text-align:center;pointer-events:none;transition:opacity .2s';
    document.body.appendChild(t);
  }
  const icon = type === 'error' ? '✕' : type === 'warning' ? '⚠' : '✓';
  t.innerHTML = `<span style="font-size:16px;margin-right:8px">${icon}</span>${msg}`;
  t.style.background = type === 'error' ? '#dc2626' : type === 'warning' ? '#c2800a' : '#16a34a';
  t.style.display = 'block'; t.style.opacity = '1';
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.style.display = 'none', 200); }, 3000);
}

// Modal de confirmação global — substitui confirm() nativo
function showConfirm(message, onOk, { okLabel = 'Confirmar', okClass = 'btn-primary' } = {}) {
  let overlay = document.getElementById('__confirm-overlay');
  if (!overlay) {
    overlay = document.createElement('div');
    overlay.id = '__confirm-overlay';
    overlay.style.cssText = 'display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.45);align-items:center;justify-content:center';
    overlay.innerHTML = `<div class="card" style="width:100%;max-width:380px;margin:0 16px">
      <div class="card-header" style="padding:16px 20px"><span id="__confirm-msg" style="font-size:14px;color:var(--text-2);line-height:1.5"></span></div>
      <div class="card-footer" style="display:flex;justify-content:flex-end;gap:8px;padding:12px 20px">
        <button id="__confirm-cancel" class="btn btn-secondary btn-sm">Cancelar</button>
        <button id="__confirm-ok" class="btn btn-sm">Confirmar</button>
      </div>
    </div>`;
    document.body.appendChild(overlay);
  }
  document.getElementById('__confirm-msg').textContent = message;
  const okBtn = document.getElementById('__confirm-ok');
  okBtn.textContent = okLabel;
  okBtn.className = `btn btn-sm ${okClass}`;
  overlay.style.display = 'flex';
  const close = () => { overlay.style.display = 'none'; };
  okBtn.onclick = () => { close(); onOk(); };
  document.getElementById('__confirm-cancel').onclick = close;
  overlay.onclick = e => { if (e.target === overlay) close(); };
}

// ── Busca Global (Cmd+K / Ctrl+K) ──────────────────────────────────────────
(function() {
  let _searchDebounce;

  function openSearch() {
    let overlay = document.getElementById('__search-overlay');
    if (!overlay) {
      overlay = document.createElement('div');
      overlay.id = '__search-overlay';
      overlay.style.cssText = 'display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.5);align-items:flex-start;justify-content:center;padding-top:80px';
      overlay.innerHTML = `
        <div style="width:100%;max-width:560px;margin:0 16px">
          <div class="card" style="overflow:visible">
            <div style="padding:12px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-3)" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
              <input id="__search-input" type="text" placeholder="Buscar pedido, código de rastreio, cliente, CPF..." autocomplete="off"
                style="flex:1;border:none;outline:none;font-size:14px;background:transparent;color:var(--text);font-family:inherit">
              <span style="font-size:11px;color:var(--text-4);background:var(--surface-2);border:1px solid var(--border);border-radius:5px;padding:2px 6px">Esc</span>
            </div>
            <div id="__search-results" style="max-height:360px;overflow-y:auto;padding:6px">
              <div style="text-align:center;color:var(--text-4);padding:20px;font-size:13px">Digite para buscar...</div>
            </div>
          </div>
        </div>`;
      document.body.appendChild(overlay);
      overlay.addEventListener('click', e => { if (e.target === overlay) closeSearch(); });
      document.getElementById('__search-input').addEventListener('input', function() {
        clearTimeout(_searchDebounce);
        const q = this.value.trim();
        if (q.length < 2) {
          document.getElementById('__search-results').innerHTML = '<div style="text-align:center;color:var(--text-4);padding:20px;font-size:13px">Digite para buscar...</div>';
          return;
        }
        document.getElementById('__search-results').innerHTML = '<div style="text-align:center;color:var(--text-4);padding:20px;font-size:13px">Buscando...</div>';
        _searchDebounce = setTimeout(() => runSearch(q), 300);
      });
      document.getElementById('__search-input').addEventListener('keydown', function(e) {
        if (e.key === 'Escape') { closeSearch(); return; }
        if (e.key === 'ArrowDown') { e.preventDefault(); focusResult(1); }
        if (e.key === 'ArrowUp')   { e.preventDefault(); focusResult(-1); }
        if (e.key === 'Enter') {
          const focused = document.querySelector('.__search-item:focus,.__search-item.focused');
          if (focused) { window.location.href = focused.dataset.href; closeSearch(); }
        }
      });
    }
    overlay.style.display = 'flex';
    setTimeout(() => document.getElementById('__search-input').focus(), 50);
  }

  function closeSearch() {
    const overlay = document.getElementById('__search-overlay');
    if (overlay) {
      overlay.style.display = 'none';
      document.getElementById('__search-input').value = '';
      document.getElementById('__search-results').innerHTML = '<div style="text-align:center;color:var(--text-4);padding:20px;font-size:13px">Digite para buscar...</div>';
    }
  }

  function focusResult(dir) {
    const items = [...document.querySelectorAll('.__search-item')];
    if (!items.length) return;
    const current = items.findIndex(i => i.classList.contains('focused'));
    items.forEach(i => i.classList.remove('focused'));
    const next = Math.max(0, Math.min(items.length - 1, current + dir));
    items[next].classList.add('focused');
    items[next].scrollIntoView({ block: 'nearest' });
  }

  const STATUS_LABELS = {
    delivered:'Entregue', forwarded:'Em Trânsito', delivering:'Saiu p/ Entrega',
    posted_object:'Obj. Postado', pending:'Pendente', returning:'Devolvendo',
    returned:'Devolvido', no_tracking:'Sem rastreio', tracking_delayed:'Rastreio em atraso',
    in_transit:'Em Trânsito', out_for_delivery:'Saiu p/ Entrega',
  };
  const STATUS_BADGE = {
    delivered:'badge-success', returned:'badge-danger', returning:'badge-warning',
    forwarded:'badge-info', delivering:'badge-info', posted_object:'badge-info',
    in_transit:'badge-info', out_for_delivery:'badge-info',
    pending:'badge-neutral', no_tracking:'badge-neutral', tracking_delayed:'badge-warning',
  };

  async function runSearch(q) {
    try {
      const res = await fetch('/api/search?q=' + encodeURIComponent(q));
      const { results } = await res.json();
      const container = document.getElementById('__search-results');
      if (!results || !results.length) {
        container.innerHTML = '<div style="text-align:center;color:var(--text-4);padding:20px;font-size:13px">Nenhum resultado encontrado</div>';
        return;
      }
      container.innerHTML = results.map((r, i) => `
        <a class="__search-item" data-href="${r.href}" href="${r.href}"
          style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;cursor:pointer;transition:background .1s"
          onmouseenter="this.classList.add('focused');document.querySelectorAll('.__search-item').forEach(x=>x!==this&&x.classList.remove('focused'))"
          onmouseleave="this.classList.remove('focused')"
          onfocus="document.querySelectorAll('.__search-item').forEach(x=>x.classList.remove('focused'));this.classList.add('focused')">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--surface-2);display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-3)" stroke-width="2" stroke-linecap="round">
              ${r.type === 'ticket' ? '<path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>' : '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>'}
            </svg>
          </div>
          <div style="flex:1;min-width:0">
            <div style="font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.title}</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.sub}</div>
          </div>
          ${r.status ? `<span class="badge ${STATUS_BADGE[r.status] || 'badge-neutral'}" style="flex-shrink:0;font-size:10px">${STATUS_LABELS[r.status] || r.status}</span>` : ''}
        </a>`).join('');
    } catch(e) {
      document.getElementById('__search-results').innerHTML = '<div style="text-align:center;color:var(--danger);padding:20px;font-size:13px">Erro ao buscar</div>';
    }
  }

  // Abre com Cmd+K ou Ctrl+K; fecha com Escape
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
    if (e.key === 'Escape') closeSearch();
  });

  // Expõe globalmente para botão manual
  window.openGlobalSearch = openSearch;
})();
</script>

<!-- Botão de busca no topbar (CSS hover via style tag) -->
<style>
  .__search-item.focused { background: var(--surface-2) !important; }
  .__search-item:hover { background: var(--surface-2) !important; }
  #__search-overlay .card { animation: searchFadeIn .15s ease; }
  @keyframes searchFadeIn { from { opacity:0; transform:translateY(-8px); } to { opacity:1; transform:translateY(0); } }
</style>
