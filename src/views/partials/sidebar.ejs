<%
  const _perms = (typeof currentUser !== 'undefined' && currentUser.permissions) || {};
  const _role  = typeof currentUser !== 'undefined' ? currentUser.role : '';
  const _isAdmin = _role === 'admin';
  const _page  = typeof activePage !== 'undefined' ? activePage : '';

  // Admin bypasses all permission checks; non-admin follows DB permissions
  // Default: show item if no permission record exists yet
  const canView = (mod) => _isAdmin || !_perms[mod] || _perms[mod].can_view;

  const roleLabels = { admin: 'Administrador', suporte: 'Suporte', usuario: 'Usuário', terceiros: 'Terceiros' };
  const _userName  = typeof currentUser !== 'undefined' ? currentUser.name : '';
  const _userRole  = typeof currentUser !== 'undefined' ? currentUser.role : '';
  const _userInit  = _userName ? _userName.charAt(0).toUpperCase() : '?';
%>

<aside class="sidebar" id="sidebar">

  <!-- Brand -->
  <div class="sidebar-brand">
    <div class="brand-logo">
      <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    </div>
    <div>
      <div class="brand-name">payt</div>
      <div class="brand-tag">Suporte</div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="sidebar-nav">

    <!-- Principal -->
    <div class="sidebar-section">
      <div class="sidebar-section-label">Principal</div>

      <% if (canView('dashboard')) { %>
      <a href="/dashboard" class="nav-item <%= _page === 'dashboard' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        Dashboard
      </a>
      <% } %>

      <a href="/" class="nav-item <%= _page === 'rastreios' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        Rastreios
      </a>

      <% if (canView('tickets')) { %>
      <a href="/relatorios/tickets" class="nav-item <%= _page === 'tickets' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        </span>
        Tickets
      </a>
      <% } %>
    </div>

    <!-- Relatórios -->
    <% if (canView('relatorio_cancelamentos')) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Relatórios</div>

      <a href="/relatorios/cancelamentos" class="nav-item <%= _page === 'cancelamentos' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
        </span>
        Cancelamentos
      </a>
    </div>
    <% } %>

    <!-- Administração -->
    <% if (_isAdmin || canView('admin_usuarios') || canView('admin_permissoes')) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Administração</div>

      <% if (_isAdmin || canView('admin_usuarios')) { %>
      <a href="/admin/users" class="nav-item <%= _page === 'admin-users' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
        </span>
        Usuários
      </a>
      <% } %>

      <% if (_isAdmin || canView('admin_permissoes')) { %>
      <a href="/admin/permissions" class="nav-item <%= _page === 'admin-permissions' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </span>
        Permissões
      </a>
      <% } %>
    </div>
    <% } %>

  </nav>

  <!-- User Footer -->
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="avatar"><%= _userInit %></div>
      <div class="user-info">
        <div class="user-name"><%= _userName %></div>
        <div class="user-role"><%= roleLabels[_userRole] || _userRole %></div>
      </div>
      <a href="/logout" class="btn-logout" title="Sair">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  </div>

</aside>
