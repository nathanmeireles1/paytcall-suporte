<%
  const _perms = (typeof currentUser !== 'undefined' && currentUser.permissions) || {};
  const _role  = typeof currentUser !== 'undefined' ? currentUser.role : '';
  const _isAdmin = _role === 'admin';
  const _page  = typeof activePage !== 'undefined' ? activePage : '';

  // Admin bypasses all permission checks; non-admin follows DB permissions
  // Default: show item if no permission record exists yet
  const canView = (mod) => _isAdmin || !_perms[mod] || _perms[mod].can_view;

  const roleLabels = { admin: 'Administrador', suporte: 'Suporte', usuario: 'Usuário', terceiros: 'Terceiros' };
  const _userName  = typeof currentUser !== 'undefined' ? currentUser.name : '';
  const _userRole  = typeof currentUser !== 'undefined' ? currentUser.role : '';
  const _userInit  = _userName ? _userName.charAt(0).toUpperCase() : '?';
%>

<aside class="sidebar" id="sidebar">

  <!-- Brand -->
  <div class="sidebar-brand">
    <div class="brand-logo">
      <span style="color:#fff;font-size:13px;font-weight:800;font-family:'Plus Jakarta Sans',sans-serif;line-height:1">P</span>
    </div>
    <div>
      <div class="brand-name">PAYTCALL</div>
      <div class="brand-tag">Suporte</div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="sidebar-nav">

    <!-- Principal -->
    <div class="sidebar-section">
      <div class="sidebar-section-label">Principal</div>

      <% if (canView('dashboard')) { %>
      <a href="/dashboard" class="nav-item <%= _page === 'dashboard' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        Dashboard
      </a>
      <% } %>

      <a href="/" class="nav-item <%= _page === 'rastreios' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        Rastreios
      </a>

      <% if (canView('tickets')) { %>
      <a href="/relatorios/tickets" class="nav-item <%= _page === 'tickets' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        </span>
        Tickets
      </a>
      <% } %>

      <% if (_isAdmin) { %>
      <a href="/admin/mural" class="nav-item <%= _page === 'admin-mural' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16h6M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </span>
        Mural de Avisos
      </a>
      <% } %>
    </div>

    <!-- Relatórios -->
    <% if (canView('relatorio_cancelamentos') || canView('relatorio_logistica') || _isAdmin) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Relatórios</div>

      <a href="/analytics" class="nav-item <%= _page === 'analytics' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </span>
        Análises
      </a>

      <% if (canView('relatorio_cancelamentos')) { %>
      <a href="/relatorios/retencao" class="nav-item <%= _page === 'retencao' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
        </span>
        Retenção
      </a>
      <% if (canView('tickets')) { %>
      <a href="/relatorios/retencao/solicitacoes" class="nav-item <%= _page === 'retencao-solicitacoes' ? 'active' : '' %>" style="padding:5px 10px 5px 28px;font-size:12px">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </span>
        Solicitações
      </a>
      <% } %>
      <% } %>

      <% if (canView('relatorio_logistica')) { %>
      <a href="/relatorios/logistica" class="nav-item <%= _page === 'logistica' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </span>
        Logística
      </a>
      <% if (canView('tickets')) { %>
      <a href="/relatorios/logistica/solicitacoes" class="nav-item <%= _page === 'logistica-solicitacoes' ? 'active' : '' %>" style="padding:5px 10px 5px 28px;font-size:12px">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </span>
        Solicitações
      </a>
      <% } %>
      <% } %>
    </div>
    <% } %>

    <!-- Administração -->
    <% if (_isAdmin || canView('admin_usuarios') || canView('admin_permissoes')) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Administração</div>

      <% if (_isAdmin || canView('admin_usuarios')) { %>
      <a href="/admin/users" class="nav-item <%= _page === 'admin-users' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
        </span>
        Usuários
      </a>
      <% } %>

      <% if (_isAdmin || canView('admin_permissoes')) { %>
      <a href="/admin/permissions" class="nav-item <%= _page === 'admin-permissions' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </span>
        Permissões
      </a>
      <% } %>

      <% if (_isAdmin) { %>
      <a href="/admin/settings" class="nav-item <%= _page === 'admin-settings' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
        </span>
        Configurações
      </a>
      <% } %>
    </div>
    <% } %>

  </nav>

  <!-- User Footer -->
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="avatar avatar-clickable" onclick="document.getElementById('avatarInput').click()" title="Trocar foto">
        <% if (typeof currentUser !== 'undefined' && currentUser.avatar_url) { %>
        <img src="<%= currentUser.avatar_url %>" alt="<%= _userInit %>" id="avatarImg" style="width:100%;height:100%;object-fit:cover;border-radius:inherit">
        <% } else { %>
        <span id="avatarInit"><%= _userInit %></span>
        <% } %>
        <div class="avatar-overlay">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
        </div>
      </div>
      <input type="file" id="avatarInput" accept="image/jpeg,image/png,image/webp" style="display:none" onchange="uploadAvatar(this)">
      <div class="user-info">
        <div class="user-name"><%= _userName %></div>
        <div class="user-role"><%= roleLabels[_userRole] || _userRole %></div>
      </div>
      <a href="/logout" class="btn-logout" title="Sair">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  </div>

<script>
function uploadAvatar(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = async (e) => {
    const base64 = e.target.result.split(',')[1];
    try {
      const r = await fetch('/api/profile/photo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ imageBase64: base64, mimeType: file.type }),
      });
      const d = await r.json();
      if (d.ok) {
        const img = document.getElementById('avatarImg');
        const init = document.getElementById('avatarInit');
        if (img) { img.src = d.url + '?t=' + Date.now(); }
        else {
          const avatar = document.querySelector('.avatar-clickable');
          if (init) init.remove();
          const newImg = document.createElement('img');
          newImg.id = 'avatarImg';
          newImg.src = d.url + '?t=' + Date.now();
          newImg.alt = '';
          newImg.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:inherit';
          avatar.insertBefore(newImg, avatar.querySelector('.avatar-overlay'));
        }
      } else { alert(d.error || 'Erro ao salvar foto'); }
    } catch(e) { alert('Erro ao enviar foto'); }
  };
  reader.readAsDataURL(file);
}
</script>

</aside>
