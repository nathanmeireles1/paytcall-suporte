<%
  const _perms = (typeof currentUser !== 'undefined' && currentUser.permissions) || {};
  const _role  = typeof currentUser !== 'undefined' ? currentUser.role : '';
  const _isAdmin = _role === 'admin';
  const _page  = typeof activePage !== 'undefined' ? activePage : '';

  // Admin bypasses all permission checks; non-admin follows DB permissions
  // Default: show item if no permission record exists yet
  const canView = (mod) => _isAdmin || !_perms[mod] || _perms[mod].can_view;

  const roleLabels = { admin: 'Administrador', suporte: 'Suporte', usuario: 'Usuário', terceiros: 'Terceiros' };
  const _userName  = typeof currentUser !== 'undefined' ? currentUser.name : '';
  const _userRole  = typeof currentUser !== 'undefined' ? currentUser.role : '';
  const _userInit  = _userName ? _userName.charAt(0).toUpperCase() : '?';
%>

<aside class="sidebar" id="sidebar">

  <!-- Brand -->
  <div class="sidebar-brand">
    <div class="brand-logo" style="background:transparent;border:none;box-shadow:none;width:34px;height:34px;padding:0">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" style="width:34px;height:34px">
        <path d="M380 344 A175 175 0 1 0 132 344 L178 298 A110 110 0 1 1 334 298 Z" fill="#c2410c"/>
        <path d="M368 337 A163 163 0 1 0 144 337 L190 292 A98 98 0 1 1 322 292 Z" fill="#f97316"/>
        <path d="M256 42 L246 72 L256 60 L266 72 Z" fill="#fb923c"/>
        <path d="M155 86 L166 118 L182 100 Z" fill="#f97316"/>
        <path d="M357 86 L346 118 L330 100 Z" fill="#f97316"/>
        <path d="M88 198 L120 212 L108 234 Z" fill="#ea580c"/>
        <path d="M424 198 L392 212 L404 234 Z" fill="#ea580c"/>
        <path d="M200 196 C178 170 167 138 176 108 C187 130 192 162 190 188 Z" fill="#c2410c"/>
        <path d="M210 190 C190 160 180 128 192 98 C202 122 206 158 204 186 Z" fill="#ea580c"/>
        <path d="M312 196 C334 170 345 138 336 108 C325 130 320 162 322 188 Z" fill="#c2410c"/>
        <path d="M302 190 C322 160 332 128 320 98 C310 122 306 158 308 186 Z" fill="#ea580c"/>
        <path d="M256 148 C244 122 240 96 256 82 C272 96 268 122 256 148 Z" fill="#fb923c"/>
        <ellipse cx="256" cy="212" rx="54" ry="58" fill="#fb923c"/>
        <path d="M220 268 C212 290 210 314 216 334 L296 334 C302 314 300 290 292 268 C278 258 264 254 256 254 C248 254 234 258 220 268 Z" fill="#ea580c"/>
        <path d="M222 272 C198 264 170 264 144 272 L146 290 C172 282 200 282 222 288 Z" fill="#f97316"/>
        <path d="M148 270 C126 258 104 260 84 274 C96 268 112 268 128 268 Z" fill="#ea580c"/>
        <path d="M144 282 C118 272 94 276 70 294 C86 284 108 280 130 280 Z" fill="#f97316"/>
        <path d="M140 298 C112 294 86 306 60 326 C80 312 106 306 136 305 Z" fill="#c2410c"/>
        <path d="M290 272 C314 264 342 264 368 272 L366 290 C340 282 312 282 290 288 Z" fill="#f97316"/>
        <path d="M364 270 C386 258 408 260 428 274 C416 268 400 268 384 268 Z" fill="#ea580c"/>
        <path d="M368 282 C394 272 418 276 442 294 C426 284 404 280 382 280 Z" fill="#f97316"/>
        <path d="M372 298 C400 294 426 306 452 326 C432 312 406 306 376 305 Z" fill="#c2410c"/>
        <path d="M256 330 L240 425 L256 398 L272 425 Z" fill="#f97316"/>
        <path d="M237 334 L212 442 L236 408 Z" fill="#ea580c"/>
        <path d="M275 334 L300 442 L276 408 Z" fill="#ea580c"/>
        <path d="M220 340 L190 458 L218 422 Z" fill="#c2410c"/>
        <path d="M292 340 L322 458 L294 422 Z" fill="#c2410c"/>
      </svg>
    </div>
    <div>
      <div class="brand-name">PAYTCALL</div>
      <div class="brand-tag">Suporte</div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="sidebar-nav">

    <!-- Principal -->
    <div class="sidebar-section">
      <div class="sidebar-section-label">Principal</div>

      <% if (canView('dashboard')) { %>
      <a href="/dashboard" class="nav-item <%= _page === 'dashboard' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        Dashboard
      </a>
      <% } %>

      <a href="/" class="nav-item <%= _page === 'rastreios' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        Rastreios
      </a>

      <% if (canView('tickets')) { %>
      <a href="/relatorios/tickets" class="nav-item <%= _page === 'tickets' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        </span>
        Tickets
      </a>
      <% } %>
    </div>

    <!-- Relatórios -->
    <% if (canView('relatorio_cancelamentos') || _isAdmin) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Relatórios</div>

      <a href="/analytics" class="nav-item <%= _page === 'analytics' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </span>
        Análises
      </a>

      <% if (canView('relatorio_cancelamentos')) { %>
      <a href="/relatorios/cancelamentos" class="nav-item <%= _page === 'cancelamentos' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
        </span>
        Cancelamentos
      </a>
      <% } %>
    </div>
    <% } %>

    <!-- Administração -->
    <% if (_isAdmin || canView('admin_usuarios') || canView('admin_permissoes')) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Administração</div>

      <% if (_isAdmin || canView('admin_usuarios')) { %>
      <a href="/admin/users" class="nav-item <%= _page === 'admin-users' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
        </span>
        Usuários
      </a>
      <% } %>

      <% if (_isAdmin || canView('admin_permissoes')) { %>
      <a href="/admin/permissions" class="nav-item <%= _page === 'admin-permissions' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </span>
        Permissões
      </a>
      <% } %>

      <% if (_isAdmin) { %>
      <a href="/admin/settings" class="nav-item <%= _page === 'admin-settings' ? 'active' : '' %>">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
        </span>
        Configurações
      </a>
      <% } %>
    </div>
    <% } %>

  </nav>

  <!-- User Footer -->
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="avatar"><%= _userInit %></div>
      <div class="user-info">
        <div class="user-name"><%= _userName %></div>
        <div class="user-role"><%= roleLabels[_userRole] || _userRole %></div>
      </div>
      <a href="/logout" class="btn-logout" title="Sair">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  </div>

</aside>
