<!-- Lina — Payt IA Chat Widget -->
<style>
.ai-chat-btn {
  position: fixed; bottom: 24px; right: 24px; z-index: 1000;
  width: 52px; height: 52px; border-radius: 99px;
  background: linear-gradient(135deg, #e47c24 0%, #c46918 100%);
  color: #fff; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 20px rgba(228,124,36,.5), 0 1px 4px rgba(0,0,0,.12);
  transition: transform .2s, box-shadow .2s;
}
.ai-chat-btn:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(228,124,36,.6), 0 2px 6px rgba(0,0,0,.15); }
.ai-chat-btn svg { width: 22px; height: 22px; stroke: #fff; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
.ai-chat-btn .icon-close { display: none; }
.ai-chat-btn.open .icon-chat { display: none; }
.ai-chat-btn.open .icon-close { display: block; }

.ai-chat-panel {
  position: fixed; bottom: 88px; right: 24px; z-index: 999;
  width: 380px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 16px; box-shadow: 0 16px 48px rgba(0,0,0,.14), 0 4px 12px rgba(0,0,0,.08);
  display: none; flex-direction: column; overflow: hidden;
  opacity: 0; transform: translateY(10px) scale(.97);
  transition: opacity .2s, transform .2s;
  max-height: 560px;
}
.ai-chat-panel.open {
  display: flex; opacity: 1; transform: translateY(0) scale(1);
}

.ai-chat-header {
  padding: 14px 16px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px;
  background: var(--surface);
  flex-shrink: 0;
}
.ai-avatar-wrap {
  position: relative; flex-shrink: 0;
}
.ai-avatar {
  width: 34px; height: 34px; border-radius: 99px;
  background: linear-gradient(135deg, #e47c24, #c46918);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', sans-serif; font-size: 15px; letter-spacing: .5px;
  color: #fff; font-weight: 400;
}
.ai-status-dot {
  position: absolute; bottom: 1px; right: 1px;
  width: 9px; height: 9px; border-radius: 99px;
  background: var(--success); border: 2px solid var(--surface);
}
.ai-info { flex: 1; min-width: 0; }
.ai-name { font-size: 13.5px; font-weight: 700; color: var(--text); line-height: 1.2; }
.ai-subtitle { font-size: 11px; color: var(--text-3); margin-top: 1px; }

.ai-chat-messages {
  flex: 1; overflow-y: auto; padding: 14px 14px 6px;
  display: flex; flex-direction: column; gap: 12px;
  scroll-behavior: smooth;
}
.ai-chat-messages::-webkit-scrollbar { width: 4px; }
.ai-chat-messages::-webkit-scrollbar-track { background: transparent; }
.ai-chat-messages::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 99px; }

.ai-msg { max-width: 86%; display: flex; flex-direction: column; gap: 3px; }
.ai-msg.user { align-self: flex-end; align-items: flex-end; }
.ai-msg.bot  { align-self: flex-start; align-items: flex-start; }
.ai-msg .bubble {
  padding: 9px 13px; border-radius: 13px; font-size: 13px; line-height: 1.55; color: var(--text);
}
.ai-msg.user .bubble {
  background: linear-gradient(135deg, #e47c24, #c46918);
  color: #fff; border-radius: 13px 13px 3px 13px;
  box-shadow: 0 2px 8px rgba(228,124,36,.3);
}
.ai-msg.bot .bubble {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 13px 13px 13px 3px;
}
.ai-msg .time { font-size: 10px; color: var(--text-4); padding: 0 3px; }

.ai-suggestions {
  display: flex; flex-wrap: wrap; gap: 6px; padding: 0 14px 10px;
  flex-shrink: 0;
}
.ai-suggestion {
  font-size: 11.5px; padding: 5px 10px; border-radius: 99px;
  border: 1px solid var(--brand-border); background: var(--brand-dim);
  color: var(--brand-dark); cursor: pointer; transition: background .12s;
  white-space: nowrap;
}
.ai-suggestion:hover { background: rgba(228,124,36,.18); }

.ai-typing { display: none; align-self: flex-start; }
.ai-typing.visible { display: flex; }
.ai-typing .bubble { display: flex; gap: 4px; align-items: center; padding: 10px 14px; }
.ai-typing .dot { width: 6px; height: 6px; border-radius: 99px; background: var(--text-3); animation: aiDot 1.2s infinite; }
.ai-typing .dot:nth-child(2) { animation-delay: .2s; }
.ai-typing .dot:nth-child(3) { animation-delay: .4s; }
@keyframes aiDot { 0%,80%,100% { opacity: .25; transform: scale(.75); } 40% { opacity: 1; transform: scale(1); } }

.ai-chat-input {
  padding: 10px 12px; border-top: 1px solid var(--border);
  display: flex; gap: 8px; align-items: flex-end;
  background: var(--surface); flex-shrink: 0;
}
.ai-chat-input textarea {
  flex: 1; resize: none; border: 1.5px solid var(--border);
  border-radius: 10px; padding: 8px 11px; font-size: 13px; font-family: var(--font);
  background: var(--surface-2); color: var(--text); max-height: 100px;
  outline: none; transition: border-color .15s, box-shadow .15s;
  line-height: 1.4;
}
.ai-chat-input textarea:focus { border-color: var(--brand-border); box-shadow: 0 0 0 3px rgba(228,124,36,.1); background: var(--surface); }
.ai-chat-input textarea::placeholder { color: var(--text-4); }
.ai-send-btn {
  width: 36px; height: 36px; border-radius: 9px; border: none;
  background: linear-gradient(135deg, #e47c24, #c46918); color: #fff; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: opacity .12s, transform .1s; flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(228,124,36,.35);
}
.ai-send-btn:hover { opacity: .9; transform: scale(1.05); }
.ai-send-btn:disabled { opacity: .45; cursor: not-allowed; transform: none; }
.ai-send-btn svg { width: 16px; height: 16px; stroke: #fff; fill: none; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round; }

.ai-clear-btn { padding: 4px 6px; border-radius: 6px; color: var(--text-4); border: none; background: none; cursor: pointer; transition: color .12s, background .12s; }
.ai-clear-btn:hover { color: var(--danger); background: var(--danger-bg); }
</style>

<!-- Toggle button -->
<button class="ai-chat-btn" id="aiChatBtn" onclick="toggleAIChat()" title="Lina — Payt IA">
  <svg class="icon-chat" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
  <svg class="icon-close" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
</button>

<!-- Chat panel -->
<div class="ai-chat-panel" id="aiChatPanel">

  <!-- Header -->
  <div class="ai-chat-header">
    <div class="ai-avatar-wrap">
      <div class="ai-avatar">L</div>
      <div class="ai-status-dot"></div>
    </div>
    <div class="ai-info">
      <div class="ai-name">Lina</div>
      <div class="ai-subtitle">Payt IA · assistente de suporte</div>
    </div>
    <button class="ai-clear-btn" onclick="clearChat()" title="Limpar conversa">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
    </button>
  </div>

  <!-- Messages -->
  <div class="ai-chat-messages" id="aiMessages">
    <div class="ai-msg bot">
      <div class="bubble">Olá! Sou a <strong>Lina</strong>, assistente de suporte da Paytcall. Posso consultar pedidos, tickets, métricas e muito mais. Como posso ajudar?</div>
      <div class="time">agora</div>
    </div>
  </div>

  <!-- Typing indicator -->
  <div class="ai-msg ai-typing bot" id="aiTyping" style="margin:0 14px 6px">
    <div class="bubble"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
  </div>

  <!-- Quick suggestions (sumem após primeiro uso) -->
  <div class="ai-suggestions" id="aiSuggestions">
    <span class="ai-suggestion" onclick="useSuggestion(this,'Quantos pedidos estão em atraso?')">Pedidos em atraso</span>
    <span class="ai-suggestion" onclick="useSuggestion(this,'Qual a taxa de entrega atual?')">Taxa de entrega</span>
    <span class="ai-suggestion" onclick="useSuggestion(this,'Quantos tickets abertos temos?')">Tickets abertos</span>
  </div>

  <!-- Input -->
  <div class="ai-chat-input">
    <textarea id="aiInput" placeholder="Pergunte sobre pedidos, tickets, métricas..." rows="1"
      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendAIMessage()}"
      oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px'"></textarea>
    <button class="ai-send-btn" id="aiSendBtn" onclick="sendAIMessage()">
      <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<script>
(function() {
  const STORAGE_KEY = 'payt_ai_history';
  const STORAGE_HTML = 'payt_ai_messages_html';
  const STORAGE_SUSED = 'payt_ai_suggestions_used';

  let aiHistory = [];
  let aiOpen = false;
  let suggestionsUsed = false;

  // Restaurar conversa anterior
  try {
    const savedHistory = sessionStorage.getItem(STORAGE_KEY);
    const savedHtml = sessionStorage.getItem(STORAGE_HTML);
    const savedSugg = sessionStorage.getItem(STORAGE_SUSED);
    if (savedHistory) aiHistory = JSON.parse(savedHistory);
    if (savedHtml) {
      document.getElementById('aiMessages').innerHTML = savedHtml;
    }
    if (savedSugg === '1') {
      suggestionsUsed = true;
      document.getElementById('aiSuggestions').style.display = 'none';
    }
  } catch(e) {}

  function saveState() {
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(aiHistory));
      sessionStorage.setItem(STORAGE_HTML, document.getElementById('aiMessages').innerHTML);
      sessionStorage.setItem(STORAGE_SUSED, suggestionsUsed ? '1' : '0');
    } catch(e) {}
  }

  window.toggleAIChat = function() {
    aiOpen = !aiOpen;
    const btn = document.getElementById('aiChatBtn');
    const panel = document.getElementById('aiChatPanel');
    btn.classList.toggle('open', aiOpen);
    panel.classList.toggle('open', aiOpen);
    if (aiOpen) {
      setTimeout(() => document.getElementById('aiInput').focus(), 150);
      scrollAI();
    }
  };

  window.clearChat = function() {
    aiHistory = [];
    suggestionsUsed = false;
    const msgs = document.getElementById('aiMessages');
    msgs.innerHTML = '<div class="ai-msg bot"><div class="bubble">Conversa reiniciada. Como posso ajudar?</div><div class="time">agora</div></div>';
    document.getElementById('aiSuggestions').style.display = 'flex';
    saveState();
  };

  window.useSuggestion = function(el, text) {
    document.getElementById('aiInput').value = text;
    document.getElementById('aiSuggestions').style.display = 'none';
    suggestionsUsed = true;
    sendAIMessage();
  };

  function scrollAI() {
    const msgs = document.getElementById('aiMessages');
    msgs.scrollTop = msgs.scrollHeight;
  }

  function fmtTime() {
    return new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  }

  function appendMsg(role, text) {
    if (!suggestionsUsed) {
      document.getElementById('aiSuggestions').style.display = 'none';
      suggestionsUsed = true;
    }
    const msgs = document.getElementById('aiMessages');
    const div = document.createElement('div');
    div.className = 'ai-msg ' + role;
    const html = text
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/`(.*?)`/g, '<code style="background:var(--surface-3);padding:1px 5px;border-radius:4px;font-size:11.5px;font-family:monospace">$1</code>')
      .replace(/\n/g, '<br>');
    div.innerHTML = '<div class="bubble">' + html + '</div><div class="time">' + fmtTime() + '</div>';
    msgs.appendChild(div);
    scrollAI();
    saveState();
  }

  window.sendAIMessage = async function() {
    const input = document.getElementById('aiInput');
    const sendBtn = document.getElementById('aiSendBtn');
    const message = input.value.trim();
    if (!message) return;

    input.value = '';
    input.style.height = 'auto';
    appendMsg('user', message);
    aiHistory.push({ role: 'user', content: message });

    const typing = document.getElementById('aiTyping');
    typing.classList.add('visible');
    sendBtn.disabled = true;
    scrollAI();

    try {
      const res = await fetch('/api/ai/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message, history: aiHistory.slice(-10) }),
      });
      const data = await res.json();
      typing.classList.remove('visible');
      sendBtn.disabled = false;

      if (data.error) {
        appendMsg('bot', '⚠️ ' + data.error);
      } else {
        appendMsg('bot', data.reply);
        aiHistory.push({ role: 'assistant', content: data.reply });
        saveState();
      }
    } catch (e) {
      typing.classList.remove('visible');
      sendBtn.disabled = false;
      appendMsg('bot', '⚠️ Erro de conexão. Tente novamente.');
    }
  };
})();
</script>
