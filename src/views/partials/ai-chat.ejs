<!-- Payt IA — Chat Widget -->
<style>
.ai-chat-btn {
  position: fixed; bottom: 24px; right: 24px; z-index: 1000;
  width: 48px; height: 48px; border-radius: 99px;
  background: var(--brand); color: #fff;
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(228,124,36,.45);
  transition: transform .15s, box-shadow .15s;
}
.ai-chat-btn:hover { transform: scale(1.07); box-shadow: 0 6px 20px rgba(228,124,36,.55); }
.ai-chat-btn svg { width: 22px; height: 22px; stroke: #fff; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
.ai-chat-btn .icon-close { display: none; }
.ai-chat-btn.open .icon-chat { display: none; }
.ai-chat-btn.open .icon-close { display: block; }

.ai-chat-panel {
  position: fixed; bottom: 82px; right: 24px; z-index: 999;
  width: 360px; max-height: 520px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 14px; box-shadow: 0 12px 40px rgba(0,0,0,.15);
  display: none; flex-direction: column; overflow: hidden;
  transition: opacity .15s, transform .15s;
  opacity: 0; transform: translateY(8px);
}
.ai-chat-panel.open { display: flex; opacity: 1; transform: translateY(0); }

.ai-chat-header {
  padding: 12px 16px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px;
  background: var(--surface-2);
}
.ai-chat-header .ai-avatar {
  width: 30px; height: 30px; border-radius: 99px;
  background: var(--brand-dim); border: 1.5px solid var(--brand-border);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 800; color: var(--brand);
  font-family: 'Bebas Neue', sans-serif; letter-spacing: .5px;
}
.ai-chat-header .ai-info { flex: 1; }
.ai-chat-header .ai-name { font-size: 13px; font-weight: 600; color: var(--text); }
.ai-chat-header .ai-status { font-size: 11px; color: var(--success); display: flex; align-items: center; gap: 4px; }
.ai-chat-header .ai-status::before { content:''; width:5px; height:5px; border-radius:99px; background:var(--success); }

.ai-chat-messages {
  flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px;
  max-height: 340px;
}
.ai-msg { max-width: 88%; display: flex; flex-direction: column; gap: 2px; }
.ai-msg.user { align-self: flex-end; align-items: flex-end; }
.ai-msg.bot  { align-self: flex-start; align-items: flex-start; }
.ai-msg .bubble {
  padding: 9px 13px; border-radius: 12px; font-size: 13px; line-height: 1.5; color: var(--text);
}
.ai-msg.user .bubble { background: var(--brand); color: #fff; border-radius: 12px 12px 2px 12px; }
.ai-msg.bot  .bubble { background: var(--surface-2); border: 1px solid var(--border); border-radius: 12px 12px 12px 2px; }
.ai-msg .time { font-size: 10px; color: var(--text-4); padding: 0 2px; }

.ai-typing { display: none; align-self: flex-start; }
.ai-typing.visible { display: flex; }
.ai-typing .bubble { display: flex; gap: 4px; align-items: center; padding: 10px 14px; }
.ai-typing .dot { width: 6px; height: 6px; border-radius: 99px; background: var(--text-4); animation: aiDot 1.2s infinite; }
.ai-typing .dot:nth-child(2) { animation-delay: .2s; }
.ai-typing .dot:nth-child(3) { animation-delay: .4s; }
@keyframes aiDot { 0%,80%,100% { opacity: .2; transform: scale(.8); } 40% { opacity: 1; transform: scale(1.1); } }

.ai-chat-input {
  padding: 10px 12px; border-top: 1px solid var(--border);
  display: flex; gap: 8px; align-items: flex-end;
  background: var(--surface-2);
}
.ai-chat-input textarea {
  flex: 1; resize: none; border: 1px solid var(--border);
  border-radius: 8px; padding: 8px 10px; font-size: 13px; font-family: var(--font);
  background: var(--surface); color: var(--text); max-height: 100px;
  outline: none; transition: border-color .12s;
  line-height: 1.4;
}
.ai-chat-input textarea:focus { border-color: var(--brand-border); }
.ai-chat-input textarea::placeholder { color: var(--text-4); }
.ai-send-btn {
  width: 34px; height: 34px; border-radius: 8px; border: none;
  background: var(--brand); color: #fff; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .12s; flex-shrink: 0;
}
.ai-send-btn:hover { background: var(--brand-dark); }
.ai-send-btn:disabled { opacity: .5; cursor: not-allowed; }
.ai-send-btn svg { width: 16px; height: 16px; stroke: #fff; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
</style>

<!-- Toggle button -->
<button class="ai-chat-btn" id="aiChatBtn" onclick="toggleAIChat()" title="Payt IA">
  <svg class="icon-chat" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
  <svg class="icon-close" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
</button>

<!-- Chat panel -->
<div class="ai-chat-panel" id="aiChatPanel">
  <div class="ai-chat-header">
    <div class="ai-avatar">P</div>
    <div class="ai-info">
      <div class="ai-name">Payt IA</div>
      <div class="ai-status">Online</div>
    </div>
    <button onclick="clearChat()" style="padding:4px;border-radius:6px;color:var(--text-4);border:none;background:none;cursor:pointer;font-size:11px" title="Limpar conversa">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
    </button>
  </div>

  <div class="ai-chat-messages" id="aiMessages">
    <div class="ai-msg bot">
      <div class="bubble">Olá! Sou a <strong>Payt IA</strong>, assistente de suporte da Paytcall. Posso consultar pedidos, tickets, métricas e muito mais. Como posso ajudar?</div>
      <div class="time">agora</div>
    </div>
  </div>

  <div class="ai-msg ai-typing bot" id="aiTyping" style="margin:0 14px 10px">
    <div class="bubble"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
  </div>

  <div class="ai-chat-input">
    <textarea id="aiInput" placeholder="Pergunte sobre pedidos, tickets, métricas..." rows="1"
      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendAIMessage()}"
      oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px'"></textarea>
    <button class="ai-send-btn" id="aiSendBtn" onclick="sendAIMessage()">
      <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<script>
(function() {
  let aiHistory = [];
  let aiOpen = false;

  window.toggleAIChat = function() {
    aiOpen = !aiOpen;
    const btn = document.getElementById('aiChatBtn');
    const panel = document.getElementById('aiChatPanel');
    btn.classList.toggle('open', aiOpen);
    panel.classList.toggle('open', aiOpen);
    if (aiOpen) {
      setTimeout(() => document.getElementById('aiInput').focus(), 100);
      scrollAI();
    }
  };

  window.clearChat = function() {
    aiHistory = [];
    const msgs = document.getElementById('aiMessages');
    msgs.innerHTML = '<div class="ai-msg bot"><div class="bubble">Conversa reiniciada. Como posso ajudar?</div><div class="time">agora</div></div>';
  };

  function scrollAI() {
    const msgs = document.getElementById('aiMessages');
    msgs.scrollTop = msgs.scrollHeight;
  }

  function fmtTime() {
    return new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  }

  function appendMsg(role, text) {
    const msgs = document.getElementById('aiMessages');
    const div = document.createElement('div');
    div.className = 'ai-msg ' + role;
    // Formata markdown básico
    const html = text
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/`(.*?)`/g, '<code style="background:var(--surface-3);padding:1px 4px;border-radius:3px;font-size:12px">$1</code>')
      .replace(/\n/g, '<br>');
    div.innerHTML = '<div class="bubble">' + html + '</div><div class="time">' + fmtTime() + '</div>';
    msgs.appendChild(div);
    scrollAI();
  }

  window.sendAIMessage = async function() {
    const input = document.getElementById('aiInput');
    const sendBtn = document.getElementById('aiSendBtn');
    const message = input.value.trim();
    if (!message) return;

    input.value = '';
    input.style.height = 'auto';
    appendMsg('user', message);
    aiHistory.push({ role: 'user', content: message });

    // Mostra typing
    const typing = document.getElementById('aiTyping');
    typing.classList.add('visible');
    sendBtn.disabled = true;
    scrollAI();

    try {
      const res = await fetch('/api/ai/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message, history: aiHistory.slice(-10) }),
      });
      const data = await res.json();
      typing.classList.remove('visible');
      sendBtn.disabled = false;

      if (data.error) {
        appendMsg('bot', '⚠️ ' + data.error);
      } else {
        appendMsg('bot', data.reply);
        aiHistory.push({ role: 'assistant', content: data.reply });
      }
    } catch (e) {
      typing.classList.remove('visible');
      sendBtn.disabled = false;
      appendMsg('bot', '⚠️ Erro de conexão. Tente novamente.');
    }
  };
})();
</script>
