<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Segmentos — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-segmentos' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: 'Segmentos', breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Segmentos' }
    ] }) %>

    <div class="page">

      <div class="page-header">
        <div>
          <h1 class="page-title">Segmentos</h1>
          <p class="page-subtitle">Nichos de produtos cadastrados</p>
        </div>
        <a href="/gestao/produtos" class="btn btn-secondary btn-sm" style="align-self:center">Ver todos os produtos</a>
      </div>

      <% if (segmentos.length === 0) { %>
        <div class="card">
          <div class="card-body" style="text-align:center;color:var(--text-3);padding:40px">
            Nenhum segmento cadastrado
          </div>
        </div>
      <% } else { %>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px">
          <% segmentos.forEach(s => { %>
          <a href="/gestao/segmentos/<%= encodeURIComponent(s.nicho) %>" style="text-decoration:none">
            <div class="card" style="padding:20px;cursor:pointer;transition:box-shadow .15s;text-align:center" onmouseenter="this.style.boxShadow='var(--shadow-md)'" onmouseleave="this.style.boxShadow=''">
              <div style="width:40px;height:40px;background:var(--brand-dim);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;margin:0 auto 12px">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--brand)" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
              </div>
              <div style="font-weight:600;font-size:14px;color:var(--text);margin-bottom:4px"><%= s.nicho %></div>
              <div style="font-size:12px;color:var(--text-3)"><%= s.total %> produto<%= s.total !== 1 ? 's' : '' %></div>
            </div>
          </a>
          <% }) %>
        </div>
      <% } %>

    </div><!-- /.page -->
  </div><!-- /.main -->

  <%- include('partials/ai-chat') %>
</div>
</body>
</html>
