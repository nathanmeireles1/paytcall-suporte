<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>#<%= shipment.order_id || shipment.tracking_code %> — Suporte Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'rastreios' }) %>

  <div class="main">
    <%- include('partials/topbar', {
      pageTitle: shipment.order_id ? '#' + shipment.order_id : shipment.tracking_code,
      breadcrumb: [
        { label: 'Paytcall', href: '/dashboard' },
        { label: 'Rastreios', href: '/rastreios' },
        { label: shipment.order_id ? '#' + shipment.order_id : shipment.tracking_code }
      ]
    }) %>

    <div class="page">

<%
const statusLabel = {
  pending: 'Pendente', posted_object: 'Obj. Postado', forwarded: 'Em Trânsito',
  delivering: 'Saiu p/ Entrega', recipient_not_found: 'Dest. não encontrado',
  delivery_problem: 'Prob. Entrega', wrong_address: 'End. Incorreto',
  waiting_client: 'Ag. Retirada', delivered: 'Entregue',
  returning: 'Devolvendo', returned: 'Devolvido', overdue: 'Em Atraso',
  no_tracking: 'Sem Rastreio', tracking_delayed: 'Rastreio em Atraso',
};
const fmtDate = (iso) => {
  if (!iso) return '—';
  try {
    return new Date(String(iso).replace(' ', 'T')).toLocaleString('pt-BR', {timeZone:'America/Sao_Paulo', day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'});
  } catch(e) { return String(iso); }
};
const cleanLocation = (loc) => (!loc || loc.includes('undefined') || loc.trim() === ',') ? '' : loc;
%>

      <!-- Page header -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px">
        <div>
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <h1 style="font-size:20px;font-weight:700;color:var(--text)">#<%= shipment.order_id || shipment.tracking_code %></h1>
            <span class="badge badge-<%= shipment.status %>"><%= statusLabel[shipment.status] || shipment.status %></span>
          </div>
          <div style="font-size:13px;color:var(--text-3);margin-top:4px">
            <%= shipment.customer_name || '—' %><% if (shipment.company_name) { %> · <%= shipment.company_name %><% } %>
          </div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn btn-secondary btn-sm" onclick="refreshTracking(event)">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
            Atualizar rastreio
          </button>
          <a href="/rastreios" class="btn btn-ghost btn-sm">← Voltar</a>
        </div>
      </div>

      <!-- Grid principal -->
      <div class="grid-2" style="margin-bottom:18px;align-items:start">

        <!-- Card rastreio -->
        <div class="card">
          <div class="card-header">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3>Rastreamento</h3>
          </div>
          <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:11px">
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Código</span>
                <div style="display:flex;align-items:center;gap:6px">
                  <code style="font-family:monospace;font-size:13px;background:var(--surface-2);border:1px solid var(--border);padding:2px 9px;border-radius:5px;letter-spacing:.5px;color:var(--text)"><%= shipment.tracking_code %></code>
                  <button onclick="copyText('<%= shipment.tracking_code %>')" class="copy-btn" title="Copiar">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                  </button>
                </div>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Transportadora</span>
                <span class="fw-600"><%= shipment.carrier || '—' %></span>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Última consulta</span>
                <span class="fw-600"><%= fmtDate(shipment.last_queried_at) %></span>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Cadastrado em</span>
                <span class="fw-600"><%= fmtDate(shipment.created_at) %></span>
              </div>
              <% if (shipment.expected_date) { %>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Previsão de entrega</span>
                <span class="fw-600" style="color:var(--success)"><%= shipment.expected_date %></span>
              </div>
              <% } %>
              <% if (shipment.tracking_url) { %>
              <div style="padding-top:8px;border-top:1px solid var(--border)">
                <a href="<%= shipment.tracking_url %>" target="_blank" class="btn btn-ghost btn-sm" style="width:100%;justify-content:center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Ver rastreio <%= shipment.carrier || '' %>
                </a>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Card pedido -->
        <div class="card">
          <div class="card-header">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            <h3>Pedido</h3>
          </div>
          <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:11px">
              <% if (shipment.order_id) { %>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">ID do Pedido</span>
                <div style="display:flex;align-items:center;gap:6px">
                  <span class="fw-600">#<%= shipment.order_id %></span>
                  <button onclick="copyText('<%= shipment.order_id %>')" class="copy-btn" title="Copiar">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                  </button>
                </div>
              </div>
              <% } %>
              <% if (shipment.product_name) { %>
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px">
                <span class="text-muted" style="flex-shrink:0">Produto</span>
                <span class="fw-600" style="text-align:right"><%= shipment.product_name %><% if (shipment.product_quantity > 1) { %> ×<%= shipment.product_quantity %><% } %></span>
              </div>
              <% } %>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Empresa</span>
                <span class="fw-600"><%= shipment.company_name || shipment.seller_id || '—' %></span>
              </div>
              <% if (shipment.paid_at) { %>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Pago em</span>
                <span class="fw-600"><%= fmtDate(shipment.paid_at) %></span>
              </div>
              <% } %>
              <% if (shipment.total_price) { %>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Total pago</span>
                <span class="fw-600" style="color:var(--success)">R$ <%= (shipment.total_price/100).toFixed(2).replace('.',',') %></span>
              </div>
              <% } %>
              <% if (shipment.payment_method) { %>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
                <span class="text-muted">Pagamento</span>
                <span class="fw-600"><%= {pix:'PIX',credit_card:'Cartão de crédito',boleto:'Boleto',debit_card:'Cartão de débito'}[shipment.payment_method] || shipment.payment_method %></span>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="grid-2" style="margin-bottom:18px;align-items:start">

        <!-- Cliente -->
        <div class="card">
          <div class="card-header">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <h3>Cliente</h3>
          </div>
          <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:11px">
              <% if (shipment.customer_name) { %>
              <div style="display:flex;justify-content:space-between;gap:12px"><span class="text-muted">Nome</span><span class="fw-600"><%= shipment.customer_name %></span></div>
              <% } %>
              <% if (shipment.customer_email) { %>
              <div style="display:flex;justify-content:space-between;gap:12px"><span class="text-muted">Email</span><span style="font-size:13px;color:var(--text-2)"><%= shipment.customer_email %></span></div>
              <% } %>
              <% if (shipment.customer_cpf || shipment.customer_doc) { %>
              <div style="display:flex;justify-content:space-between;gap:12px"><span class="text-muted">CPF</span><span class="fw-600"><%= (shipment.customer_cpf || shipment.customer_doc || '').replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4') %></span></div>
              <% } %>
              <% if (shipment.customer_phone) { %>
              <div style="display:flex;justify-content:space-between;gap:12px"><span class="text-muted">Telefone</span><span class="fw-600"><%= shipment.customer_phone %></span></div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Endereço -->
        <% const addr = shipment.shipping_address ? (typeof shipment.shipping_address === 'string' ? JSON.parse(shipment.shipping_address) : shipment.shipping_address) : null; %>
        <% if (addr) { %>
        <div class="card">
          <div class="card-header">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3>Endereço de Entrega</h3>
          </div>
          <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:11px">
              <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start"><span class="text-muted" style="flex-shrink:0">Logradouro</span><span class="fw-600" style="text-align:right"><%= addr.street %><% if (addr.street_number) { %>, <%= addr.street_number %><% } %><% if (addr.complement) { %> — <%= addr.complement %><% } %></span></div>
              <% if (addr.district) { %><div style="display:flex;justify-content:space-between;gap:12px"><span class="text-muted">Bairro</span><span class="fw-600"><%= addr.district %></span></div><% } %>
              <div style="display:flex;justify-content:space-between;gap:12px"><span class="text-muted">Cidade / UF</span><span class="fw-600"><%= addr.city %> / <%= addr.state %></span></div>
              <div style="display:flex;justify-content:space-between;gap:12px"><span class="text-muted">CEP</span><span class="fw-600"><%= String(addr.zipcode||'').replace(/^(\d{5})(\d{3})$/, '$1-$2') %></span></div>
            </div>
          </div>
        </div>
        <% } %>
      </div>

      <!-- Último evento -->
      <% if (shipment.last_event) { %>
      <div class="card" style="margin-bottom:18px;border-left:3px solid var(--brand)">
        <div class="card-header">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <h3>Último Evento</h3>
        </div>
        <div class="card-body">
          <div style="font-size:13.5px;font-weight:500;color:var(--text)"><%= shipment.last_event %></div>
          <% if (shipment.last_event_date) { %><div style="font-size:12px;color:var(--text-3);margin-top:4px"><%= fmtDate(shipment.last_event_date) %></div><% } %>
        </div>
      </div>
      <% } %>

      <!-- Timeline -->
      <% if (events.length > 0) { %>
      <div class="card" style="margin-bottom:18px">
        <div class="card-header">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/></svg>
          <h3>Histórico de Rastreamento</h3>
          <span class="badge badge-neutral" style="margin-left:auto"><%= events.length %> eventos</span>
        </div>
        <div class="card-body no-pad">
          <div style="position:relative;padding:16px 20px">
            <div style="position:absolute;left:32px;top:0;bottom:0;width:2px;background:var(--border)"></div>
            <% events.forEach((ev, idx) => { %>
            <div style="display:flex;gap:14px;padding-bottom:<%= idx === events.length-1 ? '0' : '16px' %>">
              <div style="flex-shrink:0;width:12px;height:12px;border-radius:99px;background:<%= idx===0 ? 'var(--brand)' : 'var(--border-2)' %>;border:2px solid var(--surface);box-shadow:0 0 0 2px <%= idx===0 ? 'var(--brand)' : 'var(--border-2)' %>;margin-top:3px;position:relative;z-index:1"></div>
              <div style="flex:1;min-width:0">
                <div style="font-size:13px;font-weight:500;color:var(--text)"><%= ev.description %></div>
                <div style="font-size:11.5px;color:var(--text-3);margin-top:2px">
                  <%= ev.event_date ? fmtDate(ev.event_date) : '' %>
                  <% const loc = cleanLocation(ev.location); if (loc) { %> · <%= loc %><% } %>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Tickets -->
      <div class="card" style="margin-bottom:18px">
        <div class="card-header">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
          <h3>Tickets de Suporte</h3>
          <span class="badge badge-neutral" style="margin-left:auto"><%= tickets.length %></span>
        </div>
        <div class="card-body">
          <% if (tickets.length > 0) { %>
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px">
          <% tickets.forEach(t => {
            const cfg = TICKET_CONFIG[t.tipo] || {};
            const isTerminal = (cfg.terminalStatuses || []).includes(t.status);
            const hoursOpen = Math.floor((Date.now() - new Date(t.created_at).getTime()) / 3600000);
            const prioColor = {1:'var(--danger)',2:'var(--warning)',3:'var(--text-3)'}[t.priority] || 'var(--text-3)';
            const tipoLabel = t.tipo === 'RETENCAO' ? 'Retenção' : 'Logística';
          %>
          <div style="border:1px solid var(--border);border-left:3px solid <%= isTerminal ? 'var(--border-2)' : 'var(--brand)' %>;border-radius:var(--radius-md);padding:12px 14px;opacity:<%= isTerminal ? '.7' : '1' %>">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:6px">
              <span class="badge badge-brand" style="<%= t.tipo === 'LOGISTICA' ? 'background:var(--info-bg);color:var(--info);border-color:var(--info-border)' : '' %>"><%= tipoLabel %></span>
              <span style="font-weight:600;font-size:13px;color:var(--text)"><%= t.motivo %></span>
              <% if (t.motivo_cancelamento) { %><span style="font-size:12px;color:var(--text-3)">— <%= t.motivo_cancelamento %></span><% } %>
              <span style="margin-left:auto;font-size:11px;padding:2px 8px;border-radius:99px;background:var(--surface-2);color:var(--text-2);border:1px solid var(--border)"><%= t.status %></span>
            </div>
            <div style="font-size:12px;color:var(--text-3)">
              <% if (t.assigned_to) { %><strong style="color:var(--text-2)"><%= t.assigned_to %></strong> · <% } %>
              Criado por <%= t.created_by %> · <%= fmtDate(t.created_at) %>
              <% if (!isTerminal) { %>
              · <span style="color:<%= hoursOpen >= 72 ? 'var(--danger)' : hoursOpen >= 48 ? 'var(--warning)' : 'var(--text-3)' %>;font-weight:<%= hoursOpen >= 48 ? '600' : '400' %>">
                Aberto há <%= hoursOpen %>h<% if (hoursOpen >= 72) { %> (SLA estourado)<% } %>
              </span>
              <% } else if (t.closed_at) { %>
              · <span style="color:var(--success)">Encerrado em <%= fmtDate(t.closed_at) %></span>
              <% } %>
            </div>
            <% if (t.observacao) { %><div style="font-size:13px;color:var(--text-2);margin-top:8px;padding-top:8px;border-top:1px solid var(--border)"><%= t.observacao %></div><% } %>
            <% if (!isTerminal) { %>
            <div style="margin-top:10px;display:flex;align-items:center;gap:6px">
              <select onchange="updateTicketStatus('<%= t.id %>', this)" class="form-select" style="font-size:12px;padding:4px 8px;max-width:200px">
                <option value="">Alterar status...</option>
                <% (cfg.statuses || []).filter(s => s !== t.status).forEach(s => { %>
                <option value="<%= s %>"><%= s %></option>
                <% }) %>
              </select>
            </div>
            <% } %>
          </div>
          <% }) %>
          </div>
          <% } %>

          <!-- Abrir novo ticket -->
          <details>
            <summary style="cursor:pointer;font-size:13px;font-weight:600;color:var(--brand);list-style:none;display:flex;align-items:center;gap:6px">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Abrir novo ticket
            </summary>
            <form method="POST" action="/shipment/<%= shipment.tracking_code %>/ticket" style="margin-top:14px;display:flex;flex-direction:column;gap:10px">
              <select name="tipo" id="ticketTipo" class="form-select" required>
                <option value="">Selecione o tipo</option>
                <option value="RETENCAO">Retenção</option>
                <option value="LOGISTICA">Logística</option>
              </select>
              <select name="motivo" id="ticketMotivo" class="form-select" required disabled>
                <option value="">Selecione o motivo</option>
              </select>
              <div id="motivoCancelamentoWrap" style="display:none">
                <select name="motivo_cancelamento" id="ticketMotivoCancelamento" class="form-select">
                  <option value="">Motivo do cancelamento (opcional)</option>
                  <% MOTIVOS_CANCELAMENTO.forEach(m => { %>
                  <option value="<%= m %>"><%= m %></option>
                  <% }) %>
                </select>
              </div>
              <textarea name="observacao" placeholder="Observações (opcional)" class="form-textarea" style="min-height:80px"></textarea>
              <div><button type="submit" class="btn btn-primary btn-sm">Abrir ticket</button></div>
            </form>
          </details>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
function copyText(text) {
  navigator.clipboard.writeText(text).catch(() => {});
}

function refreshTracking(e) {
  const btn = e.currentTarget;
  btn.disabled = true;
  btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="animation:spin .8s linear infinite"><path d="M21 12a9 9 0 11-6.22-8.56"/></svg> Consultando…';
  fetch('/api/tracking/<%= shipment.tracking_code %>')
    .then(r => r.json())
    .then(() => location.reload())
    .catch(() => {
      btn.disabled = false;
      btn.textContent = 'Atualizar rastreio';
      alert('Erro ao consultar. Tente novamente.');
    });
}

const TCFG = <%- JSON.stringify(TICKET_CONFIG) %>;
const tipoSel = document.getElementById('ticketTipo');
const motivoSel = document.getElementById('ticketMotivo');
const cancelWrap = document.getElementById('motivoCancelamentoWrap');

if (tipoSel) {
  tipoSel.addEventListener('change', function() {
    const tipo = this.value;
    motivoSel.innerHTML = '<option value="">Selecione o motivo</option>';
    motivoSel.disabled = !tipo;
    cancelWrap.style.display = 'none';
    if (tipo && TCFG[tipo]) {
      TCFG[tipo].motivos.forEach(m => {
        const opt = document.createElement('option');
        opt.value = m; opt.textContent = m;
        motivoSel.appendChild(opt);
      });
    }
  });
  motivoSel.addEventListener('change', function() {
    cancelWrap.style.display = (tipoSel.value === 'RETENCAO' && this.value === 'Cancelamento') ? 'block' : 'none';
  });
}

function updateTicketStatus(id, selectEl) {
  const newStatus = selectEl.value;
  if (!newStatus || !confirm('Alterar status para "' + newStatus + '"?')) { selectEl.value = ''; return; }
  fetch('/ticket/' + id + '/status', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status: newStatus }),
  })
  .then(r => r.json())
  .then(d => { if (d.ok) location.reload(); else alert(d.error || 'Erro'); })
  .catch(() => { selectEl.value = ''; alert('Erro ao alterar status.'); });
}

// Notificações
const NOTIF_USER = '<%= typeof currentUser !== "undefined" ? currentUser.name : "" %>';
function toggleNotifs() {
  const dd = document.getElementById('notifDropdown');
  dd.classList.toggle('open');
  if (dd.classList.contains('open')) loadNotifs();
}
async function loadNotifs() {
  try {
    const r = await fetch('/api/notifications');
    const { notifications, unread } = await r.json();
    const b = document.getElementById('notifBadge');
    b.style.display = unread > 0 ? 'block' : 'none';
    b.textContent = unread;
    const list = document.getElementById('notifList');
    if (!notifications.length) { list.innerHTML = '<div style="text-align:center;color:var(--gray-400);padding:24px;font-size:13px">Nenhuma notificação</div>'; return; }
    list.innerHTML = notifications.map(n => {
      const date = new Date(n.created_at).toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo',day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
      return `<a href="/pedido/${n.order_id||n.tracking_code||''}" class="notif-item${n.is_read ? '' : ' unread'}"><div style="font-size:13px;color:var(--text-2)">${n.message}</div><div style="font-size:11px;color:var(--text-4);margin-top:2px">${date}</div></a>`;
    }).join('');
  } catch(e) {}
}
async function markAllRead() {
  await fetch('/api/notifications/read', { method: 'POST' });
  loadNotifs();
}
if (NOTIF_USER) {
  fetch('/api/notifications').then(r=>r.json()).then(({unread})=>{
    const b = document.getElementById('notifBadge');
    if (b) { b.style.display = unread > 0 ? 'block' : 'none'; b.textContent = unread; }
  }).catch(()=>{});
}
document.addEventListener('click', (e) => {
  const dd = document.getElementById('notifDropdown');
  const btn = document.getElementById('notifBtn');
  if (dd && btn && !dd.contains(e.target) && !btn.contains(e.target)) dd.classList.remove('open');
});
@keyframes spin { to { transform: rotate(360deg); } }
</script>
