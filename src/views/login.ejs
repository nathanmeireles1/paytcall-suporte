        <path d="M304 192 C324 163 334 130 324 100 C314 124 310 158 312 186 Z" fill="#ea580c"/>
        <path d="M296 186 C312 155 318 122 306 92 C297 118 294 155 297 182 Z" fill="#f97316"/>
        <path d="M256 148 C244 122 240 96 256 82 C272 96 268 122 256 148 Z" fill="#fb923c"/>
        <ellipse cx="256" cy="212" rx="54" ry="58" fill="#fb923c"/>
        <ellipse cx="248" cy="204" rx="30" ry="34" fill="#fbbf24" opacity="0.22"/>
        <path d="M220 268 C212 290 210 314 216 334 L296 334 C302 314 300 290 292 268 C280 258 266 254 256 254 C246 254 232 258 220 268 Z" fill="#ea580c"/>
