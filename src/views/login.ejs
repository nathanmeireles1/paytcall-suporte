<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entrar — Suporte Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
      min-height: 100vh;
      display: flex;
      background: #faf8f5;
    }

    /* Left panel — brand */
    .panel-left {
      width: 480px;
      flex-shrink: 0;
      background: #1a1410;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 44px 48px;
      position: relative;
      overflow: hidden;
    }

    .panel-left::before {
      content: '';
      position: absolute;
      top: -120px;
      left: -80px;
      width: 360px;
      height: 360px;
      background: radial-gradient(circle, rgba(228,124,36,.22) 0%, transparent 70%);
      pointer-events: none;
    }

    .panel-left::after {
      content: '';
      position: absolute;
      bottom: -80px;
      right: -100px;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(228,124,36,.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .brand-icon {
      width: 36px;
      height: 36px;
      background: rgba(228,124,36,.15);
      border: 1.5px solid rgba(228,124,36,.4);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 800;
      color: #e47c24;
      letter-spacing: -1px;
    }

    .brand-text .brand-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px;
      font-weight: 400;
      color: #fff;
      letter-spacing: 1px;
      text-transform: uppercase;
      line-height: 1;
    }

    .brand-text .brand-tag {
      font-size: 10px;
      font-weight: 600;
      color: rgba(255,255,255,.35);
      letter-spacing: .8px;
      text-transform: uppercase;
      margin-top: 1px;
    }

    .panel-tagline {
      position: relative;
      z-index: 1;
    }

    .panel-tagline h2 {
      font-size: 26px;
      font-weight: 700;
      color: #fff;
      line-height: 1.3;
      letter-spacing: -.5px;
      margin-bottom: 12px;
    }

    .panel-tagline p {
      font-size: 13px;
      color: rgba(255,255,255,.45);
      line-height: 1.6;
    }

    .panel-dots {
      display: flex;
      gap: 6px;
      position: relative;
      z-index: 1;
    }

    .panel-dots span {
      width: 6px;
      height: 6px;
      border-radius: 99px;
      background: rgba(255,255,255,.2);
    }

    .panel-dots span:first-child {
      background: #e47c24;
      width: 18px;
    }

    /* Right panel — form */
    .panel-right {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 24px;
    }

    .form-wrap {
      width: 100%;
      max-width: 380px;
    }

    .form-head {
      margin-bottom: 28px;
    }

    .form-head h1 {
      font-size: 22px;
      font-weight: 700;
      color: #1a1410;
      letter-spacing: -.4px;
      margin-bottom: 4px;
    }

    .form-head p {
      font-size: 13px;
      color: #8a7a6a;
    }

    .field {
      margin-bottom: 14px;
    }

    .field label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #4a3f35;
      margin-bottom: 5px;
    }

    .field input {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #e0d8cc;
      border-radius: 7px;
      font-size: 13.5px;
      font-family: inherit;
      color: #1a1410;
      background: #faf8f5;
      transition: border-color .15s, box-shadow .15s;
      outline: none;
    }

    .field input:focus {
      border-color: #e47c24;
      box-shadow: 0 0 0 3px rgba(228,124,36,.12);
      background: #fff;
    }

    .field input::placeholder {
      color: #b8aba0;
    }

    .btn-submit {
      width: 100%;
      padding: 11px;
      background: #e47c24;
      color: #fff;
      border: none;
      border-radius: 7px;
      font-size: 14px;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background .15s, transform .1s;
      margin-top: 6px;
      letter-spacing: -.1px;
    }

    .btn-submit:hover { background: #c46918; }
    .btn-submit:active { transform: scale(.99); }

    .error-msg {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
      padding: 10px 14px;
      border-radius: 7px;
      font-size: 13px;
      margin-bottom: 16px;
    }

    .footer-text {
      text-align: center;
      font-size: 11.5px;
      color: #b8aba0;
      margin-top: 24px;
    }

    /* Mobile: stack panels */
    @media (max-width: 768px) {
      body { flex-direction: column; }
      .panel-left { width: 100%; padding: 28px 24px; gap: 0; }
      .panel-tagline, .panel-dots { display: none; }
    }
  </style>
</head>
<body>

  <!-- Left brand panel -->
  <div class="panel-left">
    <div class="brand">
      <div class="brand-icon">P</div>
      <div class="brand-text">
        <div class="brand-name">Paytcall</div>
        <div class="brand-tag">Suporte</div>
      </div>
    </div>

    <!-- Lina logo centered -->
    <div style="flex:1;display:flex;align-items:center;justify-content:center;position:relative;z-index:1">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" style="width:220px;height:220px;filter:drop-shadow(0 0 32px rgba(228,124,36,.35))">
        <!-- Outer flame wreath — left side -->
        <path d="M108 348 C72 282 82 198 138 152 C116 216 148 262 168 284 C152 308 132 328 108 348Z" fill="#b91c1c"/>
        <path d="M128 338 C96 276 108 204 158 164 C140 224 166 268 182 288 C168 310 150 326 128 338Z" fill="#e47c24"/>
        <!-- Outer flame wreath — right side -->
        <path d="M404 348 C440 282 430 198 374 152 C396 216 364 262 344 284 C360 308 380 328 404 348Z" fill="#b91c1c"/>
        <path d="M384 338 C416 276 404 204 354 164 C372 224 346 268 330 288 C344 310 362 326 384 338Z" fill="#e47c24"/>
        <!-- Top left flame spike -->
        <path d="M162 128 C144 82 164 44 200 36 C176 68 188 100 198 122 C180 126 170 128 162 128Z" fill="#b91c1c"/>
        <path d="M174 122 C158 80 176 50 206 44 C184 72 194 100 204 118 C190 122 182 122 174 122Z" fill="#e47c24"/>
        <!-- Top right flame spike -->
        <path d="M350 128 C368 82 348 44 312 36 C336 68 324 100 314 122 C332 126 342 128 350 128Z" fill="#b91c1c"/>
        <path d="M338 122 C354 80 336 50 306 44 C328 72 318 100 308 118 C322 122 330 122 338 122Z" fill="#e47c24"/>
        <!-- Top center flame -->
        <path d="M256 88 C242 58 246 28 256 16 C266 28 270 58 256 88Z" fill="#e47c24"/>
        <path d="M232 104 C212 68 218 38 230 26 C236 50 238 76 232 104Z" fill="#b91c1c" opacity=".9"/>
        <path d="M280 104 C300 68 294 38 282 26 C276 50 274 76 280 104Z" fill="#b91c1c" opacity=".9"/>
        <!-- Female silhouette — head -->
        <ellipse cx="256" cy="192" rx="34" ry="38" fill="#e47c24"/>
        <!-- Hair left -->
        <path d="M222 178 C210 164 214 140 222 128 C226 144 226 162 222 178Z" fill="#c46918"/>
        <!-- Hair right -->
        <path d="M290 178 C302 164 298 140 290 128 C286 144 286 162 290 178Z" fill="#c46918"/>
        <!-- Body / torso -->
        <path d="M218 228 C204 240 200 262 204 284 L308 284 C312 262 308 240 294 228 C280 220 268 216 256 216 C244 216 232 220 218 228Z" fill="#e47c24"/>
        <!-- Arms — left -->
        <path d="M204 236 C185 242 162 248 136 258 C145 265 162 268 178 264 C190 256 198 248 204 236Z" fill="#e47c24"/>
        <!-- Arms — right -->
        <path d="M308 236 C327 242 350 248 376 258 C367 265 350 268 334 264 C322 256 314 248 308 236Z" fill="#e47c24"/>
        <!-- Bottom flames -->
        <path d="M256 284 L228 380 L256 358 L284 380 Z" fill="#e47c24"/>
        <path d="M256 284 L205 395 L240 368 Z" fill="#b91c1c"/>
        <path d="M256 284 L307 395 L272 368 Z" fill="#b91c1c"/>
        <!-- Accent diamonds -->
        <polygon points="200,108 208,120 196,120" fill="#fca5a5" opacity=".6"/>
        <polygon points="312,108 320,120 308,120" fill="#fca5a5" opacity=".6"/>
        <polygon points="145,200 155,215 143,215" fill="#fca5a5" opacity=".5"/>
        <polygon points="367,200 357,215 369,215" fill="#fca5a5" opacity=".5"/>
      </svg>
    </div>

    <div class="panel-tagline">
      <h2>Central de<br>Suporte Paytcall</h2>
      <p>Rastreios, tickets e relatórios<br>em um só lugar.</p>
    </div>

  </div>

  <!-- Right form panel -->
  <div class="panel-right">
    <div class="form-wrap">
      <div class="form-head">
        <h1>Bem-vindo de volta</h1>
        <p>Entre com seus dados de acesso</p>
      </div>

      <% if (error) { %>
      <div class="error-msg">
        <% if (error === 'inactive') { %>
          Conta desativada. Contate o administrador.
        <% } else { %>
          <%= error %>
        <% } %>
      </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autofocus placeholder="seu@email.com">
        </div>
        <div class="field">
          <label for="password">Senha</label>
          <input type="password" id="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn-submit">Entrar</button>
      </form>

      <div class="footer-text">Suporte Paytcall &copy; 2025</div>
    </div>
  </div>

</body>
</html>
