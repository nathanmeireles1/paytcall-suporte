        <path d="M144 282 C120 272 96 276 72 292 C86 284 106 280 128 280 Z" fill="#f97316"/>
        <path d="M140 296 C114 292 88 302 62 320 C80 308 104 303 134 302 Z" fill="#c2410c"/>
        <path d="M132 312 C104 316 76 330 50 352 C74 334 100 328 136 324 Z" fill="#ea580c"/>
        <path d="M290 272 C314 264 342 264 368 272 L366 290 C340 282 312 282 290 288 Z" fill="#f97316"/>
        <path d="M364 270 C386 258 408 260 428 274 C416 268 400 268 384 268 Z" fill="#ea580c"/>
        <path d="M368 282 C392 272 416 276 440 292 C426 284 406 280 384 280 Z" fill="#f97316"/>
        <path d="M372 296 C398 292 424 302 450 320 C432 308 408 303 378 302 Z" fill="#c2410c"/>
        <path d="M380 312 C408 316 436 330 462 352 C438 334 412 328 376 324 Z" fill="#ea580c"/>
        <path d="M256 330 L240 425 L256 398 L272 425 Z" fill="#f97316"/>
        <path d="M237 334 L212 440 L236 408 Z" fill="#ea580c"/>
        <path d="M275 334 L300 440 L276 408 Z" fill="#ea580c"/>
        <path d="M220 340 L190 455 L217 420 Z" fill="#c2410c"/>
        <path d="M292 340 L322 455 L295 420 Z" fill="#c2410c"/>
      </svg>
    </div>

    <div class="panel-tagline">
      <h2>Central de<br>Suporte Paytcall</h2>
      <p>Rastreios, tickets e relatórios<br>em um só lugar.</p>
    </div>

  </div>

  <!-- Right form panel -->
  <div class="panel-right">
    <div class="form-wrap">
      <div class="form-head">
        <h1>Bem-vindo de volta</h1>
        <p>Entre com seus dados de acesso</p>
      </div>

      <% if (error) { %>
      <div class="error-msg">
        <% if (error === 'inactive') { %>
          Conta desativada. Contate o administrador.
        <% } else { %>
          <%= error %>
        <% } %>
      </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autofocus placeholder="seu@email.com">
        </div>
        <div class="field">
          <label for="password">Senha</label>
          <input type="password" id="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn-submit">Entrar</button>
      </form>

      <div class="footer-text">Suporte Paytcall &copy; 2025</div>
    </div>
  </div>

</body>
</html>
