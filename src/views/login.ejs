<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entrar — Suporte Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
      min-height: 100vh;
      display: flex;
      background: #faf8f5;
    }

    /* Left panel — brand */
    .panel-left {
      width: 480px;
      flex-shrink: 0;
      background: #1a1410;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 44px 48px;
      position: relative;
      overflow: hidden;
    }

    .panel-left::before {
      content: '';
      position: absolute;
      top: -120px;
      left: -80px;
      width: 360px;
      height: 360px;
      background: radial-gradient(circle, rgba(228,124,36,.22) 0%, transparent 70%);
      pointer-events: none;
    }

    .panel-left::after {
      content: '';
      position: absolute;
      bottom: -80px;
      right: -100px;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(228,124,36,.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .brand-icon {
      width: 36px;
      height: 36px;
      background: rgba(228,124,36,.15);
      border: 1.5px solid rgba(228,124,36,.4);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 800;
      color: #e47c24;
      letter-spacing: -1px;
    }

    .brand-text .brand-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px;
      font-weight: 400;
      color: #fff;
      letter-spacing: 1px;
      text-transform: uppercase;
      line-height: 1;
    }

    .brand-text .brand-tag {
      font-size: 10px;
      font-weight: 600;
      color: rgba(255,255,255,.35);
      letter-spacing: .8px;
      text-transform: uppercase;
      margin-top: 1px;
    }

    .panel-tagline {
      position: relative;
      z-index: 1;
    }

    .panel-tagline h2 {
      font-size: 26px;
      font-weight: 700;
      color: #fff;
      line-height: 1.3;
      letter-spacing: -.5px;
      margin-bottom: 12px;
    }

    .panel-tagline p {
      font-size: 13px;
      color: rgba(255,255,255,.45);
      line-height: 1.6;
    }

    .panel-dots {
      display: flex;
      gap: 6px;
      position: relative;
      z-index: 1;
    }

    .panel-dots span {
      width: 6px;
      height: 6px;
      border-radius: 99px;
      background: rgba(255,255,255,.2);
    }

    .panel-dots span:first-child {
      background: #e47c24;
      width: 18px;
    }

    /* Right panel — form */
    .panel-right {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 24px;
    }

    .form-wrap {
      width: 100%;
      max-width: 380px;
    }

    .form-head {
      margin-bottom: 28px;
    }

    .form-head h1 {
      font-size: 22px;
      font-weight: 700;
      color: #1a1410;
      letter-spacing: -.4px;
      margin-bottom: 4px;
    }

    .form-head p {
      font-size: 13px;
      color: #8a7a6a;
    }

    .field {
      margin-bottom: 14px;
    }

    .field label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #4a3f35;
      margin-bottom: 5px;
    }

    .field input {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #e0d8cc;
      border-radius: 7px;
      font-size: 13.5px;
      font-family: inherit;
      color: #1a1410;
      background: #faf8f5;
      transition: border-color .15s, box-shadow .15s;
      outline: none;
    }

    .field input:focus {
      border-color: #e47c24;
      box-shadow: 0 0 0 3px rgba(228,124,36,.12);
      background: #fff;
    }

    .field input::placeholder {
      color: #b8aba0;
    }

    .btn-submit {
      width: 100%;
      padding: 11px;
      background: #e47c24;
      color: #fff;
      border: none;
      border-radius: 7px;
      font-size: 14px;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background .15s, transform .1s;
      margin-top: 6px;
      letter-spacing: -.1px;
    }

    .btn-submit:hover { background: #c46918; }
    .btn-submit:active { transform: scale(.99); }

    .error-msg {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
      padding: 10px 14px;
      border-radius: 7px;
      font-size: 13px;
      margin-bottom: 16px;
    }

    .footer-text {
      text-align: center;
      font-size: 11.5px;
      color: #b8aba0;
      margin-top: 24px;
    }

    /* Mobile: stack panels */
    @media (max-width: 768px) {
      body { flex-direction: column; }
      .panel-left { width: 100%; padding: 28px 24px; gap: 0; }
      .panel-tagline, .panel-dots { display: none; }
    }
  </style>
</head>
<body>

  <!-- Left brand panel -->
  <div class="panel-left">
    <div class="brand">
      <div class="brand-icon">P</div>
      <div class="brand-text">
        <div class="brand-name">Paytcall</div>
        <div class="brand-tag">Suporte</div>
      </div>
    </div>

    <!-- Lina logo centered -->
    <div style="flex:1;display:flex;align-items:center;justify-content:center;position:relative;z-index:1">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" style="width:230px;height:230px;filter:drop-shadow(0 0 28px rgba(234,88,12,.5))">
        <path d="M380 344 A175 175 0 1 0 132 344 L178 298 A110 110 0 1 1 334 298 Z" fill="#c2410c"/>
        <path d="M372 338 A168 168 0 1 0 140 338 L186 294 A103 103 0 1 1 326 294 Z" fill="#ea580c"/>
