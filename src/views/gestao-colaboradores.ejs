<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Colaboradores — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-colaboradores' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: 'Colaboradores', breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Colaboradores' }
    ] }) %>

    <div class="page">

      <div class="p-page-header" style="margin-bottom:16px">
        <div class="p-page-header-left">
          <h1>Colaboradores</h1>
          <p class="p-subtitle">Dados sincronizados do Portal de Gestão — somente leitura</p>
        </div>
        <div class="p-page-header-right">
          <span style="font-size:12px;color:var(--text-3)"><%= colaboradores.length %> colaboradores</span>
        </div>
      </div>

      <!-- Toolbar de busca -->
      <div class="toolbar" style="margin-bottom:12px">
        <input type="text" class="form-input" placeholder="Buscar por nome, email ou equipe..." id="searchInput" oninput="filterTable()" style="max-width:340px">
        <select class="form-select" id="filterAtivo" onchange="filterTable()" style="width:140px">
          <option value="">Todos</option>
          <option value="true" selected>Ativos</option>
          <option value="false">Inativos</option>
        </select>
        <select class="form-select" id="filterRegiao" onchange="filterTable()" style="width:140px">
          <option value="">Região</option>
          <% [...new Set(colaboradores.map(c => c.regiao).filter(Boolean))].sort().forEach(r => { %>
          <option value="<%= r.toLowerCase() %>"><%= r %></option>
          <% }) %>
        </select>
      </div>

      <div class="card" style="padding:0">
        <div class="table-wrap">
          <table id="tabelaColaboradores">
            <thead>
              <tr>
                <th>Nome</th>
                <th>Email</th>
                <th>Equipe</th>
                <th>Região</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% colaboradores.forEach(c => { %>
              <tr data-nome="<%= (c.primeiro_nome || c.nome || '').toLowerCase() %>"
                  data-email="<%= (c.email || '').toLowerCase() %>"
                  data-equipe="<%= (c.equipe || '').toLowerCase() %>"
                  data-regiao="<%= (c.regiao || '').toLowerCase() %>"
                  data-ativo="<%= c.ativo %>">
                <td>
                  <div style="font-weight:500"><%= c.primeiro_nome || '—' %></div>
                  <div style="font-size:11px;color:var(--text-3)"><%= c.nome || '' %></div>
                </td>
                <td style="font-size:12px"><%= c.email || '—' %></td>
                <td><%= c.equipe || '—' %></td>
                <td><%= c.regiao || '—' %></td>
                <td>
                  <span class="badge <%= c.ativo ? 'badge-success' : 'badge-neutral' %>">
                    <%= c.ativo ? 'Ativo' : 'Inativo' %>
                  </span>
                </td>
              </tr>
              <% }) %>
              <% if (colaboradores.length === 0) { %>
              <tr><td colspan="5" class="empty-state" style="padding:40px">Nenhum colaborador encontrado</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <%- include('partials/ai-chat') %>
</div>

<script>
  function filterTable() {
    const q      = document.getElementById('searchInput').value.toLowerCase();
    const ativo  = document.getElementById('filterAtivo').value;
    const regiao = document.getElementById('filterRegiao').value;
    document.querySelectorAll('#tabelaColaboradores tbody tr').forEach(tr => {
      const matchQ = !q || tr.dataset.nome.includes(q) || tr.dataset.email.includes(q) || tr.dataset.equipe.includes(q);
      const matchA = !ativo  || tr.dataset.ativo   === ativo;
      const matchR = !regiao || tr.dataset.regiao   === regiao;
      tr.style.display = matchQ && matchA && matchR ? '' : 'none';
    });
  }
  filterTable();
</script>
</body>
</html>
