<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Configurações — Paytcall Operações</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
  <style>
    /* Badges role */
    .badge-admin     { background: var(--purple-bg); color: var(--purple); }
    .badge-suporte   { background: var(--info-bg); color: var(--info); }
    .badge-logistica { background: var(--info-bg); color: var(--info); }
    .badge-retencao  { background: var(--warning-bg); color: var(--warning); }
    .badge-usuario   { background: var(--success-bg); color: var(--success); }
    .badge-terceiros { background: var(--warning-bg); color: var(--warning); }
    .badge-active    { background: var(--success-bg); color: var(--success); }
    .badge-inactive  { background: var(--danger-bg); color: var(--danger); }
    .badge-pending   { background: var(--warning-bg); color: var(--warning); }
    .invite-link     { background: var(--success-bg); border: 1px solid #bbf7d0; padding: 12px 16px; border-radius: var(--radius); font-family: monospace; font-size: 12px; word-break: break-all; margin-top: 12px; display: none; }

    /* Tabs */
    .tab-bar { display: flex; gap: 2px; border-bottom: 1.5px solid var(--border); margin-bottom: 24px; }
    .tab-btn {
      padding: 9px 18px; font-size: 13px; font-weight: 600; cursor: pointer;
      background: none; border: none; border-bottom: 2.5px solid transparent;
      color: var(--text-3); transition: color .15s, border-color .15s;
      margin-bottom: -1.5px; letter-spacing: -.1px;
    }
    .tab-btn:hover { color: var(--text); }
    .tab-btn.active { color: var(--brand); border-bottom-color: var(--brand); }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }

    /* Permissions table */
    .perm-table th:first-child { text-align: left; min-width: 180px; }
    .perm-table th { text-align: center; padding: 8px 6px; }
    .perm-table td { text-align: center; padding: 8px 6px; }
    .perm-table td:first-child { text-align: left; font-weight: 500; color: var(--text-2); padding-left: 16px; cursor: pointer; }
    .perm-table td:first-child:hover { color: var(--brand); }
    .perm-table input[type=checkbox] { width: 17px; height: 17px; cursor: pointer; accent-color: var(--brand); }
    .role-col { border-left: 3px solid var(--border); }
    .role-head-first { border-left: 3px solid var(--border); background: var(--surface-2); }
    .action-head { font-size: 10px !important; color: var(--text-4) !important; font-weight: 500 !important; }
    .perm-table tbody tr:hover td { background: var(--surface-2); }
    .perm-table tbody tr td.role-col { border-left: 3px solid var(--border); }
  </style>
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'admin-configuracoes' }) %>

  <div class="main">
    <%- include('partials/topbar', {
      pageTitle: 'Configurações',
      breadcrumb: [{ label: 'Paytcall', href: '/dashboard' }, { label: 'Configurações' }]
    }) %>

    <div class="page">

      <!-- Feedback de saved -->
      <% if (saved) { %>
      <div style="padding:12px 16px;background:var(--success-bg);border:1px solid var(--success-border);border-radius:var(--radius-md);color:var(--success);font-size:13px;font-weight:600;margin-bottom:18px;display:flex;align-items:center;gap:8px">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        <%= savedMessage || 'Salvo com sucesso!' %>
      </div>
      <% } %>

      <!-- Tab bar -->
      <div class="tab-bar">
        <button class="tab-btn" id="tab-btn-usuarios"   onclick="switchTab('usuarios')">Usuários</button>
        <button class="tab-btn" id="tab-btn-permissoes" onclick="switchTab('permissoes')">Permissões</button>
        <button class="tab-btn" id="tab-btn-sistema"    onclick="switchTab('sistema')">Sistema</button>
      </div>

      <!-- ════════════════════════════════════════ TAB: USUÁRIOS ════ -->
      <div class="tab-pane" id="tab-usuarios">

        <!-- Convidar -->
        <div class="card" style="margin-bottom:18px">
          <div class="card-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
            <h3>Convidar Usuário</h3>
          </div>
          <div class="card-body">
            <form id="invite-form" style="display:flex;gap:12px;flex-wrap:wrap;align-items:end">
              <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" name="email" required placeholder="email@empresa.com" class="form-input" style="width:220px">
              </div>
              <div class="form-group">
                <label class="form-label">Nome</label>
                <input type="text" name="name" required placeholder="Nome completo" class="form-input" style="width:180px">
              </div>
              <div class="form-group">
                <label class="form-label">Papel</label>
                <select name="role" id="invite-role" onchange="toggleCompanies()" class="form-select">
                  <option value="suporte">Suporte</option>
                  <option value="logistica">Logística</option>
                  <option value="retencao">Retenção</option>
                  <option value="usuario">Usuário</option>
                  <option value="terceiros">Terceiros</option>
                  <option value="admin">Admin</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Senha <span style="color:var(--text-4);font-weight:400">(opcional)</span></label>
                <input type="password" name="password" placeholder="Deixe em branco para enviar link" class="form-input" style="width:200px" autocomplete="new-password" id="invite-password">
              </div>
              <div id="companies-group" style="display:none;align-self:center;padding-top:18px">
                <% Object.entries(companies).forEach(([sid, name]) => { %>
                <label style="display:inline-flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;white-space:nowrap;margin-right:12px">
                  <input type="checkbox" name="seller_ids" value="<%= sid %>" style="accent-color:var(--brand);width:13px;height:13px">
                  <%= name %>
                </label>
                <% }) %>
              </div>
              <button type="submit" class="btn btn-primary" id="invite-submit-btn">Criar Usuário</button>
            </form>
            <div class="invite-link" id="invite-result">
              <div id="invite-email-status" style="margin-bottom:6px;font-size:12px;font-weight:600"></div>
              Link: <span id="invite-url"></span>
              <span style="margin-left:8px;cursor:pointer;color:var(--brand);font-weight:600" onclick="copyInvite()">Copiar</span>
            </div>
          </div>
        </div>

        <!-- Tabela de usuários -->
        <div class="card">
          <div class="card-header">
            <h3>Usuários (<%= users.length %>)</h3>
          </div>
          <div class="card-body no-pad">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Nome</th><th>Email</th><th>Papel</th><th>Status</th>
                    <th>Empresas</th><th>Criado em</th><th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach(u => { %>
                  <tr>
                    <td class="fw-600"><%= u.name %></td>
                    <td class="text-muted"><%= u.email %></td>
                    <td>
                      <div style="display:flex;align-items:center;gap:6px">
                        <select id="role-sel-<%= u.id %>" class="form-select" style="padding:3px 6px;font-size:12px;width:auto">
                          <option value="admin"     <%= u.role==='admin'     ?'selected':'' %>>Admin</option>
                          <option value="suporte"   <%= u.role==='suporte'   ?'selected':'' %>>Suporte</option>
                          <option value="logistica" <%= u.role==='logistica' ?'selected':'' %>>Logística</option>
                          <option value="retencao"  <%= u.role==='retencao'  ?'selected':'' %>>Retenção</option>
                          <option value="usuario"   <%= u.role==='usuario'   ?'selected':'' %>>Usuário</option>
                          <option value="terceiros" <%= u.role==='terceiros' ?'selected':'' %>>Terceiros</option>
                        </select>
                        <button class="btn btn-sm btn-primary" onclick="changeRole('<%= u.id %>', this)">Salvar</button>
                      </div>
                    </td>
                    <td>
                      <% if (!u.auth_id) { %>
                        <span class="badge badge-pending">Pendente</span>
                      <% } else if (u.active) { %>
                        <span class="badge badge-active">Ativo</span>
                      <% } else { %>
                        <span class="badge badge-inactive">Inativo</span>
                      <% } %>
                    </td>
                    <td class="text-sm">
                      <% if (u.role === 'terceiros') { %>
                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                          <% if (accessMap[u.id]?.length) { %>
                            <% accessMap[u.id].forEach(sid => { %>
                              <span class="badge" style="background:var(--brand-dim);color:var(--brand-dark);font-size:11px"><%= companies[sid] || sid %></span>
                            <% }) %>
                          <% } else { %>
                            <span class="text-muted">Nenhuma</span>
                          <% } %>
                          <button class="btn btn-sm btn-ghost" style="padding:2px 6px;font-size:11px" onclick="editCompanies('<%= u.id %>', '<%= u.name %>', <%- JSON.stringify(accessMap[u.id] || []) %>)">Editar</button>
                        </div>
                      <% } else { %>
                        <span class="text-muted">Todas</span>
                      <% } %>
                    </td>
                    <td class="text-muted text-sm">
                      <%= u.created_at ? new Date(u.created_at).toLocaleDateString('pt-BR') : '—' %>
                    </td>
                    <td style="white-space:nowrap">
                      <% if (u.auth_id) { %>
                        <button class="btn btn-sm btn-secondary" onclick="toggleUser('<%= u.id %>', this)" style="margin-right:4px">
                          <%= u.active ? 'Desativar' : 'Ativar' %>
                        </button>
                        <button class="btn btn-sm btn-ghost" onclick="openPasswordModal('<%= u.id %>', '<%= u.name %>')" title="Alterar senha">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </button>
                        <button class="btn btn-sm btn-ghost" onclick="deleteInvite('<%= u.id %>', '<%= u.name %>', true)" title="Remover acesso" style="color:var(--danger);margin-left:4px">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                        </button>
                      <% } else { %>
                        <button class="btn btn-sm btn-ghost" onclick="resendInvite('<%= u.id %>', this)" title="Reenviar convite" style="margin-right:4px">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        </button>
                        <button class="btn btn-sm btn-ghost" onclick="deleteInvite('<%= u.id %>', '<%= u.name %>')" title="Excluir convite" style="color:var(--danger)">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                        </button>
                      <% } %>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

      </div><!-- /tab-usuarios -->

      <!-- ══════════════════════════════════════ TAB: PERMISSÕES ════ -->
      <div class="tab-pane" id="tab-permissoes">

        <div style="display:flex;gap:20px;margin-bottom:16px;font-size:12px;color:var(--text-3)">
          <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--info-bg);display:inline-block"></span> Ver</span>
          <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--success-bg);display:inline-block"></span> Criar</span>
          <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--warning-bg);display:inline-block"></span> Editar</span>
          <span style="display:flex;align-items:center;gap:4px"><span style="width:12px;height:12px;border-radius:3px;background:var(--danger-bg);display:inline-block"></span> Excluir</span>
          <span style="margin-left:auto;color:var(--text-4);font-size:11px">Clique no nome do módulo para selecionar/deselecionar toda a linha</span>
        </div>

        <form method="POST" action="/admin/permissions">
          <div class="card">
            <div class="card-header">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              <h3>Matriz de Permissões</h3>
              <span class="text-muted" style="margin-left:auto;font-size:12px">Defina o que cada papel pode fazer em cada módulo</span>
            </div>
            <div class="card-body no-pad">
              <div class="table-wrap">
                <table class="perm-table">
                  <thead>
                    <tr>
                      <th>Módulo</th>
                      <% ROLES.forEach(role => { %>
                      <th colspan="4" class="role-col" style="color:var(--text);font-size:12px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;background:var(--surface-2)"><%= ROLE_LABELS[role] %></th>
                      <% }) %>
                    </tr>
                    <tr>
                      <th></th>
                      <% ROLES.forEach(() => { %>
                      <th class="role-col action-head">Ver</th>
                      <th class="action-head">Criar</th>
                      <th class="action-head">Editar</th>
                      <th class="action-head">Excluir</th>
                      <% }) %>
                    </tr>
                  </thead>
                  <tbody>
                    <% MODULES.forEach(mod => { %>
                    <tr>
                      <td title="Clique para selecionar tudo"><%= mod.label %></td>
                      <% ROLES.forEach(role => {
                        const p = (permissions[role] && permissions[role][mod.key]) || {};
                      %>
                      <td class="role-col"><input type="checkbox" name="<%= role %>|<%= mod.key %>|can_view"   <%= p.can_view   ? 'checked' : '' %>></td>
                      <td>                 <input type="checkbox" name="<%= role %>|<%= mod.key %>|can_create" <%= p.can_create ? 'checked' : '' %>></td>
                      <td>                 <input type="checkbox" name="<%= role %>|<%= mod.key %>|can_edit"   <%= p.can_edit   ? 'checked' : '' %>></td>
                      <td>                 <input type="checkbox" name="<%= role %>|<%= mod.key %>|can_delete" <%= p.can_delete ? 'checked' : '' %>></td>
                      <% }) %>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="card-footer" style="display:flex;align-items:center;gap:12px">
              <button type="submit" class="btn btn-primary">Salvar Permissões</button>
              <span style="margin-left:auto;font-size:12px;color:var(--text-4)">Alterações entram em vigor imediatamente</span>
            </div>
          </div>
        </form>

      </div><!-- /tab-permissoes -->

      <!-- ════════════════════════════════════════ TAB: SISTEMA ════ -->
      <div class="tab-pane" id="tab-sistema">

        <!-- Gemini / Lina IA -->
        <div class="card" style="margin-bottom:18px">
          <div class="card-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            <h3>Lina IA — Gemini 2.5 Flash</h3>
            <span class="badge badge-brand" style="margin-left:auto">API</span>
          </div>
          <div class="card-body">
            <%
            const geminiSetting   = (settings || []).find(s => s.key === 'gemini_api_key');
            const geminiKey       = geminiSetting ? geminiSetting.value : '';
            const geminiUpdated   = geminiSetting ? geminiSetting.updated_at : null;
            const geminiUpdatedBy = geminiSetting ? geminiSetting.updated_by : null;
            const keyMasked = geminiKey ? geminiKey.substring(0,8) + '•'.repeat(Math.max(0, geminiKey.length-12)) + geminiKey.slice(-4) : '';
            %>
            <p style="font-size:13px;color:var(--text-3);margin-bottom:16px">
              Chave da API do Google Gemini usada pelo agente <strong>Lina</strong>. Obtenha sua chave em
              <a href="https://aistudio.google.com/app/apikey" target="_blank" style="color:var(--brand)">Google AI Studio</a>.
            </p>
            <% if (geminiKey) { %>
            <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--radius-md);margin-bottom:14px">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              <div style="flex:1;min-width:0">
                <div style="font-size:12px;color:var(--text-3)">Chave atual</div>
                <code style="font-family:monospace;font-size:12.5px;color:var(--text-2)"><%= keyMasked %></code>
              </div>
              <% if (geminiUpdated) { %>
              <div style="font-size:11px;color:var(--text-4);text-align:right">
                Atualizado <%= new Date(geminiUpdated).toLocaleDateString('pt-BR') %>
                <% if (geminiUpdatedBy) { %><br>por <%= geminiUpdatedBy %><% } %>
              </div>
              <% } %>
            </div>
            <% } %>
            <form method="POST" action="/admin/settings" style="display:flex;flex-direction:column;gap:12px">
              <input type="hidden" name="key" value="gemini_api_key">
              <div class="form-group">
                <label class="form-label">Nova chave API</label>
                <input type="password" name="value" class="form-input" placeholder="AIzaSy..." autocomplete="new-password" style="font-family:monospace">
                <div style="font-size:11.5px;color:var(--text-4);margin-top:4px">A chave fica ativa imediatamente após salvar.</div>
              </div>
              <div><button type="submit" class="btn btn-primary btn-sm">Salvar chave</button></div>
            </form>
          </div>
        </div>

        <!-- Mural de Avisos -->
        <div class="card">
          <div class="card-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16h6M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <h3>Mural de Avisos</h3>
            <a href="/admin/mural" class="btn btn-ghost btn-sm" style="margin-left:auto">Gerenciar →</a>
          </div>
          <div class="card-body">
            <p style="font-size:13px;color:var(--text-3)">Configure os avisos exibidos para a equipe no portal. <a href="/admin/mural" style="color:var(--brand)">Ir para o Mural de Avisos</a>.</p>
          </div>
        </div>

      </div><!-- /tab-sistema -->

    </div>
  </div>
</div>

<!-- Modal: Alterar senha -->
<div id="modal-password" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center">
  <div class="card" style="width:380px;max-width:94vw;padding:0;box-shadow:var(--shadow-lg)">
    <div class="card-header" style="padding:16px 20px">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <h3 id="modal-pass-title" style="font-size:14px">Alterar senha</h3>
      <button onclick="closePasswordModal()" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--text-3);font-size:18px;line-height:1">×</button>
    </div>
    <div class="card-body" style="padding:16px 20px;display:flex;flex-direction:column;gap:12px">
      <p style="font-size:12px;color:var(--text-4);margin:0">As senhas são criptografadas e não podem ser visualizadas. Defina uma nova senha para este usuário.</p>
      <div class="form-group">
        <label class="form-label">Nova senha</label>
        <input id="modal-pass-input" type="password" class="form-input" placeholder="Mínimo 6 caracteres" autocomplete="new-password">
      </div>
      <div class="form-group">
        <label class="form-label">Confirmar senha</label>
        <input id="modal-pass-confirm" type="password" class="form-input" placeholder="Repita a senha" autocomplete="new-password">
      </div>
      <p id="modal-pass-error" style="font-size:12px;color:var(--danger);margin:0"></p>
    </div>
    <div class="card-footer" style="display:flex;justify-content:flex-end;gap:8px">
      <button onclick="closePasswordModal()" class="btn btn-secondary">Cancelar</button>
      <button id="modal-pass-save" onclick="savePassword()" class="btn btn-primary">Salvar</button>
    </div>
  </div>
</div>

<!-- Modal: Editar empresas -->
<div id="modal-companies" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center">
  <div class="card" style="width:420px;max-width:94vw;padding:0;box-shadow:var(--shadow-lg)">
    <div class="card-header" style="padding:16px 20px">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <h3 id="modal-companies-title" style="font-size:14px">Empresas</h3>
      <button onclick="closeCompaniesModal()" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--text-3);font-size:18px;line-height:1">×</button>
    </div>
    <div class="card-body" style="padding:16px 20px">
      <p style="font-size:12px;color:var(--text-4);margin-bottom:12px">Selecione as empresas que este usuário poderá visualizar</p>
      <div id="modal-companies-list"></div>
    </div>
    <div class="card-footer" style="display:flex;justify-content:flex-end;gap:8px">
      <button onclick="closeCompaniesModal()" class="btn btn-secondary">Cancelar</button>
      <button onclick="saveCompanies()" class="btn btn-primary">Salvar</button>
    </div>
  </div>
</div>

<script>
// ── Tabs ──────────────────────────────────────────────────────────────────
const VALID_TABS = ['usuarios','permissoes','sistema'];
function switchTab(tab) {
  VALID_TABS.forEach(t => {
    document.getElementById('tab-' + t).classList.toggle('active', t === tab);
    document.getElementById('tab-btn-' + t).classList.toggle('active', t === tab);
  });
  const url = new URL(window.location);
  url.searchParams.set('tab', tab);
  history.replaceState(null, '', url);
}
// Inicializa pela URL
const _initTab = new URLSearchParams(window.location.search).get('tab') || 'usuarios';
switchTab(VALID_TABS.includes(_initTab) ? _initTab : 'usuarios');

// ── Usuários ──────────────────────────────────────────────────────────────
function toggleCompanies() {
  const show = document.getElementById('invite-role').value === 'terceiros';
  document.getElementById('companies-group').style.display = show ? '' : 'none';
  if (!show) document.querySelectorAll('#companies-group input[type=checkbox]').forEach(c => c.checked = false);
}

document.getElementById('invite-password').addEventListener('input', function() {
  document.getElementById('invite-submit-btn').textContent = this.value.length > 0 ? 'Criar com Senha' : 'Criar Usuário';
});

document.getElementById('invite-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = new FormData(e.target);
  const body = {
    email: form.get('email'), name: form.get('name'),
    role: form.get('role'), seller_ids: form.getAll('seller_ids'),
    password: form.get('password') || '',
  };
  const res = await fetch('/admin/users/invite', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  const data = await res.json();
  if (data.ok) {
    if (data.immediate) {
      showToast('Usuário criado com sucesso! Já pode fazer login.');
    } else {
      document.getElementById('invite-url').textContent = data.inviteLink;
      const result = document.getElementById('invite-result');
      result.style.display = 'block';
      result.style.background = data.emailSent ? 'var(--success-bg)' : 'var(--warning-bg)';
      result.style.borderColor = data.emailSent ? '#bbf7d0' : '#fde68a';
      document.getElementById('invite-email-status').textContent = data.emailSent
        ? '✓ Email enviado para o usuário'
        : '⚠ Email não configurado — compartilhe o link manualmente';
    }
    e.target.reset();
    toggleCompanies();
    location.reload();
  } else { showToast(data.error || 'Erro ao criar usuário', 'error'); }
});

function copyInvite() { navigator.clipboard.writeText(document.getElementById('invite-url').textContent).then(() => showToast('Link copiado!')); }
async function changeRole(id, btn) {
  const sel = document.getElementById('role-sel-' + id);
  const role = sel.value;
  btn.disabled = true; btn.textContent = '...';
  try {
    const res = await fetch('/admin/users/' + id + '/role', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ role }) });
    const data = await res.json();
    if (data.ok) { btn.textContent = '✓'; setTimeout(() => { btn.textContent = 'Salvar'; btn.disabled = false; }, 1500); return; }
    else { showToast(data.error || 'Erro ao alterar papel', 'error'); }
  } catch (e) { showToast('Erro de conexão', 'error'); }
  btn.disabled = false; btn.textContent = 'Salvar';
}
async function toggleUser(id, btn) { const res = await fetch('/admin/users/' + id + '/toggle', { method: 'POST' }); const data = await res.json(); if (data.ok) location.reload(); }

const ALL_COMPANIES = <%- JSON.stringify(companies) %>;
let _editingUserId = null;

function editCompanies(userId, userName, currentIds) {
  _editingUserId = userId;
  document.getElementById('modal-companies-title').textContent = 'Empresas de ' + userName;
  const container = document.getElementById('modal-companies-list');
  container.innerHTML = '';
  Object.entries(ALL_COMPANIES).forEach(([sid, name]) => {
    const checked = currentIds.includes(sid);
    container.innerHTML += `<label style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);cursor:pointer">
      <input type="checkbox" value="${sid}" ${checked ? 'checked' : ''} style="width:16px;height:16px;accent-color:var(--brand)">
      <span style="font-size:13px;font-weight:500">${name}</span>
      <span style="font-size:11px;color:var(--text-4);margin-left:auto">${sid}</span>
    </label>`;
  });
  document.getElementById('modal-companies').style.display = 'flex';
}
function closeCompaniesModal() { document.getElementById('modal-companies').style.display = 'none'; _editingUserId = null; }
async function saveCompanies() {
  const checks = document.querySelectorAll('#modal-companies-list input[type=checkbox]:checked');
  const seller_ids = Array.from(checks).map(c => c.value);
  const res = await fetch('/admin/users/' + _editingUserId + '/companies', {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ seller_ids }),
  });
  const data = await res.json();
  if (data.ok) { closeCompaniesModal(); location.reload(); }
  else showToast(data.error || 'Erro ao salvar empresas', 'error');
}

async function deleteInvite(id, name, isActive) {
  const msg = isActive
    ? `Remover acesso de "${name}"? O usuário será deletado e poderá ser convidado novamente.`
    : `Excluir convite de "${name}"?`;
  showConfirm(msg, async () => {
    const res = await fetch('/admin/users/' + id, { method: 'DELETE' });
    const data = await res.json();
    if (data.ok) location.reload();
    else showToast(data.error || 'Erro ao remover usuário', 'error');
  }, { okLabel: 'Confirmar', okClass: 'btn-danger' });
}

async function resendInvite(id, btn) {
  btn.disabled = true; btn.style.opacity = '0.5';
  const res = await fetch('/admin/users/' + id + '/resend-invite', { method: 'POST' });
  const data = await res.json();
  btn.disabled = false; btn.style.opacity = '';
  if (data.ok) {
    showToast(data.emailSent ? 'Email reenviado com sucesso!' : 'Email não configurado — compartilhe o link manualmente.');
  } else showToast(data.error || 'Erro ao reenviar convite', 'error');
}

function openPasswordModal(id, name) {
  document.getElementById('modal-pass-title').textContent = 'Alterar senha de ' + name;
  document.getElementById('modal-pass-input').value = '';
  document.getElementById('modal-pass-confirm').value = '';
  document.getElementById('modal-pass-error').textContent = '';
  document.getElementById('modal-password').style.display = 'flex';
  document.getElementById('modal-password').dataset.userId = id;
}
function closePasswordModal() { document.getElementById('modal-password').style.display = 'none'; }
async function savePassword() {
  const id   = document.getElementById('modal-password').dataset.userId;
  const pass = document.getElementById('modal-pass-input').value;
  const conf = document.getElementById('modal-pass-confirm').value;
  const errEl = document.getElementById('modal-pass-error');
  if (pass.length < 6) { errEl.textContent = 'Mínimo 6 caracteres'; return; }
  if (pass !== conf)   { errEl.textContent = 'As senhas não coincidem'; return; }
  const btn = document.getElementById('modal-pass-save');
  btn.disabled = true; btn.textContent = 'Salvando...';
  const res = await fetch('/admin/users/' + id + '/password', {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ password: pass }),
  });
  const data = await res.json();
  btn.disabled = false; btn.textContent = 'Salvar';
  if (data.ok) { closePasswordModal(); showToast('Senha alterada com sucesso!'); }
  else errEl.textContent = data.error || 'Erro ao alterar senha';
}

// ── Permissões — toggle row ───────────────────────────────────────────────
document.querySelectorAll('.perm-table td:first-child').forEach(td => {
  td.addEventListener('click', () => {
    const checks = td.parentElement.querySelectorAll('input[type=checkbox]');
    const allChecked = [...checks].every(c => c.checked);
    checks.forEach(c => c.checked = !allChecked);
  });
});

// ── Notificações ──────────────────────────────────────────────────────────
const NOTIF_USER = '<%= typeof currentUser !== "undefined" ? currentUser.name : "" %>';
function toggleNotifs() { const dd=document.getElementById('notifDropdown'); dd.classList.toggle('open'); if(dd.classList.contains('open')) loadNotifs(); }
async function loadNotifs() { try { const r=await fetch('/api/notifications'); const {notifications,unread}=await r.json(); const b=document.getElementById('notifBadge'); b.style.display=unread>0?'block':'none'; b.textContent=unread; const list=document.getElementById('notifList'); if(!notifications.length){list.innerHTML='<div style="text-align:center;color:var(--text-4);padding:24px;font-size:13px">Nenhuma notificação</div>';return;} list.innerHTML=notifications.map(n=>`<a href="/pedido/${n.order_id||n.tracking_code||''}" class="notif-item${n.is_read?'':' unread'}"><div style="font-size:13px;color:var(--text-2)">${n.message}</div></a>`).join(''); } catch(e){} }
async function markAllRead() { await fetch('/api/notifications/read',{method:'POST'}); loadNotifs(); }
document.addEventListener('click',(e)=>{ const dd=document.getElementById('notifDropdown'); const btn=document.getElementById('notifBtn'); if(dd&&btn&&!dd.contains(e.target)&&!btn.contains(e.target))dd.classList.remove('open'); });
</script>
<%- include('partials/ai-chat') %>
</body>
</html>
