<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Catálogo — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-catalogo' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: 'Catálogo', breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Catálogo' }
    ] }) %>

    <div class="page">

      <div class="p-page-header">
        <div class="p-page-header-left">
          <h1>Catálogo</h1>
          <p class="p-subtitle">Empresas, produtos e nichos</p>
        </div>
        <% if (canEdit) { %>
        <div class="p-page-header-right">
          <button class="btn btn-secondary btn-sm" onclick="openModal('modal-nova-empresa')">+ Nova Empresa</button>
          <button class="btn btn-secondary btn-sm" onclick="novoNicho()">+ Novo Nicho</button>
          <button class="btn btn-primary btn-sm" onclick="openModal('modal-novo-produto')">+ Novo Produto</button>
        </div>
        <% } %>
      </div>

      <!-- Tabs -->
      <div style="display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:24px">
        <button class="catalog-tab" data-tab="empresas" style="padding:10px 22px;font-size:13px;font-weight:600;background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .15s,border-color .15s">
          Empresas (<%= empresas.length %>)
        </button>
        <button class="catalog-tab" data-tab="produtos" style="padding:10px 22px;font-size:13px;font-weight:600;background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .15s,border-color .15s">
          Produtos (<%= produtos.length %>)
        </button>
        <button class="catalog-tab" data-tab="nichos" style="padding:10px 22px;font-size:13px;font-weight:600;background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .15s,border-color .15s">
          Nichos (<%= nichos.length %>)
        </button>
      </div>

      <!-- ── ABA EMPRESAS ── -->
      <div id="tab-empresas" class="tab-pane">
        <div class="toolbar" style="margin-bottom:16px">
          <input type="text" id="emp-search" class="form-input" placeholder="Buscar empresa..." style="max-width:260px" oninput="filterEmpresas()">
          <select id="emp-segmento" class="form-select" style="max-width:200px" onchange="filterEmpresas()">
            <option value="">Todos os segmentos</option>
            <% segmentos.forEach(s => { %>
            <option value="<%= s %>"><%= s %></option>
            <% }) %>
          </select>
          <select id="emp-status" class="form-select" style="max-width:160px" onchange="filterEmpresas()">
            <option value="">Todos os status</option>
            <option value="Ativo">Ativo</option>
            <option value="Inativo">Inativo</option>
          </select>
        </div>

        <div class="card" style="padding:0">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Empresa</th>
                  <th>Segmento</th>
                  <th>Contato</th>
                  <th>Cidade</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="emp-tbody">
                <% empresas.forEach(e => { %>
                <tr class="emp-row" data-nome="<%= (e.nome||'').toLowerCase() %>" data-segmento="<%= e.segmento||'' %>" data-status="<%= e.status||'' %>" style="cursor:pointer" onclick="location.href='/gestao/empresas/<%= e.id %>'">
                  <td>
                    <div style="font-weight:600;font-size:13px"><%= e.nome %></div>
                    <% if (e.descricao) { %>
                    <div style="font-size:11px;color:var(--text-4);margin-top:2px;max-width:280px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= e.descricao %></div>
                    <% } %>
                  </td>
                  <td>
                    <% if (e.segmento) { %>
                      <span style="display:inline-block;font-size:11px;font-weight:600;color:var(--brand);background:rgba(255,140,0,.1);border-radius:20px;padding:2px 10px;white-space:nowrap"><%= e.segmento %></span>
                    <% } else { %>
                      <span style="color:var(--text-4);font-size:12px">—</span>
                    <% } %>
                  </td>
                  <td style="font-size:13px">
                    <% if (e.contato) { %><div style="color:var(--text-2)"><%= e.contato %></div><% } %>
                    <% if (e.email) { %><div style="color:var(--text-4);font-size:12px"><%= e.email %></div><% } %>
                  </td>
                  <td style="color:var(--text-3);font-size:13px"><%= [e.cidade, e.estado].filter(Boolean).join('/') || '—' %></td>
                  <td>
                    <% if (e.status === 'Ativo' || e.status === 'ativo') { %>
                      <span class="badge badge-success">Ativo</span>
                    <% } else if (e.status) { %>
                      <span class="badge badge-neutral"><%= e.status %></span>
                    <% } else { %>
                      <span style="color:var(--text-4);font-size:12px">—</span>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
                <% if (empresas.length === 0) { %>
                <tr><td colspan="5" style="text-align:center;padding:32px;color:var(--text-3)">Nenhuma empresa cadastrada</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div id="emp-empty" style="display:none;text-align:center;padding:32px;color:var(--text-3);font-size:13px">Nenhuma empresa encontrada</div>
      </div>

      <!-- ── ABA PRODUTOS ── -->
      <div id="tab-produtos" class="tab-pane" style="display:none">
        <div class="toolbar" style="margin-bottom:16px">
          <input type="text" id="prod-search" class="form-input" placeholder="Buscar produto..." style="max-width:260px" oninput="filterProdutos()">
          <select id="prod-nicho" class="form-select" style="max-width:200px" onchange="filterProdutos()">
            <option value="">Todos os nichos</option>
            <% nichos.forEach(n => { %>
            <option value="<%= n.nicho %>"><%= n.nicho %></option>
            <% }) %>
          </select>
        </div>

        <% Object.keys(porNicho).sort().forEach(nicho => { %>
        <div class="nicho-group" data-nicho="<%= nicho.toLowerCase() %>">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--text-4);margin:0 0 10px;padding-left:2px"><%= nicho %></div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;margin-bottom:24px">
            <% porNicho[nicho].forEach(p => { %>
            <% const _temMidia = p.playbook_slug && slugsComMidia.includes(p.playbook_slug); %>
            <a href="/gestao/produtos/<%= p.id %>" class="prod-card" data-nome="<%= (p.nome||'').toLowerCase() %>" data-nicho="<%= (p.nicho||'').toLowerCase() %>" style="display:block;text-decoration:none">
              <div class="card" style="padding:16px;height:100%;box-sizing:border-box;transition:box-shadow .15s,transform .1s">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
                  <div style="font-weight:700;font-size:14px;color:var(--text);line-height:1.3"><%= p.nome %></div>
                  <div style="display:flex;align-items:center;gap:4px;flex-shrink:0;margin-left:8px">
                    <% if (_temMidia) { %><span title="Tem mídias no Storage" style="font-size:11px;color:var(--success);background:rgba(34,197,94,.1);border-radius:4px;padding:2px 6px;font-weight:600">📷</span><% } %>
                    <% if (p.sku) { %><span style="font-size:10px;color:var(--text-4);background:var(--bg-2);border:1px solid var(--border);border-radius:4px;padding:2px 6px;white-space:nowrap">SKU <%= p.sku %></span><% } %>
                  </div>
                </div>
                <% if (p.o_que_e) { %>
                <div style="font-size:12px;color:var(--text-3);line-height:1.5;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden"><%= p.o_que_e %></div>
                <% } %>
                <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:auto">
                  <% if (p.nicho) { %><span style="font-size:11px;color:var(--brand);background:var(--brand-bg,rgba(255,140,0,.08));border-radius:4px;padding:2px 7px"><%= p.nicho %></span><% } %>
                  <% if (p.composicao) { %><span style="font-size:11px;color:var(--text-4);background:var(--bg-2);border:1px solid var(--border);border-radius:4px;padding:2px 7px">Composição</span><% } %>
                  <% if (p.como_funciona) { %><span style="font-size:11px;color:var(--text-4);background:var(--bg-2);border:1px solid var(--border);border-radius:4px;padding:2px 7px">Como funciona</span><% } %>
                  <% if (p.playbook_slug) { %><span style="font-size:11px;color:var(--success);background:rgba(34,197,94,.08);border-radius:4px;padding:2px 7px">Playbook</span><% } %>
                  <% if (!_temMidia && p.playbook_slug) { %><span title="Sem mídias cadastradas" style="font-size:11px;color:var(--text-4);background:var(--bg-2);border:1px dashed var(--border);border-radius:4px;padding:2px 7px">Sem mídia</span><% } %>
                </div>
              </div>
            </a>
            <% }) %>
          </div>
        </div>
        <% }) %>

        <% if (produtos.length === 0) { %>
        <div style="text-align:center;padding:48px;color:var(--text-3);font-size:13px">Nenhum produto cadastrado</div>
        <% } %>
        <div id="prod-empty" style="display:none;text-align:center;padding:32px;color:var(--text-3);font-size:13px">Nenhum produto encontrado</div>
      </div>

      <!-- ── ABA NICHOS ── -->
      <div id="tab-nichos" class="tab-pane" style="display:none">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px">
          <% nichos.forEach(n => { %>
          <div class="card" style="padding:20px;text-align:center;cursor:pointer;transition:box-shadow .15s" onclick="switchTab('produtos');document.getElementById('prod-nicho').value='<%= n.nicho %>';filterProdutos()">
            <div style="font-size:32px;font-weight:800;color:var(--brand);margin-bottom:6px"><%= n.total %></div>
            <div style="font-size:14px;font-weight:600;color:var(--text)"><%= n.nicho %></div>
            <div style="font-size:11px;color:var(--text-4);margin-top:4px">produto<%= n.total !== 1 ? 's' : '' %> · clique para ver</div>
          </div>
          <% }) %>
          <% if (nichos.length === 0) { %>
          <div style="text-align:center;padding:48px;color:var(--text-3);font-size:13px;grid-column:1/-1">Nenhum nicho cadastrado</div>
          <% } %>
        </div>
      </div>

    </div><!-- /.page -->
  </div><!-- /.main -->

  <%- include('partials/ai-chat') %>
</div>

<!-- ── MODAL: Nova Empresa ── -->
<% if (canEdit) { %>
<div id="modal-nova-empresa" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;overflow-y:auto;padding:40px 20px">
  <div class="card" style="max-width:560px;margin:0 auto">
    <div class="card-header" style="justify-content:space-between">
      <span style="font-weight:700;font-size:15px">Nova Empresa</span>
      <button onclick="closeModal('modal-nova-empresa')" style="background:none;border:none;cursor:pointer;color:var(--text-3);font-size:20px;line-height:1">&times;</button>
    </div>
    <form method="POST" action="/gestao/empresas">
      <div style="padding:20px;display:flex;flex-direction:column;gap:14px">
        <div class="form-group">
          <label class="form-label">Nome *</label>
          <input name="nome" class="form-input" required>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">Segmento</label>
            <input name="segmento" class="form-input" list="seg-list-new">
            <datalist id="seg-list-new"><% segmentos.forEach(s => { %><option value="<%= s %>"><% }) %></datalist>
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
              <option value="">—</option>
              <option value="Ativo">Ativo</option>
              <option value="Inativo">Inativo</option>
            </select>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">CNPJ</label>
            <input name="cnpj" class="form-input">
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-input">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">Telefone</label>
            <input name="telefone" class="form-input">
          </div>
          <div class="form-group">
            <label class="form-label">Contato</label>
            <input name="contato" class="form-input">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 80px;gap:12px">
          <div class="form-group">
            <label class="form-label">Cidade</label>
            <input name="cidade" class="form-input">
          </div>
          <div class="form-group">
            <label class="form-label">UF</label>
            <input name="estado" class="form-input" maxlength="2" placeholder="SP">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Site</label>
          <input name="site" class="form-input" placeholder="https://">
        </div>
        <div class="form-group">
          <label class="form-label">Descrição</label>
          <textarea name="descricao" class="form-input" rows="3" style="resize:vertical"></textarea>
        </div>
      </div>
      <div class="card-footer" style="justify-content:flex-end;gap:8px">
        <button type="button" onclick="closeModal('modal-nova-empresa')" class="btn btn-secondary">Cancelar</button>
        <button type="submit" class="btn btn-primary">Criar Empresa</button>
      </div>
    </form>
  </div>
</div>

<!-- ── MODAL: Novo Nicho ── -->
<div id="modal-novo-nicho" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1001;overflow-y:auto;padding:40px 20px">
  <div class="card" style="max-width:420px;margin:0 auto">
    <div class="card-header" style="justify-content:space-between">
      <span style="font-weight:700;font-size:15px">Novo Nicho</span>
      <button onclick="closeModal('modal-novo-nicho')" style="background:none;border:none;cursor:pointer;color:var(--text-3);font-size:20px;line-height:1">&times;</button>
    </div>
    <div style="padding:20px;display:flex;flex-direction:column;gap:14px">
      <div class="form-group">
        <label class="form-label">Nome do nicho *</label>
        <input id="novo-nicho-input" class="form-input" placeholder="Ex: Emagrecimento, Cabelo, Sono...">
      </div>
      <p style="font-size:12px;color:var(--text-4);margin:0">O nicho será criado ao cadastrar o primeiro produto com este nome.</p>
    </div>
    <div class="card-footer" style="justify-content:flex-end;gap:8px">
      <button type="button" onclick="closeModal('modal-novo-nicho')" class="btn btn-secondary">Cancelar</button>
      <button type="button" onclick="confirmarNovoNicho()" class="btn btn-primary">Continuar</button>
    </div>
  </div>
</div>

<!-- ── MODAL: Novo Produto ── -->
<div id="modal-novo-produto" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;overflow-y:auto;padding:40px 20px">
  <div class="card" style="max-width:560px;margin:0 auto">
    <div class="card-header" style="justify-content:space-between">
      <span style="font-weight:700;font-size:15px">Novo Produto</span>
      <button onclick="closeModal('modal-novo-produto')" style="background:none;border:none;cursor:pointer;color:var(--text-3);font-size:20px;line-height:1">&times;</button>
    </div>
    <form method="POST" action="/gestao/produtos">
      <div style="padding:20px;display:flex;flex-direction:column;gap:14px">
        <div class="form-group">
          <label class="form-label">Nome *</label>
          <input name="nome" class="form-input" required>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">Nicho <span style="color:var(--text-4);font-weight:400">(existente ou novo)</span></label>
            <input name="nicho" class="form-input" list="nicho-list-new" placeholder="Digite ou selecione...">
            <datalist id="nicho-list-new"><% nichosUnicos.forEach(n => { %><option value="<%= n %>"><% }) %></datalist>
          </div>
          <div class="form-group">
            <label class="form-label">SKU</label>
            <input name="sku" class="form-input">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">O que é?</label>
          <textarea name="o_que_e" class="form-input" rows="3" style="resize:vertical"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Como funciona?</label>
          <textarea name="como_funciona" class="form-input" rows="3" style="resize:vertical"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Composição</label>
          <textarea name="composicao" class="form-input" rows="2" style="resize:vertical"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Descrição</label>
          <textarea name="descricao" class="form-input" rows="2" style="resize:vertical"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Playbook Slug <span style="color:var(--text-4);font-weight:400">(para mídias)</span></label>
          <input name="playbook_slug" class="form-input" placeholder="nome-do-produto">
        </div>
      </div>
      <div class="card-footer" style="justify-content:flex-end;gap:8px">
        <button type="button" onclick="closeModal('modal-novo-produto')" class="btn btn-secondary">Cancelar</button>
        <button type="submit" class="btn btn-primary">Criar Produto</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<script>
function openModal(id) { document.getElementById(id).style.display = ''; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }
document.querySelectorAll('[id^="modal-"]').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) closeModal(m.id); });
});

function switchTab(name) {
  document.querySelectorAll('.tab-pane').forEach(p => p.style.display = 'none');
  document.querySelectorAll('.catalog-tab').forEach(b => {
    Object.assign(b.style, { color: 'var(--text-3)', borderBottomColor: 'transparent' });
  });
  document.getElementById('tab-' + name).style.display = '';
  const btn = document.querySelector(`.catalog-tab[data-tab="${name}"]`);
  if (btn) Object.assign(btn.style, { color: 'var(--text)', borderBottomColor: 'var(--brand)' });
  localStorage.setItem('catalog-tab', name);
}

document.querySelectorAll('.catalog-tab').forEach(b => {
  b.addEventListener('click', () => switchTab(b.dataset.tab));
});

function filterEmpresas() {
  const search = document.getElementById('emp-search').value.toLowerCase();
  const seg    = document.getElementById('emp-segmento').value;
  const status = document.getElementById('emp-status').value;
  let visible  = 0;
  document.querySelectorAll('.emp-row').forEach(row => {
    const ok = (!search || row.dataset.nome.includes(search))
            && (!seg    || row.dataset.segmento === seg)
            && (!status || row.dataset.status === status);
    row.style.display = ok ? '' : 'none';
    if (ok) visible++;
  });
  document.getElementById('emp-empty').style.display = visible === 0 ? '' : 'none';
  document.querySelector('.card:has(#emp-tbody)').style.display = visible === 0 ? 'none' : '';
}

function filterProdutos() {
  const search = document.getElementById('prod-search').value.toLowerCase();
  const nicho  = document.getElementById('prod-nicho').value.toLowerCase();
  let visible  = 0;
  document.querySelectorAll('.prod-card').forEach(card => {
    const ok = (!search || card.dataset.nome.includes(search))
            && (!nicho  || card.dataset.nicho === nicho);
    card.style.display = ok ? '' : 'none';
    if (ok) visible++;
  });
  document.querySelectorAll('.nicho-group').forEach(g => {
    const visCards = [...g.querySelectorAll('.prod-card')].filter(c => c.style.display !== 'none').length;
    g.style.display = visCards === 0 ? 'none' : '';
  });
  document.getElementById('prod-empty').style.display = visible === 0 ? '' : 'none';
}

function novoNicho() {
  document.getElementById('novo-nicho-input').value = '';
  openModal('modal-novo-nicho');
  setTimeout(() => document.getElementById('novo-nicho-input').focus(), 50);
}
function confirmarNovoNicho() {
  const nome = document.getElementById('novo-nicho-input').value.trim();
  if (!nome) return;
  closeModal('modal-novo-nicho');
  switchTab('produtos');
  openModal('modal-novo-produto');
  const nichoInput = document.querySelector('#modal-novo-produto input[name="nicho"]');
  if (nichoInput) { nichoInput.value = nome; nichoInput.focus(); }
}
document.getElementById('novo-nicho-input')?.addEventListener('keydown', e => {
  if (e.key === 'Enter') confirmarNovoNicho();
});

const initialTab = '<%= tab %>' || localStorage.getItem('catalog-tab') || 'empresas';
switchTab(initialTab);
</script>
</body>
</html>
