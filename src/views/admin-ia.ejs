<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agente Lina — Paytcall Operações</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
  <style>
    .lina-hero {
      display: flex; align-items: center; gap: 20px;
      background: linear-gradient(135deg, #e47c24 0%, #c46918 100%);
      border-radius: 14px; padding: 28px 32px; margin-bottom: 24px;
      color: #fff;
    }
    .lina-avatar-lg {
      width: 72px; height: 72px; border-radius: 99px;
      background: rgba(255,255,255,.2); display: flex; align-items: center;
      justify-content: center; font-family: 'Bebas Neue', sans-serif;
      font-size: 32px; letter-spacing: .5px; color: #fff; flex-shrink: 0;
      border: 2px solid rgba(255,255,255,.35);
    }
    .lina-hero h1 { font-size: 22px; font-weight: 800; margin: 0 0 4px; letter-spacing: -.3px; }
    .lina-hero p { font-size: 14px; opacity: .85; margin: 0; line-height: 1.5; }
    .lina-badge {
      display: inline-flex; align-items: center; gap: 5px;
      background: rgba(255,255,255,.2); border-radius: 99px;
      padding: 3px 10px; font-size: 11px; font-weight: 700;
      letter-spacing: .5px; margin-top: 8px;
    }
    .lina-dot { width: 6px; height: 6px; border-radius: 99px; background: #4ade80; }

    .cap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 14px; margin-bottom: 24px; }
    .cap-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 16px 18px;
    }
    .cap-icon {
      width: 36px; height: 36px; border-radius: 8px;
      background: rgba(228,124,36,.1); display: flex; align-items: center;
      justify-content: center; margin-bottom: 10px;
    }
    .cap-icon svg { width: 18px; height: 18px; stroke: var(--brand); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .cap-title { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
    .cap-desc { font-size: 12px; color: var(--text-3); line-height: 1.55; }

    .chat-full-wrap {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden; display: flex;
      flex-direction: column; height: 560px;
    }
    .chat-full-header {
      padding: 16px 20px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 12px; background: var(--surface);
    }
    .chat-full-messages {
      flex: 1; overflow-y: auto; padding: 18px 20px;
      display: flex; flex-direction: column; gap: 14px;
      scroll-behavior: smooth;
    }
    .chat-full-footer {
      border-top: 1px solid var(--border); padding: 14px 16px;
      display: flex; align-items: center; gap: 10px; background: var(--surface);
    }
    .chat-full-input {
      flex: 1; border: 1.5px solid var(--border); border-radius: 10px;
      padding: 10px 14px; font-size: 14px; font-family: inherit;
      color: var(--text); background: var(--bg); outline: none;
      resize: none; line-height: 1.5; max-height: 120px;
      transition: border-color .15s;
    }
    .chat-full-input:focus { border-color: var(--brand); }
    .chat-full-input::placeholder { color: var(--text-4); }
    .chat-send-btn {
      width: 40px; height: 40px; border-radius: 10px; border: none;
      background: var(--brand); color: #fff; cursor: pointer; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      transition: background .15s, transform .1s;
    }
    .chat-send-btn:hover { background: #c46918; }
    .chat-send-btn:active { transform: scale(.95); }
    .chat-send-btn svg { width: 16px; height: 16px; stroke: #fff; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

    .msg-row { display: flex; gap: 8px; }
    .msg-row.user { flex-direction: row-reverse; }
    .msg-av {
      width: 30px; height: 30px; border-radius: 99px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; font-family: 'Bebas Neue', sans-serif;
    }
    .msg-av.lina { background: linear-gradient(135deg,#e47c24,#c46918); color: #fff; }
    .msg-av.user-av { background: var(--border); color: var(--text-3); }
    .msg-bubble {
      max-width: 78%; padding: 10px 14px; border-radius: 14px;
      font-size: 13.5px; line-height: 1.6; color: var(--text-2);
    }
    .msg-bubble.lina { background: var(--bg); border: 1px solid var(--border); border-bottom-left-radius: 4px; }
    .msg-bubble.user { background: var(--brand); color: #fff; border-bottom-right-radius: 4px; }
    .msg-bubble.thinking { opacity: .6; font-style: italic; }
    .msg-bubble ul { margin: 6px 0 0 16px; padding: 0; }
    .msg-bubble li { margin-bottom: 3px; }
    .msg-time { font-size: 10px; color: var(--text-4); margin-top: 3px; text-align: right; }
    .msg-row.user .msg-time { text-align: left; }
    .suggestions { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 4px; }
    .suggestion-btn {
      background: rgba(228,124,36,.08); border: 1px solid rgba(228,124,36,.25);
      border-radius: 99px; padding: 5px 12px; font-size: 12px; font-weight: 600;
      color: var(--brand); cursor: pointer; transition: background .15s;
    }
    .suggestion-btn:hover { background: rgba(228,124,36,.16); }

    /* FAQ */
    .faq-item {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 14px 16px; display: flex;
      gap: 12px; align-items: flex-start;
    }
    .faq-body { flex: 1; min-width: 0; }
    .faq-q { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
    .faq-a { font-size: 12px; color: var(--text-3); line-height: 1.5; }
    .faq-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .faq-actions button {
      padding: 4px 10px; font-size: 11px; font-weight: 600;
      border-radius: 6px; border: 1px solid var(--border);
      background: var(--surface); color: var(--text-3); cursor: pointer;
      transition: background .15s, color .15s;
    }
    .faq-actions button:hover { background: var(--border); color: var(--text); }
    .faq-actions button.danger:hover { background: rgba(var(--danger-rgb),.1); color: var(--danger); border-color: var(--danger); }
  </style>
</head>
<body>
<div class="app">
  <%- include('partials/sidebar', { activePage: 'admin-ia' }) %>
  <div class="main">
    <%- include('partials/topbar', {
      pageTitle: 'Agente Lina',
      breadcrumb: [{ label: 'Paytcall', href: '/dashboard' }, { label: 'Admin' }, { label: 'Agente Lina' }]
    }) %>

    <div class="page">

      <!-- Hero -->
      <div class="lina-hero">
        <div class="lina-avatar-lg">L</div>
        <div>
          <h1>Lina — Agente de IA Paytcall</h1>
          <p>Assistente inteligente integrada ao portal para apoiar o time de operações em tempo real.</p>
          <div class="lina-badge">
            <div class="lina-dot"></div>
            Online · Gemini 2.5 Flash (Google)
          </div>
        </div>
      </div>

      <!-- Capacidades -->
      <div style="margin-bottom:10px;font-size:11px;font-weight:700;color:var(--text-4);text-transform:uppercase;letter-spacing:.8px">O que Lina pode fazer</div>
      <div class="cap-grid">
        <div class="cap-card">
          <div class="cap-icon">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <div class="cap-title">Consultar pedidos</div>
          <div class="cap-desc">Buscar status de rastreios, histórico de clientes e situação de pedidos diretamente no banco de dados.</div>
        </div>
        <div class="cap-card">
          <div class="cap-icon">
            <svg viewBox="0 0 24 24"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
          </div>
          <div class="cap-title">Apoio em tickets</div>
          <div class="cap-desc">Sugerir soluções, classificar solicitações e apoiar a tomada de decisão da equipe de suporte.</div>
        </div>
        <div class="cap-card">
          <div class="cap-icon">
            <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div class="cap-title">Análises e relatórios</div>
          <div class="cap-desc">Interpretar métricas do portal, identificar padrões e responder perguntas sobre operação.</div>
        </div>
        <div class="cap-card">
          <div class="cap-icon">
            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <div class="cap-title">Conversa natural</div>
          <div class="cap-desc">Responder dúvidas sobre processos, políticas e procedimentos internos da operação Paytcall.</div>
        </div>
      </div>

      <!-- Chat completo -->
      <div style="margin-bottom:10px;font-size:11px;font-weight:700;color:var(--text-4);text-transform:uppercase;letter-spacing:.8px">Conversar com Lina</div>
      <div class="chat-full-wrap" style="margin-bottom:24px">
        <div class="chat-full-header">
          <div style="width:36px;height:36px;border-radius:99px;background:linear-gradient(135deg,#e47c24,#c46918);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:16px;color:#fff;position:relative">
            L
            <div style="position:absolute;bottom:1px;right:1px;width:9px;height:9px;border-radius:99px;background:var(--success);border:2px solid var(--surface)"></div>
          </div>
          <div>
            <div style="font-size:13.5px;font-weight:700;color:var(--text)">Lina</div>
            <div style="font-size:11px;color:var(--text-4)">Agente de IA · Paytcall Operações</div>
          </div>
          <div style="margin-left:auto;display:flex;align-items:center;gap:6px">
            <div style="width:7px;height:7px;border-radius:99px;background:var(--success)"></div>
            <span style="font-size:12px;color:var(--text-3)">Disponível</span>
          </div>
        </div>

        <div class="chat-full-messages" id="fullChatMessages">
          <div class="msg-row">
            <div class="msg-av lina">L</div>
            <div>
              <div class="msg-bubble lina">
                Olá! Sou a Lina, agente de IA da Paytcall Operações. Posso ajudar com consultas de pedidos, análise de tickets, métricas operacionais e muito mais.
                <div class="suggestions" style="margin-top:10px">
                  <button class="suggestion-btn" onclick="sendSuggestion('Como estão os rastreios hoje?')">Rastreios hoje</button>
                  <button class="suggestion-btn" onclick="sendSuggestion('Quantos tickets estão em aberto?')">Tickets abertos</button>
                  <button class="suggestion-btn" onclick="sendSuggestion('Como funciona o scheduler?')">Como funciona o scheduler?</button>
                </div>
              </div>
              <div class="msg-time">agora</div>
            </div>
          </div>
        </div>

        <div class="chat-full-footer">
          <textarea
            id="fullChatInput"
            class="chat-full-input"
            rows="1"
            placeholder="Digite sua mensagem para Lina..."
            onkeydown="handleFullChatKey(event)"
            oninput="autoResize(this)"
          ></textarea>
          <button class="chat-send-btn" onclick="sendFullChat()" title="Enviar">
            <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </div>

      <!-- FAQs da Lina -->
      <div style="margin-bottom:10px;font-size:11px;font-weight:700;color:var(--text-4);text-transform:uppercase;letter-spacing:.8px">Perguntas Frequentes (FAQs da Lina)</div>
      <div class="card" style="margin-bottom:24px">
        <div class="card-header">
          <div>
            <div style="font-size:14px;font-weight:700;color:var(--text)">Base de conhecimento</div>
            <div style="font-size:12px;color:var(--text-3);margin-top:2px">Perguntas e respostas que a Lina usa para responder sobre políticas e procedimentos internos.</div>
          </div>
          <button class="btn btn-primary btn-sm" onclick="openFaqModal()">+ Adicionar FAQ</button>
        </div>
        <div class="card-body" style="padding:16px">
          <div id="faqList" style="display:flex;flex-direction:column;gap:10px">
            <div style="text-align:center;color:var(--text-4);padding:24px;font-size:13px" id="faqEmpty">Carregando FAQs...</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Modal FAQ -->
<div id="faqModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;display:none;align-items:center;justify-content:center">
  <div class="card" style="width:100%;max-width:560px;margin:16px">
    <div class="card-header">
      <span id="faqModalTitle" style="font-weight:700;font-size:15px">Nova FAQ</span>
    </div>
    <div class="card-body" style="padding:20px;display:flex;flex-direction:column;gap:14px">
      <div class="form-group">
        <label class="form-label">Pergunta</label>
        <input type="text" class="form-input" id="faqQ" placeholder="Ex: Qual é o prazo de entrega?">
      </div>
      <div class="form-group">
        <label class="form-label">Resposta</label>
        <textarea class="form-input" id="faqA" rows="4" placeholder="Ex: O prazo padrão é de 7 a 12 dias úteis após a postagem." style="resize:vertical"></textarea>
      </div>
    </div>
    <div class="card-footer" style="display:flex;justify-content:flex-end;gap:8px">
      <button class="btn btn-secondary btn-sm" onclick="closeFaqModal()">Cancelar</button>
      <button class="btn btn-primary btn-sm" onclick="saveFaqItem()">Salvar</button>
    </div>
  </div>
</div>

<script>
const USER_INIT = '<%= typeof currentUser !== "undefined" ? currentUser.name.charAt(0).toUpperCase() : "?" %>';

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function handleFullChatKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendFullChat(); }
}

function sendSuggestion(text) {
  document.getElementById('fullChatInput').value = text;
  sendFullChat();
}

function appendMsg(role, html, isLoading) {
  const wrap = document.getElementById('fullChatMessages');
  const isUser = role === 'user';
  const div = document.createElement('div');
  div.className = 'msg-row' + (isUser ? ' user' : '');
  if (isLoading) div.id = 'fullChatLoading';
  const now = new Date().toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit' });
  div.innerHTML = `
    <div class="msg-av ${isUser ? 'user-av' : 'lina'}">${isUser ? USER_INIT : 'L'}</div>
    <div>
      <div class="msg-bubble ${isUser ? 'user' : 'lina'}${isLoading ? ' thinking' : ''}">${html}</div>
      <div class="msg-time">${now}</div>
    </div>`;
  wrap.appendChild(div);
  wrap.scrollTop = wrap.scrollHeight;
  return div;
}

function mdToHtml(text) {
  return text
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/`(.*?)`/g,'<code style="background:var(--border);padding:1px 5px;border-radius:4px;font-size:12px">$1</code>')
    .replace(/\n/g,'<br>');
}

async function sendFullChat() {
  const input = document.getElementById('fullChatInput');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';
  input.style.height = 'auto';

  appendMsg('user', mdToHtml(text));
  const loading = appendMsg('lina', 'Lina está digitando...', true);

  try {
    const res = await fetch('/api/ai/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text }),
    });
    const data = await res.json();
    loading.remove();
    appendMsg('lina', mdToHtml(data.reply || 'Desculpe, não consegui processar sua mensagem.'));
  } catch(e) {
    loading.remove();
    appendMsg('lina', 'Erro de conexão. Tente novamente.');
  }
}

// ── FAQs ────────────────────────────────────────────────────────────────
let faqs = [];
let editingIndex = -1;

async function loadFaqs() {
  try {
    const res = await fetch('/api/ai/faqs');
    const data = await res.json();
    faqs = data.faqs || [];
    renderFaqs();
  } catch(e) {
    document.getElementById('faqEmpty').textContent = 'Erro ao carregar FAQs.';
  }
}

function renderFaqs() {
  const list = document.getElementById('faqList');
  if (!faqs.length) {
    list.innerHTML = '<div style="text-align:center;color:var(--text-4);padding:24px;font-size:13px">Nenhuma FAQ cadastrada. Adicione perguntas e respostas para enriquecer o conhecimento da Lina.</div>';
    return;
  }
  list.innerHTML = faqs.map((f, i) => `
    <div class="faq-item">
      <div class="faq-body">
        <div class="faq-q">${escHtml(f.q)}</div>
        <div class="faq-a">${escHtml(f.a)}</div>
      </div>
      <div class="faq-actions">
        <button onclick="openFaqModal(${i})">Editar</button>
        <button class="danger" onclick="deleteFaq(${i})">Excluir</button>
      </div>
    </div>`).join('');
}

function escHtml(s) {
  return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function openFaqModal(index) {
  editingIndex = (index !== undefined) ? index : -1;
  document.getElementById('faqModalTitle').textContent = editingIndex >= 0 ? 'Editar FAQ' : 'Nova FAQ';
  document.getElementById('faqQ').value = editingIndex >= 0 ? (faqs[editingIndex].q || '') : '';
  document.getElementById('faqA').value = editingIndex >= 0 ? (faqs[editingIndex].a || '') : '';
  document.getElementById('faqModal').style.display = 'flex';
  setTimeout(() => document.getElementById('faqQ').focus(), 50);
}

function closeFaqModal() {
  document.getElementById('faqModal').style.display = 'none';
}

async function saveFaqItem() {
  const q = document.getElementById('faqQ').value.trim();
  const a = document.getElementById('faqA').value.trim();
  if (!q || !a) return alert('Preencha a pergunta e a resposta.');

  if (editingIndex >= 0) {
    faqs[editingIndex] = { q, a };
  } else {
    faqs.push({ q, a });
  }
  closeFaqModal();
  await persistFaqs();
}

function deleteFaq(index) {
  showConfirm('Excluir esta FAQ?', async () => {
    faqs.splice(index, 1);
    await persistFaqs();
  }, { okLabel: 'Excluir', okClass: 'btn-danger' });
}

async function persistFaqs() {
  try {
    const res = await fetch('/api/ai/faqs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ faqs }),
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'Erro ao salvar');
    renderFaqs();
  } catch(e) {
    alert('Erro ao salvar FAQs: ' + e.message);
    // recarrega para ter estado consistente
    await loadFaqs();
  }
}

document.getElementById('faqModal').addEventListener('click', function(e) {
  if (e.target === this) closeFaqModal();
});

loadFaqs();
</script>

<script>
const NOTIF_USER = '<%= typeof currentUser !== "undefined" ? currentUser.name : "" %>';
function toggleNotifs() { const dd=document.getElementById('notifDropdown'); dd.classList.toggle('open'); if(dd.classList.contains('open')) loadNotifs(); }
async function loadNotifs() { try { const r=await fetch('/api/notifications'); const {notifications,unread}=await r.json(); const b=document.getElementById('notifBadge'); b.style.display=unread>0?'block':'none'; b.textContent=unread; const list=document.getElementById('notifList'); if(!notifications.length){list.innerHTML='<div style="text-align:center;color:var(--text-4);padding:24px;font-size:13px">Nenhuma notificação</div>';return;} list.innerHTML=notifications.map(n=>`<a href="/pedido/${n.order_id||n.tracking_code||''}" class="notif-item${n.is_read?'':' unread'}"><div style="font-size:13px;color:var(--text-2)">${n.message}</div></a>`).join(''); } catch(e){} }
async function markAllRead() { await fetch('/api/notifications/read',{method:'POST'}); loadNotifs(); }
document.addEventListener('click',(e)=>{ const dd=document.getElementById('notifDropdown'); const btn=document.getElementById('notifBtn'); if(dd&&btn&&!dd.contains(e.target)&&!btn.contains(e.target))dd.classList.remove('open'); });
</script>
</body>
</html>
