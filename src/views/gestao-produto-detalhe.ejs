<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= produto.nome %> — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-catalogo' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: produto.nome, breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Catálogo', href: '/gestao/catalogo?tab=produtos' },
      { label: produto.nome }
    ] }) %>

    <div class="page">

      <div class="page-header">
        <div>
          <h1 class="page-title"><%= produto.nome %></h1>
          <% if (produto.nicho) { %>
            <p class="page-subtitle"><%= produto.nicho %></p>
          <% } %>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <% if (produto.sku) { %>
            <span class="badge badge-neutral">SKU: <%= produto.sku %></span>
          <% } %>
          <% if (canEdit) { %>
            <button class="btn btn-secondary btn-sm" onclick="openModal('modal-editar-produto')">Editar</button>
          <% } %>
          <% if (isAdmin) { %>
            <button class="btn btn-sm" style="background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger-border)" onclick="confirmarExclusao()">Excluir</button>
          <% } %>
        </div>
      </div>

      <!-- Grid: Conteúdo + Playbook -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start">

        <!-- Coluna esquerda: informações do produto -->
        <div style="display:flex;flex-direction:column;gap:16px">

          <% if (produto.o_que_e) { %>
          <div class="card">
            <div class="card-header">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span style="font-weight:600;font-size:14px">O que é?</span>
            </div>
            <div class="card-body"><p style="font-size:13px;color:var(--text-2);line-height:1.6;margin:0"><%= produto.o_que_e %></p></div>
          </div>
          <% } %>

          <% if (produto.composicao) { %>
          <div class="card">
            <div class="card-header">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
              <span style="font-weight:600;font-size:14px">Composição</span>
            </div>
            <div class="card-body"><p style="font-size:13px;color:var(--text-2);line-height:1.6;margin:0;white-space:pre-wrap"><%= produto.composicao %></p></div>
          </div>
          <% } %>

          <% if (produto.como_funciona) { %>
          <div class="card">
            <div class="card-header">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              <span style="font-weight:600;font-size:14px">Como funciona?</span>
            </div>
            <div class="card-body"><p style="font-size:13px;color:var(--text-2);line-height:1.6;margin:0;white-space:pre-wrap"><%= produto.como_funciona %></p></div>
          </div>
          <% } %>

          <% if (produto.descricao) { %>
          <div class="card">
            <div class="card-header">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span style="font-weight:600;font-size:14px">Descrição</span>
            </div>
            <div class="card-body"><p style="font-size:13px;color:var(--text-2);line-height:1.6;margin:0;white-space:pre-wrap"><%= produto.descricao %></p></div>
          </div>
          <% } %>

          <% if (!produto.o_que_e && !produto.composicao && !produto.como_funciona && !produto.descricao) { %>
          <div class="card">
            <div class="card-body" style="text-align:center;color:var(--text-3);padding:32px;font-size:13px">
              Nenhuma informação cadastrada.<% if (canEdit) { %> <a href="#" onclick="openModal('modal-editar-produto');return false" style="color:var(--brand)">Editar produto</a><% } %>
            </div>
          </div>
          <% } %>

        </div>

        <!-- Coluna direita: playbook mídias -->
        <div style="display:flex;flex-direction:column;gap:16px">

          <!-- Fotos -->
          <div class="card">
            <div class="card-header" style="justify-content:space-between">
              <div style="display:flex;align-items:center;gap:8px">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <span style="font-weight:600;font-size:14px">Fotos (<span id="fotos-count"><%= fotos.length %></span>)</span>
              </div>
              <% if (canEdit) { %>
              <label style="cursor:pointer;font-size:12px;color:var(--brand);font-weight:600">
                + Adicionar
                <input type="file" accept="image/jpeg,image/png,image/webp" multiple style="display:none" onchange="uploadMidias(this,'fotos')">
              </label>
              <% } %>
            </div>
            <div class="card-body" id="fotos-grid">
              <% if (fotos.length === 0) { %>
              <div id="fotos-empty" style="text-align:center;color:var(--text-4);font-size:13px;padding:16px">Nenhuma foto</div>
              <% } %>
              <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:8px" id="fotos-container">
                <% fotos.forEach(f => { %>
                <div style="position:relative" class="midia-item">
                  <a href="<%= f.url %>" target="_blank" rel="noopener">
                    <img src="<%= f.url %>" alt="Foto" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:var(--radius);border:1px solid var(--border)">
                  </a>
                  <% if (canEdit) { %>
                  <button onclick="deletarMidia('<%= f.path %>',this.closest('.midia-item'))" style="position:absolute;top:3px;right:3px;background:rgba(0,0,0,.6);border:none;border-radius:50%;width:20px;height:20px;color:#fff;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;line-height:1">&times;</button>
                  <% } %>
                </div>
                <% }) %>
              </div>
            </div>
          </div>

          <!-- Depoimentos -->
          <div class="card">
            <div class="card-header" style="justify-content:space-between">
              <div style="display:flex;align-items:center;gap:8px">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                <span style="font-weight:600;font-size:14px">Depoimentos (<span id="dep-count"><%= depoimentos.length %></span>)</span>
              </div>
              <% if (canEdit) { %>
              <label style="cursor:pointer;font-size:12px;color:var(--brand);font-weight:600">
                + Adicionar
                <input type="file" accept="image/jpeg,image/png,image/webp,video/mp4,video/webm" multiple style="display:none" onchange="uploadMidias(this,'depoimentos')">
              </label>
              <% } %>
            </div>
            <div class="card-body" id="dep-container" style="display:flex;flex-direction:column;gap:10px">
              <% if (depoimentos.length === 0) { %>
              <div id="dep-empty" style="text-align:center;color:var(--text-4);font-size:13px;padding:16px">Nenhum depoimento</div>
              <% } %>
              <% depoimentos.forEach(d => { %>
              <div class="midia-item" style="position:relative">
                <% if (d.isVideo) { %>
                  <video controls style="width:100%;border-radius:var(--radius);border:1px solid var(--border)">
                    <source src="<%= d.url %>" type="video/mp4">
                  </video>
                <% } else { %>
                  <a href="<%= d.url %>" target="_blank" rel="noopener">
                    <img src="<%= d.url %>" alt="Depoimento" style="width:100%;border-radius:var(--radius);border:1px solid var(--border)">
                  </a>
                <% } %>
                <% if (canEdit) { %>
                <button onclick="deletarMidia('<%= d.path %>',this.closest('.midia-item'))" style="position:absolute;top:6px;right:6px;background:rgba(0,0,0,.6);border:none;border-radius:50%;width:22px;height:22px;color:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center">&times;</button>
                <% } %>
              </div>
              <% }) %>
            </div>
          </div>

        </div>

      </div><!-- /grid -->

      <!-- Feedbacks + formulário — largura total -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px;align-items:start">

        <!-- Lista feedbacks -->
        <div class="card" style="padding:0">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            <span style="font-weight:600;font-size:14px">Feedbacks (<%= feedbacks.length %>)</span>
          </div>
          <div style="max-height:320px;overflow-y:auto">
            <%- include('partials/feedback-list', {
              feedbacks,
              redirectUrl: '/gestao/produtos/' + produto.id,
              currentUserName: currentUser.name || currentUser.email,
              isAdmin
            }) %>
          </div>
        </div>

        <!-- Novo feedback -->
        <div class="card">
          <div class="card-header">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            <span style="font-weight:600;font-size:14px">Registrar Feedback</span>
          </div>
          <div class="card-body">
            <form method="POST" action="/gestao/feedbacks">
              <input type="hidden" name="produto" value="<%= produto.nome %>">
              <input type="hidden" name="redirect" value="/gestao/produtos/<%= produto.id %>">
              <textarea name="texto" class="form-input" rows="6" placeholder="Registre um problema, atraso, observação sobre este produto..." required style="resize:vertical;width:100%;margin-bottom:12px"></textarea>
              <button type="submit" class="btn btn-primary" style="width:100%">Salvar Feedback</button>
            </form>
          </div>
        </div>

      </div>

    </div><!-- /.page -->
  </div><!-- /.main -->

  <%- include('partials/ai-chat') %>
</div>

<!-- Modal Editar Produto -->
<% if (canEdit) { %>
<div id="modal-editar-produto" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;overflow-y:auto;padding:40px 20px">
  <div class="card" style="max-width:600px;margin:0 auto">
    <div class="card-header" style="justify-content:space-between">
      <span style="font-weight:700;font-size:15px">Editar Produto</span>
      <button onclick="closeModal('modal-editar-produto')" style="background:none;border:none;cursor:pointer;color:var(--text-3);font-size:20px;line-height:1">&times;</button>
    </div>
    <form method="POST" action="/gestao/produtos/<%= produto.id %>/editar">
      <div style="padding:20px;display:flex;flex-direction:column;gap:14px">
        <div class="form-group">
          <label class="form-label">Nome *</label>
          <input name="nome" class="form-input" required value="<%= produto.nome %>">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
          <div class="form-group">
            <label class="form-label">Nicho</label>
            <input name="nicho" class="form-input" value="<%= produto.nicho || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">SKU</label>
            <input name="sku" class="form-input" value="<%= produto.sku || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Playbook Slug</label>
            <input name="playbook_slug" class="form-input" value="<%= produto.playbook_slug || '' %>" placeholder="slug-produto">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">O que é?</label>
          <textarea name="o_que_e" class="form-input" rows="3" style="resize:vertical"><%= produto.o_que_e || '' %></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Como funciona?</label>
          <textarea name="como_funciona" class="form-input" rows="3" style="resize:vertical"><%= produto.como_funciona || '' %></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Composição</label>
          <textarea name="composicao" class="form-input" rows="3" style="resize:vertical"><%= produto.composicao || '' %></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Descrição</label>
          <textarea name="descricao" class="form-input" rows="3" style="resize:vertical"><%= produto.descricao || '' %></textarea>
        </div>
      </div>
      <div class="card-footer" style="justify-content:flex-end;gap:8px">
        <button type="button" onclick="closeModal('modal-editar-produto')" class="btn btn-secondary">Cancelar</button>
        <button type="submit" class="btn btn-primary">Salvar alterações</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<% if (isAdmin) { %>
<form id="form-excluir" method="POST" action="/gestao/produtos/<%= produto.id %>/excluir" style="display:none"></form>
<% } %>

<script>
const PLAYBOOK_SLUG = '<%= playbook_slug %>';
function editarFb(id) {
  document.querySelector('.fb-view-' + id).style.display = 'none';
  document.querySelector('.fb-edit-' + id).style.display = '';
}
function cancelarEditFb(id) {
  document.querySelector('.fb-view-' + id).style.display = '';
  document.querySelector('.fb-edit-' + id).style.display = 'none';
}

function openModal(id) { document.getElementById(id).style.display = ''; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }
document.querySelectorAll('[id^="modal-"]').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) closeModal(m.id); });
});

function confirmarExclusao() {
  showConfirm('Excluir o produto "<%= produto.nome %>"? Esta ação não pode ser desfeita.', () => {
    document.getElementById('form-excluir').submit();
  }, { okLabel: 'Excluir', okClass: 'btn-danger' });
}

async function uploadMidias(input, tipo) {
  const files = [...input.files];
  if (!files.length) return;
  input.disabled = true;

  for (const file of files) {
    const base64 = await new Promise(r => {
      const reader = new FileReader();
      reader.onload = e => r(e.target.result.split(',')[1]);
      reader.readAsDataURL(file);
    });

    try {
      const resp = await fetch('/gestao/api/upload-media', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ base64, mimeType: file.type, tipo, slug: PLAYBOOK_SLUG }),
      });
      const data = await resp.json();
      if (!data.ok) { alert('Erro: ' + data.error); continue; }

      // Adiciona ao DOM sem recarregar
      const isVideo = file.type.startsWith('video/');
      const container = tipo === 'fotos'
        ? document.getElementById('fotos-container')
        : document.getElementById('dep-container');
      const empty = document.getElementById(tipo === 'fotos' ? 'fotos-empty' : 'dep-empty');
      if (empty) empty.remove();

      const wrapper = document.createElement('div');
      wrapper.className = 'midia-item';
      wrapper.style.position = 'relative';

      if (isVideo) {
        wrapper.innerHTML = `<video controls style="width:100%;border-radius:var(--radius);border:1px solid var(--border)"><source src="${data.url}" type="${file.type}"></video>
          <button onclick="deletarMidia('${data.path}',this.closest('.midia-item'))" style="position:absolute;top:6px;right:6px;background:rgba(0,0,0,.6);border:none;border-radius:50%;width:22px;height:22px;color:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center">&times;</button>`;
        container.appendChild(wrapper);
      } else if (tipo === 'fotos') {
        wrapper.innerHTML = `<a href="${data.url}" target="_blank"><img src="${data.url}" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:var(--radius);border:1px solid var(--border)"></a>
          <button onclick="deletarMidia('${data.path}',this.closest('.midia-item'))" style="position:absolute;top:3px;right:3px;background:rgba(0,0,0,.6);border:none;border-radius:50%;width:20px;height:20px;color:#fff;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center">&times;</button>`;
        container.appendChild(wrapper);
      } else {
        wrapper.innerHTML = `<a href="${data.url}" target="_blank"><img src="${data.url}" style="width:100%;border-radius:var(--radius);border:1px solid var(--border)"></a>
          <button onclick="deletarMidia('${data.path}',this.closest('.midia-item'))" style="position:absolute;top:6px;right:6px;background:rgba(0,0,0,.6);border:none;border-radius:50%;width:22px;height:22px;color:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center">&times;</button>`;
        container.appendChild(wrapper);
      }

      // Atualiza contador
      const countEl = document.getElementById(tipo === 'fotos' ? 'fotos-count' : 'dep-count');
      if (countEl) countEl.textContent = parseInt(countEl.textContent || 0) + 1;
    } catch (e) {
      alert('Erro ao enviar arquivo');
    }
  }

  input.disabled = false;
  input.value = '';
}

async function deletarMidia(path, el) {
  showConfirm('Remover esta mídia? Esta ação não pode ser desfeita.', async () => {
    try {
      const resp = await fetch('/gestao/api/delete-media', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ path }),
      });
      const data = await resp.json();
      if (!data.ok) { alert('Erro: ' + data.error); return; }

      const tipo = path.includes('/fotos/') ? 'fotos' : 'depoimentos';
      const countEl = document.getElementById(tipo === 'fotos' ? 'fotos-count' : 'dep-count');
      if (countEl) countEl.textContent = Math.max(0, parseInt(countEl.textContent || 1) - 1);
      el.remove();
    } catch (e) {
      alert('Erro ao remover mídia');
    }
  }, { okLabel: 'Remover', okClass: 'btn-danger' });
}
</script>
</body>
</html>
