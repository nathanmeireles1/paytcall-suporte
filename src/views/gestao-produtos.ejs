<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Produtos — Paytcall</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<div class="app">

  <%- include('partials/sidebar', { activePage: 'gestao-produtos' }) %>

  <div class="main">
    <%- include('partials/topbar', { pageTitle: 'Produtos', breadcrumb: [
      { label: 'Paytcall', href: '/dashboard' },
      { label: 'Produtos' }
    ] }) %>

    <div class="page">

      <div class="page-header">
        <div>
          <h1 class="page-title">Produtos</h1>
          <p class="page-subtitle">Catálogo de produtos por nicho</p>
        </div>
        <a href="/gestao/segmentos" class="btn btn-secondary btn-sm" style="align-self:center">Ver segmentos</a>
      </div>

      <!-- Filtros -->
      <form method="GET" action="/gestao/produtos" class="toolbar" style="flex-wrap:wrap;gap:8px;margin-bottom:20px">
        <input
          type="text"
          name="search"
          class="form-input"
          placeholder="Buscar produto..."
          value="<%= filters.search %>"
          style="flex:1;min-width:200px;max-width:320px"
        >
        <select name="nicho" class="form-select" style="min-width:160px">
          <option value="">Todos os nichos</option>
          <% nichos.forEach(n => { %>
            <option value="<%= n %>" <%= filters.nicho === n ? 'selected' : '' %>><%= n %></option>
          <% }) %>
        </select>
        <button type="submit" class="btn btn-primary">Filtrar</button>
        <% if (filters.search || filters.nicho) { %>
          <a href="/gestao/produtos" class="btn btn-secondary">Limpar</a>
        <% } %>
      </form>

      <!-- Exibição por nicho (quando sem filtro) ou lista plana (com filtro) -->
      <% if (!filters.search && !filters.nicho) { %>

        <% Object.entries(porNicho).sort(([a],[b]) => a.localeCompare(b)).forEach(([nicho, itens]) => { %>
        <div style="margin-bottom:28px">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
            <h2 style="font-size:15px;font-weight:600;color:var(--text);margin:0"><%= nicho %></h2>
            <span style="font-size:12px;color:var(--text-4)"><%= itens.length %> produto<%= itens.length !== 1 ? 's' : '' %></span>
            <a href="/gestao/segmentos/<%= encodeURIComponent(nicho) %>" style="font-size:12px;color:var(--brand);margin-left:auto">Ver segmento</a>
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px">
            <% itens.forEach(p => { %>
            <a href="/gestao/produtos/<%= p.id %>" style="text-decoration:none">
              <div class="card" style="padding:16px;cursor:pointer;transition:box-shadow .15s" onmouseenter="this.style.boxShadow='var(--shadow-md)'" onmouseleave="this.style.boxShadow=''">
                <div style="font-weight:600;font-size:14px;color:var(--text);margin-bottom:4px;line-height:1.3"><%= p.nome %></div>
                <% if (p.sku) { %>
                  <div style="font-size:11px;color:var(--text-4);margin-bottom:6px">SKU: <%= p.sku %></div>
                <% } %>
                <% if (p.descricao) { %>
                  <p style="font-size:12px;color:var(--text-3);margin:0;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                    <%= p.descricao %>
                  </p>
                <% } %>
              </div>
            </a>
            <% }) %>
          </div>
        </div>
        <% }) %>

      <% } else { %>

        <!-- Lista plana quando há filtro -->
        <p style="font-size:13px;color:var(--text-3);margin-bottom:12px">
          <%= produtos.length %> produto<%= produtos.length !== 1 ? 's' : '' %> encontrado<%= produtos.length !== 1 ? 's' : '' %>
        </p>
        <div class="card" style="padding:0">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Nicho</th>
                  <th>SKU</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% if (produtos.length === 0) { %>
                <tr><td colspan="4" style="text-align:center;color:var(--text-3);padding:32px">Nenhum produto encontrado</td></tr>
                <% } %>
                <% produtos.forEach(p => { %>
                <tr>
                  <td style="font-weight:500"><%= p.nome %></td>
                  <td><% if (p.nicho) { %><span class="badge badge-neutral"><%= p.nicho %></span><% } else { %><span style="color:var(--text-4)">—</span><% } %></td>
                  <td style="color:var(--text-3);font-size:13px"><%= p.sku || '—' %></td>
                  <td style="text-align:right"><a href="/gestao/produtos/<%= p.id %>" class="btn btn-secondary btn-sm">Ver</a></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

      <% } %>

    </div><!-- /.page -->
  </div><!-- /.main -->

  <%- include('partials/ai-chat') %>
</div>
</body>
</html>
