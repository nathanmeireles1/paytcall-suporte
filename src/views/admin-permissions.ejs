<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Permissões — payt Tracker</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f5; color: #333; }
    .navbar { background: #1a1a2e; padding: 0 24px; display: flex; align-items: center; height: 56px; gap: 16px; }
    .navbar h1 { color: #fff; font-size: 18px; font-weight: 700; }
    .navbar .nav-links { margin-left: auto; display: flex; gap: 16px; align-items: center; }
    .navbar a { color: #aaa; font-size: 13px; text-decoration: none; }
    .navbar a:hover { color: #fff; }
    .container { max-width: 1200px; margin: 0 auto; padding: 24px; }

    .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; }
    .alert-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }

    .card { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.08); overflow: hidden; }
    .card-header { padding: 16px 20px; border-bottom: 1px solid #f0f0f0; }
    .card-header h2 { font-size: 16px; font-weight: 600; }
    .card-header p { font-size: 13px; color: #666; margin-top: 4px; }

    .perm-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .perm-table th { padding: 10px 12px; text-align: center; font-weight: 600; color: #555; font-size: 11px; text-transform: uppercase; letter-spacing: .5px; background: #f8f9fa; border-bottom: 2px solid #e5e7eb; }
    .perm-table th:first-child { text-align: left; width: 200px; }
    .perm-table td { padding: 8px 12px; border-top: 1px solid #f0f0f0; text-align: center; }
    .perm-table td:first-child { text-align: left; font-weight: 500; }
    .perm-table tr:hover td { background: #fafafa; }

    .role-header { background: #f0f2ff !important; }
    .role-header td { font-weight: 700; color: #4f46e5; font-size: 14px; padding: 12px; border-top: 2px solid #e0e0e0; }

    .module-label { padding-left: 16px; color: #333; }

    input[type=checkbox] { width: 18px; height: 18px; cursor: pointer; accent-color: #4f46e5; }

    .actions { padding: 16px 20px; border-top: 1px solid #f0f0f0; display: flex; gap: 12px; align-items: center; }
    .btn { padding: 8px 20px; border-radius: 6px; border: none; cursor: pointer; font-size: 14px; font-weight: 500; }
    .btn-primary { background: #4f46e5; color: #fff; }
    .btn-primary:hover { background: #4338ca; }
    .btn-ghost { background: transparent; border: 1px solid #ddd; color: #555; text-decoration: none; }
    .btn-ghost:hover { background: #f5f5f5; }

    .legend { display: flex; gap: 20px; margin-bottom: 16px; font-size: 12px; color: #666; }
    .legend span { display: flex; align-items: center; gap: 4px; }
    .legend-icon { width: 14px; height: 14px; border-radius: 3px; display: inline-block; }
    .legend-view { background: #dbeafe; }
    .legend-create { background: #dcfce7; }
    .legend-edit { background: #fef3c7; }
    .legend-delete { background: #fee2e2; }

    /* Tabs por role */
    .tabs { display: flex; gap: 4px; margin-bottom: 16px; }
    .tab { padding: 8px 16px; border-radius: 8px 8px 0 0; border: 1px solid #ddd; border-bottom: none; background: #f8f9fa; cursor: pointer; font-size: 13px; font-weight: 500; color: #666; }
    .tab.active { background: #fff; color: #4f46e5; border-bottom: 2px solid #fff; position: relative; top: 1px; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
  </style>
</head>
<body>

<nav class="navbar">
  <h1>Permissões por Módulo</h1>
  <div class="nav-links">
    <a href="/admin/users">Usuários</a>
    <a href="/">← Painel</a>
    <% if (typeof currentUser !== 'undefined') { %>
    <span style="color:#4f46e5;background:rgba(79,70,229,.1);padding:4px 10px;border-radius:99px;font-size:12px;font-weight:600"><%= currentUser.name %></span>
    <a href="/logout" style="color:#f87171">Sair</a>
    <% } %>
  </div>
</nav>

<div class="container">

  <% if (typeof saved !== 'undefined' || (typeof require !== 'undefined' && false)) { %>
  <% } %>
  <script>
    if (new URLSearchParams(window.location.search).get('saved')) {
      document.addEventListener('DOMContentLoaded', () => {
        const d = document.createElement('div');
        d.className = 'alert alert-success';
        d.textContent = 'Permissões salvas com sucesso!';
        document.querySelector('.container').prepend(d);
        setTimeout(() => d.remove(), 3000);
      });
    }
  </script>

  <div class="legend">
    <span><span class="legend-icon legend-view"></span> Ver</span>
    <span><span class="legend-icon legend-create"></span> Criar</span>
    <span><span class="legend-icon legend-edit"></span> Editar</span>
    <span><span class="legend-icon legend-delete"></span> Excluir</span>
  </div>

  <form method="POST" action="/admin/permissions">
    <div class="card">
      <div class="card-header">
        <h2>Matriz de Permissões</h2>
        <p>Defina o que cada papel pode fazer em cada módulo. Admin sempre tem acesso total por padrão.</p>
      </div>

      <table class="perm-table">
        <thead>
          <tr>
            <th>Módulo</th>
            <% ROLES.forEach(role => { %>
            <th colspan="4" style="border-left:2px solid #e5e7eb"><%= ROLE_LABELS[role] %></th>
            <% }) %>
          </tr>
          <tr>
            <th></th>
            <% ROLES.forEach(() => { %>
            <th style="border-left:2px solid #e5e7eb;font-size:10px;color:#999">Ver</th>
            <th style="font-size:10px;color:#999">Criar</th>
            <th style="font-size:10px;color:#999">Editar</th>
            <th style="font-size:10px;color:#999">Excluir</th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% MODULES.forEach(mod => { %>
          <tr>
            <td class="module-label"><%= mod.label %></td>
            <% ROLES.forEach(role => {
              const p = (permissions[role] && permissions[role][mod.key]) || {};
            %>
            <td style="border-left:2px solid #f0f0f0">
              <input type="checkbox" name="<%= role %>|<%= mod.key %>|can_view" <%= p.can_view ? 'checked' : '' %>>
            </td>
            <td>
              <input type="checkbox" name="<%= role %>|<%= mod.key %>|can_create" <%= p.can_create ? 'checked' : '' %>>
            </td>
            <td>
              <input type="checkbox" name="<%= role %>|<%= mod.key %>|can_edit" <%= p.can_edit ? 'checked' : '' %>>
            </td>
            <td>
              <input type="checkbox" name="<%= role %>|<%= mod.key %>|can_delete" <%= p.can_delete ? 'checked' : '' %>>
            </td>
            <% }) %>
          </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="actions">
        <button type="submit" class="btn btn-primary">Salvar Permissões</button>
        <a href="/admin/users" class="btn btn-ghost">Voltar</a>
        <span style="margin-left:auto;font-size:12px;color:#999">Alterações entram em vigor imediatamente</span>
      </div>
    </div>
  </form>

</div>

<script>
// Marcar/desmarcar toda a linha (módulo)
document.querySelectorAll('.module-label').forEach(td => {
  td.style.cursor = 'pointer';
  td.title = 'Clique para selecionar/deselecionar tudo nesta linha';
  td.addEventListener('click', () => {
    const row = td.parentElement;
    const checks = row.querySelectorAll('input[type=checkbox]');
    const allChecked = [...checks].every(c => c.checked);
    checks.forEach(c => c.checked = !allChecked);
  });
});
</script>
</body>
</html>
